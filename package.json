{
  "name": "template-upload-app",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:server": "nodemon server.js",
    "dev:tailwind": "npx tailwindcss -i ./public/css/input.css -o ./public/css/style.css --watch",
    "dev": "npm-run-all --parallel dev:server dev:tailwind"
  },
  "dependencies": {
