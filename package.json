    "dotenv": "^17.3.1",
    "ejs": "^3.0.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "mongoose": "^9.2.1",
    "multer": "^2.0.2",
    "sanitize-html": "^2.17.1"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "nodemon": "^3.1.14",
    "npm-run-all": "^1.1.3",
    "tailwindcss": "^4.2.0"
  }
}
