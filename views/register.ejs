<%- include('partials/header') %>
<style>nav { display: none !important; }</style>

<div class="min-h-screen bg-slate-950 flex items-center justify-center px-6">
    <div class="max-w-md w-full bg-slate-900 border border-slate-800 rounded-3xl p-10 shadow-2xl">
        <div class="text-center mb-10">
            <h1 class="text-white font-black text-2xl tracking-tighter">JOIN TEATER <span class="text-blue-500">SAPHALTA</span></h1>
            <p class="text-slate-500 text-xs mt-2 uppercase tracking-widest">Create your creator account</p>
        </div>

        <% if (locals.flash_error && flash_error.length > 0) { %>
            <div class="bg-red-900/40 border border-red-500/40 text-red-300 text-xs rounded-xl px-4 py-3 text-center mb-4">
                <%= flash_error[0] %>
            </div>
        <% } %>
        <% if (locals.flash_success && flash_success.length > 0) { %>
            <div class="bg-green-900/40 border border-green-500/40 text-green-300 text-xs rounded-xl px-4 py-3 text-center mb-4">
                <%= flash_success[0] %>
            </div>
        <% } %>

        <form action="/register" method="POST" class="space-y-6">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div>
                <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest block mb-2">Username</label>
                <input type="text" name="username" required class="w-full p-4 bg-slate-950 border border-slate-800 rounded-xl text-white outline-none focus:border-blue-500 transition font-mono text-sm">
            </div>
            <div>
                <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest block mb-2">Email Address</label>
                <input type="email" name="email" required class="w-full p-4 bg-slate-950 border border-slate-800 rounded-xl text-white outline-none focus:border-blue-500 transition font-mono text-sm">
            </div>
            <div>
                <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest block mb-2">Password</label>
                <input type="password" name="password" required class="w-full p-4 bg-slate-950 border border-slate-800 rounded-xl text-white outline-none focus:border-blue-500 transition font-mono text-sm">
            </div>
            <button type="submit" class="w-full py-4 bg-blue-600 hover:bg-blue-700 text-white font-black uppercase tracking-widest rounded-xl transition shadow-lg shadow-blue-900/20">
                Create Account
            </button>
        </form>
        
        <div class="mt-8 text-center">
	    <p class="text-xs text-slate-500">Already have an account? <a href="/login" class="text-blue-500 font-bold">Login here</a></p>
            
        </div>
    </div>
</div>
