<%- include('partials/admin_header', { pageTitle: 'Keamanan Akun' }) %>

<main class="min-h-screen bg-slate-950 pt-6 pb-24">
<div class="max-w-2xl mx-auto px-4 md:px-6 space-y-8">

    <!-- PAGE HEADER -->
    <div>
        <p class="text-[10px] font-mono text-slate-600 uppercase tracking-[0.3em] mb-1">Pengaturan</p>
        <h1 class="text-2xl font-black text-white tracking-tight">Keamanan Akun</h1>
        <p class="text-slate-500 text-xs mt-1">Kelola password dan verifikasi dua langkah (2FA)</p>
    </div>

    <!-- ALERTS -->
    <% if (success) { %>
    <div class="flex items-center gap-3 px-4 py-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl">
        <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <p class="text-emerald-400 text-xs font-bold"><%= success %></p>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="flex items-center gap-3 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl">
        <svg class="w-4 h-4 text-red-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
        <p class="text-red-400 text-xs font-bold"><%= error %></p>
    </div>
    <% } %>

    <!-- ── TWO-FACTOR AUTHENTICATION ── -->
    <section class="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-800 flex items-center justify-between">
            <div>
                <h2 class="text-sm font-bold text-white">Verifikasi Dua Langkah (2FA)</h2>
                <p class="text-xs text-slate-500 mt-0.5">Wajib untuk akun admin &amp; superadmin</p>
            </div>
            <% if (twoFactorEnabled) { %>
            <span class="flex items-center gap-1.5 px-3 py-1 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-[10px] font-bold uppercase tracking-wider rounded-lg">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span> Aktif
            </span>
            <% } else { %>
            <span class="flex items-center gap-1.5 px-3 py-1 bg-slate-800 text-slate-400 border border-slate-700 text-[10px] font-bold uppercase tracking-wider rounded-lg">
                <span class="w-1.5 h-1.5 rounded-full bg-slate-500"></span> Nonaktif
            </span>
            <% } %>
        </div>

        <div class="px-6 py-5 space-y-5">

            <% if (!twoFactorEnabled && !setupPending) { %>
            <!-- State: 2FA disabled, no setup in progress -->
            <p class="text-xs text-slate-400">
                2FA menambahkan lapisan keamanan ekstra. Setiap login akan meminta kode 6 digit
                dari aplikasi autentikator seperti <strong class="text-white">Google Authenticator</strong>
                atau <strong class="text-white">Authy</strong>.
            </p>
            <form method="POST" action="/admin/security/2fa/setup">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit"
                    class="px-5 py-2.5 bg-violet-600 hover:bg-violet-500 text-white text-xs font-bold rounded-xl transition shadow-lg shadow-violet-900/20">
                    Mulai Setup 2FA
                </button>
            </form>

            <% } else if (setupPending) { %>
            <!-- State: setup in progress — show QR code -->
            <div class="space-y-4">
                <div class="p-3 bg-amber-500/10 border border-amber-500/20 rounded-xl">
                    <p class="text-amber-400 text-xs font-bold">Setup Belum Selesai</p>
                    <p class="text-amber-400/70 text-[11px] mt-1">
                        Scan QR code di bawah dengan aplikasi autentikator, lalu masukkan kode 6 digit untuk mengkonfirmasi.
                    </p>
                </div>

                <div class="flex justify-center">
                    <div class="bg-white p-3 rounded-xl">
                        <img src="<%= qrCodeUrl %>" alt="2FA QR Code" class="w-48 h-48">
                    </div>
                </div>

                <form method="POST" action="/admin/security/2fa/enable" class="space-y-4">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div>
                        <label class="block text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-2">
                            Kode Verifikasi dari Aplikasi
                        </label>
                        <input type="text" name="token" inputmode="numeric" maxlength="6" pattern="[0-9]{6}"
                            required autofocus
                            class="w-full px-4 py-3 bg-slate-950 border border-slate-700 text-white font-mono text-xl
                                   text-center tracking-[0.4em] rounded-xl focus:outline-none focus:border-violet-500 transition"
                            placeholder="000000">
                    </div>
                    <div class="flex gap-3">
                        <button type="submit"
                            class="flex-1 py-2.5 bg-violet-600 hover:bg-violet-500 text-white text-xs font-bold rounded-xl transition">
                            Konfirmasi &amp; Aktifkan 2FA
                        </button>
                        <form method="POST" action="/admin/security/2fa/setup" class="flex-none">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit"
                                class="px-4 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-400 text-xs font-bold rounded-xl transition border border-slate-700">
                                Buat QR Baru
                            </button>
                        </form>
                    </div>
                </form>
            </div>

            <% } else { %>
            <!-- State: 2FA enabled — show disable form -->
            <p class="text-xs text-slate-400">
                2FA aktif. Untuk menonaktifkan, konfirmasi dengan password Anda.
            </p>
            <form method="POST" action="/admin/security/2fa/disable"
                onsubmit="return confirm('Yakin menonaktifkan 2FA? Akun Anda akan kurang terlindungi.')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="flex gap-3 items-end">
                    <div class="flex-1">
                        <label class="block text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-2">
                            Konfirmasi Password
                        </label>
                        <input type="password" name="password" required
                            class="w-full px-4 py-2.5 bg-slate-950 border border-slate-700 text-white rounded-xl
                                   focus:outline-none focus:border-red-500 transition text-sm"
                            placeholder="••••••••">
                    </div>
                    <button type="submit"
                        class="px-4 py-2.5 bg-red-600/10 hover:bg-red-600 border border-red-500/20 hover:border-red-600
                               text-red-400 hover:text-white text-xs font-bold rounded-xl transition whitespace-nowrap">
                        Nonaktifkan 2FA
                    </button>
                </div>
            </form>
            <% } %>

        </div>
    </section>

    <!-- ── CHANGE PASSWORD ── -->
    <section class="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-800">
            <h2 class="text-sm font-bold text-white">Ubah Password</h2>
            <p class="text-xs text-slate-500 mt-0.5">Sesi login lain akan otomatis berakhir setelah password diubah</p>
        </div>
        <div class="px-6 py-5">
            <form method="POST" action="/admin/security/password" class="space-y-4">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div>
                    <label class="block text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-2">
                        Password Saat Ini
                    </label>
                    <input type="password" name="currentPassword" required
                        class="w-full px-4 py-2.5 bg-slate-950 border border-slate-700 text-white rounded-xl
                               focus:outline-none focus:border-blue-500 transition text-sm"
                        placeholder="••••••••">
                </div>
                <div>
                    <label class="block text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-2">
                        Password Baru
                    </label>
                    <input type="password" name="newPassword" required
                        class="w-full px-4 py-2.5 bg-slate-950 border border-slate-700 text-white rounded-xl
                               focus:outline-none focus:border-blue-500 transition text-sm"
                        placeholder="Min. 8 karakter, 1 huruf kapital, 1 angka">
                </div>
                <div>
                    <label class="block text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-2">
                        Konfirmasi Password Baru
                    </label>
                    <input type="password" name="confirmPassword" required
                        class="w-full px-4 py-2.5 bg-slate-950 border border-slate-700 text-white rounded-xl
                               focus:outline-none focus:border-blue-500 transition text-sm"
                        placeholder="••••••••">
                </div>
                <div class="pt-1">
                    <p class="text-[10px] text-slate-600 font-mono mb-3">
                        Syarat: min. 8 karakter · 1 huruf kapital · 1 angka
                    </p>
                    <button type="submit"
                        class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold rounded-xl transition shadow-lg shadow-blue-900/20">
                        Simpan Password Baru
                    </button>
                </div>
            </form>
        </div>
    </section>

    <!-- ── ACCOUNT INFO ── -->
    <section class="bg-slate-900/60 border border-slate-800 rounded-2xl px-6 py-5">
        <h2 class="text-sm font-bold text-white mb-4">Informasi Akun</h2>
        <div class="grid grid-cols-2 gap-4 text-xs">
            <div>
                <p class="text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-1">Username</p>
                <p class="text-white font-bold"><%= user.username %></p>
            </div>
            <div>
                <p class="text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-1">Role</p>
                <span class="px-2 py-0.5 rounded-lg text-[10px] font-bold border
                    <%= user.role === 'superadmin' ? 'bg-red-500/10 text-red-400 border-red-500/20' :
                       user.role === 'admin'       ? 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20' :
                                                     'bg-slate-700/40 text-slate-400 border-slate-700/60' %>">
                    <%= user.role %>
                </span>
            </div>
            <div>
                <p class="text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-1">Email</p>
                <p class="text-slate-300 font-mono"><%= user.email %></p>
            </div>
            <div>
                <p class="text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-1">Bergabung</p>
                <p class="text-slate-400 font-mono">
                    <%= new Date(user.createdAt).toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' }) %>
                </p>
            </div>
        </div>
    </section>

</div>
</main>

<%- include('partials/footer') %>
