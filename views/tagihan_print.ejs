<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Invoice <%= trx.invoiceNumber || trx.orderId %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; background: #f1f5f9; color: #1a1a2e; font-size: 14px; }

    /* Floating print toolbar */
    .print-toolbar {
      position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%);
      z-index: 100;
      display: flex; align-items: center; gap: 10px;
      background: #0f172a;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 100px;
      padding: 8px 8px 8px 20px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.45), 0 2px 8px rgba(0,0,0,0.3);
      backdrop-filter: blur(8px);
    }
    .print-toolbar-label {
      font-size: 0.78rem; color: #94a3b8; white-space: nowrap;
      display: flex; align-items: center; gap: 6px;
    }
    .print-toolbar-label svg { color: #64748b; }
    .btn-print {
      background: #2563eb; color: #fff; border: none;
      padding: 9px 20px; border-radius: 100px; cursor: pointer;
      font-weight: 700; font-size: 0.82rem;
      display: flex; align-items: center; gap: 7px;
      transition: background 0.15s, transform 0.1s;
      white-space: nowrap;
    }
    .btn-print:hover { background: #1d4ed8; }
    .btn-print:active { transform: scale(0.97); }

    /* Page */
    .page-wrap { padding: 32px 20px 48px; }
    .page {
      max-width: 794px; margin: 0 auto;
      background: #fff;
      border-radius: 4px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.10);
      overflow: hidden;
      display: flex; flex-direction: column;
      min-height: 27cm;
    }
    .accent-bar { height: 6px; background: linear-gradient(90deg, #2563eb 0%, #06b6d4 100%); }

    .inv-body { padding: 44px 52px; flex: 1; }

    /* Header */
    .inv-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 36px; gap: 32px; }
    .brand-block { display: flex; flex-direction: column; gap: 10px; flex: 1; }
    .brand-logo { max-height: 80px; max-width: 200px; object-fit: contain; display: block; }
    .brand-name { font-size: 1.5rem; font-weight: 900; color: #1a1a2e; letter-spacing: -0.03em; line-height: 1.1; }
    .brand-sub { font-size: 0.78rem; color: #6b7280; margin-top: 2px; line-height: 1.6; }
    .inv-meta { flex-shrink: 0; text-align: right; }
    .inv-word { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.22em; color: #9ca3af; text-transform: uppercase; }
    .inv-num { font-family: 'Courier New', monospace; font-size: 1.45rem; font-weight: 800; color: #1a1a2e; margin-top: 6px; letter-spacing: 0.02em; line-height: 1.1; }
    .inv-meta-box { margin-top: 12px; background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 8px; padding: 10px 14px; text-align: left; min-width: 200px; }
    .inv-meta-row { display: flex; justify-content: space-between; gap: 20px; padding: 3px 0; font-size: 0.78rem; }
    .inv-meta-row .lbl { color: #9ca3af; font-weight: 600; white-space: nowrap; }
    .inv-meta-row .val { color: #374151; font-weight: 700; text-align: right; }

    /* Status badge */
    .status-badge { display: inline-block; padding: 3px 12px; border-radius: 100px; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; margin-top: 6px; }
    .s-pending  { background: #fef3c7; color: #d97706; border: 1px solid #fcd34d; }
    .s-success  { background: #dcfce7; color: #15803d; border: 1px solid #86efac; }
    .s-expired  { background: #f3f4f6; color: #6b7280; border: 1px solid #d1d5db; }
    .s-failed   { background: #fee2e2; color: #dc2626; border: 1px solid #fca5a5; }

    /* Divider */
    .divider { border: none; border-top: 2px solid #2563eb; margin: 28px 0; opacity: 0.3; }

    /* Addresses */
    .addresses { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-bottom: 32px; }
    .addr-label { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #9ca3af; margin-bottom: 8px; }
    .addr-name { font-size: 1rem; font-weight: 700; color: #111827; }
    .addr-line { font-size: 0.8rem; color: #6b7280; margin-top: 3px; line-height: 1.5; }
    .addr-paid-stamp {
      display: inline-flex; align-items: center; gap: 6px;
      border: 2px solid #16a34a; color: #16a34a;
      border-radius: 6px; padding: 6px 14px;
      font-size: 0.78rem; font-weight: 700; margin-top: 8px;
    }

    /* Items table */
    .items-table { width: 100%; border-collapse: collapse; margin-bottom: 8px; }
    .items-table thead tr { border-bottom: 2px solid #1a1a2e; }
    .items-table th { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #9ca3af; padding: 8px 10px 8px 0; }
    .items-table th:first-child { padding-left: 0; width: 32px; text-align: center; }
    .items-table th.right { text-align: right; }
    .items-table td { padding: 13px 10px 13px 0; font-size: 0.875rem; color: #374151; border-bottom: 1px solid #f3f4f6; vertical-align: top; }
    .items-table td:first-child { text-align: center; color: #9ca3af; font-size: 0.75rem; padding-left: 0; }
    .items-table td.right { text-align: right; }
    .td-desc { color: #111827; font-weight: 500; }
    .td-amount { font-weight: 700; color: #111827; }
    .items-table tbody tr:last-child td { border-bottom: none; }

    /* Totals */
    .totals-section { display: flex; justify-content: flex-end; margin-top: 8px; padding-top: 16px; border-top: 1px solid #f3f4f6; }
    .totals-box { min-width: 260px; }
    .totals-row { display: flex; justify-content: space-between; padding: 5px 0; font-size: 0.85rem; color: #6b7280; }
    .totals-row.grand { font-size: 1.05rem; font-weight: 800; color: #111827; padding-top: 12px; border-top: 2px solid #2563eb; margin-top: 6px; }
    .totals-row.grand span:last-child { color: #2563eb; }

    /* No items fallback */
    .single-amount { margin-top: 20px; padding: 20px; background: #f8fafc; border-radius: 10px; border: 1px solid #e5e7eb; }
    .single-amount .desc { font-size: 0.9rem; color: #374151; font-weight: 500; margin-bottom: 10px; }
    .single-amount .total-row { display: flex; justify-content: space-between; font-size: 1.05rem; font-weight: 800; color: #111827; padding-top: 10px; border-top: 2px solid #2563eb; }
    .single-amount .total-row span:last-child { color: #2563eb; }

    /* QR section */
    .qr-section { display: flex; align-items: center; gap: 20px; margin-top: 20px; padding: 16px 20px; background: #f8fafc; border-radius: 10px; border: 1px solid #e5e7eb; }
    .qr-img-wrap { flex-shrink: 0; width: 88px; height: 88px; background: #fff; border: 1px solid #e5e7eb; border-radius: 6px; display: flex; align-items: center; justify-content: center; padding: 4px; }
    .qr-img { width: 80px; height: 80px; display: block; }
    .qr-info { flex: 1; min-width: 0; }
    .qr-title { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #374151; margin-bottom: 4px; }
    .qr-desc { font-size: 0.75rem; color: #6b7280; line-height: 1.5; margin-bottom: 6px; }
    .qr-url-wrap { display: flex; align-items: baseline; gap: 4px; margin-bottom: 4px; }
    .qr-url-label { font-size: 0.65rem; color: #9ca3af; font-weight: 600; flex-shrink: 0; }
    .qr-url-text { font-size: 0.68rem; color: #6b7280; word-break: break-all; }
    .qr-amount { font-size: 0.78rem; color: #374151; }
    .qr-amount strong { color: #2563eb; }

    /* PAID watermark */
    .paid-watermark { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%) rotate(-20deg); font-size: 7rem; font-weight: 900; color: rgba(22,163,74,0.06); letter-spacing: 0.1em; text-transform: uppercase; pointer-events: none; user-select: none; white-space: nowrap; }

    /* Footer */
    .inv-footer { padding: 14px 52px; background: #f8fafc; border-top: 2px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center; font-size: 0.7rem; color: #9ca3af; }
    .inv-footer-left { display: flex; flex-direction: column; gap: 1px; }
    .inv-footer-co { font-size: 0.72rem; font-weight: 700; color: #374151; }
    .inv-footer-sub { font-size: 0.65rem; color: #9ca3af; }
    .inv-footer-right { text-align: right; display: flex; flex-direction: column; gap: 1px; }
    .inv-footer-num { font-family: monospace; font-size: 0.72rem; font-weight: 700; color: #374151; }
    .inv-footer-pg { font-size: 0.65rem; color: #9ca3af; }

    @media print {
      body { background: #fff; }
      .no-print, .print-toolbar { display: none !important; }
      .page-wrap { padding: 0; }
      .page { box-shadow: none; border-radius: 0; max-width: 100%; min-height: calc(29.7cm - 1.6cm); }
      .inv-body { padding: 32px 40px; }
      .inv-footer { padding: 12px 40px; }
      @page { margin: 0.8cm; size: A4; }
    }
  </style>
</head>
<body>

<!-- Floating print toolbar -->
<div class="print-toolbar no-print">
  <span class="print-toolbar-label">
    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
    Invoice <%= trx.invoiceNumber || trx.orderId %>
  </span>
  <button class="btn-print" onclick="window.print()">
    <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
    Cetak / Simpan PDF
  </button>
</div>

<%
const coName  = (siteSetting && siteSetting.siteTitle) ? siteSetting.siteTitle : 'TrendingBulk';
const coLogo  = (siteSetting && siteSetting.logoUrl)   ? siteSetting.logoUrl   : null;
const sLabel  = { pending:'Menunggu', success:'Lunas', failed:'Gagal', expired:'Kedaluwarsa', refund:'Refund' };
const sCls    = { pending:'s-pending', success:'s-success', failed:'s-failed', expired:'s-expired', refund:'s-expired' };
const hasItems = trx.items && trx.items.length > 0;
const invNum  = trx.invoiceNumber || trx.orderId;
const fmtDate = d => d ? new Date(d).toLocaleDateString('id-ID', { day:'2-digit', month:'long', year:'numeric' }) : '-';
const fmtRp   = n => 'Rp ' + (n || 0).toLocaleString('id-ID');
%>

<div class="page-wrap">
<div class="page relative">
  <div class="accent-bar"></div>

  <% if (trx.status === 'success') { %>
  <div class="paid-watermark">LUNAS</div>
  <% } %>

  <div class="inv-body">

    <!-- Header -->
    <div class="inv-header">
      <div class="brand-block">
        <% if (coLogo) { %><img src="<%= coLogo %>" alt="Logo" class="brand-logo"><% } %>
        <div>
          <div class="brand-name"><%= coName %></div>
          <% if (siteSetting && siteSetting.siteDescription) { %>
          <div class="brand-sub" style="color:#374151;font-weight:500"><%= siteSetting.siteDescription %></div>
          <% } %>
        </div>
      </div>
      <div class="inv-meta">
        <div class="inv-word">INVOICE</div>
        <div class="inv-num"><%= invNum %></div>
        <div style="margin-top:6px"><span class="status-badge <%= sCls[trx.status] || 's-expired' %>"><%= sLabel[trx.status] || trx.status %></span></div>
        <div class="inv-meta-box">
          <div class="inv-meta-row">
            <span class="lbl">Tanggal</span>
            <span class="val"><%= fmtDate(trx.createdAt) %></span>
          </div>
          <% if (trx.dueDate) { %>
          <div class="inv-meta-row">
            <span class="lbl">Jatuh Tempo</span>
            <span class="val" style="<%= new Date() > new Date(trx.dueDate) && trx.status !== 'success' ? 'color:#dc2626' : '' %>">
              <%= fmtDate(trx.dueDate) %>
            </span>
          </div>
          <% } %>
          <div class="inv-meta-row" style="border-top:1px solid #e5e7eb;margin-top:4px;padding-top:6px">
            <span class="lbl">Total</span>
            <span class="val" style="color:#2563eb"><%= fmtRp(trx.amount) %></span>
          </div>
        </div>
      </div>
    </div>

    <hr class="divider" style="opacity:1">

    <!-- Addresses -->
    <div class="addresses">
      <div>
        <div class="addr-label">Tagihan Kepada</div>
        <div class="addr-name"><%= trx.customerName %></div>
        <% if (trx.customerEmail) { %><div class="addr-line"><%= trx.customerEmail %></div><% } %>
        <% if (trx.customerPhone) { %><div class="addr-line"><%= trx.customerPhone %></div><% } %>
      </div>
      <div style="text-align:right">
        <% if (trx.status === 'success' && trx.paidAt) { %>
        <div class="addr-label">Tanggal Pembayaran</div>
        <div class="addr-name" style="color:#15803d"><%= fmtDate(trx.paidAt) %></div>
        <div class="addr-paid-stamp"><i class="fas fa-check-circle"></i> LUNAS</div>
        <% } %>
      </div>
    </div>

    <!-- Items atau single amount -->
    <% if (hasItems) { %>
    <table class="items-table">
      <thead>
        <tr>
          <th>No</th>
          <th>Deskripsi</th>
          <th class="right" style="width:60px">Qty</th>
          <th class="right" style="width:140px">Harga Satuan</th>
          <th class="right" style="width:140px">Subtotal</th>
        </tr>
      </thead>
      <tbody>
        <% trx.items.forEach((item, idx) => { %>
        <tr>
          <td><%= idx + 1 %></td>
          <td class="td-desc"><%= item.description %></td>
          <td class="right"><%= item.qty %></td>
          <td class="right"><%= fmtRp(item.unitPrice) %></td>
          <td class="right td-amount"><%= fmtRp(item.subtotal) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <div class="totals-section">
      <div class="totals-box">
        <div class="totals-row grand"><span>TOTAL</span><span><%= fmtRp(trx.amount) %></span></div>
      </div>
    </div>
    <% } else { %>
    <div class="single-amount">
      <% if (trx.description) { %><div class="desc"><%= trx.description %></div><% } %>
      <div class="total-row"><span>TOTAL</span><span><%= fmtRp(trx.amount) %></span></div>
    </div>
    <% } %>

    <!-- QR Portal Customer (hanya jika belum lunas) -->
    <% if (trx.status !== 'success' && portalUrl) { %>
    <%
      const qrPortalUrl = 'https://api.qrserver.com/v1/create-qr-code/?size=220x220&color=000000&bgcolor=ffffff&qzone=1&data=' + encodeURIComponent(portalUrl);
    %>
    <div class="qr-section">
      <div class="qr-img-wrap">
        <img src="<%= qrPortalUrl %>" alt="QR Portal" class="qr-img">
      </div>
      <div class="qr-info">
        <div class="qr-title"><i class="fas fa-qrcode"></i> Login & Bayar via Portal</div>
        <div class="qr-desc">Scan kode di samping untuk masuk ke portal customer dan menyelesaikan pembayaran tagihan ini.</div>
        <div class="qr-url-wrap">
          <span class="qr-url-label">Portal:</span>
          <span class="qr-url-text"><%= portalUrl %></span>
        </div>
        <div class="qr-amount">Total: <strong><%= fmtRp(trx.amount) %></strong></div>
      </div>
    </div>
    <% } %>

  </div><!-- /inv-body -->

  <div class="inv-footer">
    <div class="inv-footer-left">
      <span class="inv-footer-co"><%= coName %></span>
      <span class="inv-footer-sub">Dokumen ini diterbitkan secara resmi</span>
    </div>
    <div class="inv-footer-right">
      <span class="inv-footer-num"><%= invNum %></span>
      <span class="inv-footer-pg">Halaman 1 / 1</span>
    </div>
  </div>

</div><!-- /page -->
</div><!-- /page-wrap -->

<script>
  // Auto-open print dialog setelah semua gambar/font selesai dimuat
  window.addEventListener('load', function () {
    setTimeout(function () { window.print(); }, 600);
  });
</script>

</body>
</html>
