<%- include('partials/admin_header', { pageTitle: 'Sekretariat - Kontak' }) %>

<div class="min-h-screen bg-slate-950 py-10 px-4 md:px-6">
<div class="max-w-2xl mx-auto">

    <!-- Header -->
    <div class="mb-8 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <div class="h-9 w-9 bg-violet-600 rounded-xl flex items-center justify-center shadow-lg shadow-violet-900/30">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
            </div>
            <div>
                <h1 class="text-xl font-black text-white uppercase tracking-tight">Informasi Kontak</h1>
                <p class="text-slate-500 text-[10px] font-mono mt-0.5">Kelola data kontak sekretariat</p>
            </div>
        </div>
        <a href="/dashboard" class="flex items-center gap-2 text-slate-400 hover:text-white text-xs font-bold border border-slate-800 hover:border-slate-600 px-4 py-2 rounded-xl bg-slate-900/50 uppercase tracking-wider transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Kembali
        </a>
    </div>

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="mb-6 flex items-center gap-3 px-4 py-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl">
        <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <p class="text-emerald-400 text-xs font-bold">Data kontak berhasil disimpan.</p>
    </div>
    <% } %>

    <form action="/admin/sekretariat/kontak/save" method="POST" class="space-y-5">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <!-- Alamat -->
        <div class="space-y-2">
            <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500">Alamat</label>
            <textarea name="alamat" rows="3"
                class="w-full bg-slate-900 border border-slate-700 focus:border-violet-500 text-slate-200 text-sm rounded-xl px-4 py-3 outline-none transition resize-none placeholder-slate-600"
                placeholder="Masukkan alamat sekretariat..."><%= typeof sekretariat !== 'undefined' && sekretariat ? sekretariat.alamat : '' %></textarea>
        </div>

        <!-- Email -->
        <div class="space-y-2">
            <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500">Email</label>
            <input type="email" name="email"
                value="<%= typeof sekretariat !== 'undefined' && sekretariat ? sekretariat.email : '' %>"
                class="w-full bg-slate-900 border border-slate-700 focus:border-violet-500 text-slate-200 text-sm rounded-xl px-4 py-3 outline-none transition placeholder-slate-600"
                placeholder="info@theater.id">
        </div>

        <!-- Telepon -->
        <div class="space-y-2">
            <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500">Telepon / WhatsApp</label>
            <input type="text" name="telepon"
                value="<%= typeof sekretariat !== 'undefined' && sekretariat ? sekretariat.telepon : '' %>"
                class="w-full bg-slate-900 border border-slate-700 focus:border-violet-500 text-slate-200 text-sm rounded-xl px-4 py-3 outline-none transition placeholder-slate-600"
                placeholder="+62 812 xxxx xxxx">
        </div>

        <!-- Google Maps Embed URL -->
        <div class="space-y-2">
            <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500">Google Maps Embed URL</label>
            <textarea name="mapEmbedUrl" rows="3"
                class="w-full bg-slate-900 border border-slate-700 focus:border-violet-500 text-slate-200 text-sm rounded-xl px-4 py-3 outline-none transition resize-none placeholder-slate-600 font-mono"
                placeholder="https://www.google.com/maps/embed?pb=..."><%= typeof sekretariat !== 'undefined' && sekretariat ? sekretariat.mapEmbedUrl : '' %></textarea>
            <div class="flex items-start gap-3 px-4 py-3 bg-amber-500/5 border border-amber-500/20 rounded-xl">
                <svg class="w-4 h-4 text-amber-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-slate-400 text-xs font-mono leading-relaxed">Buka <span class="text-amber-400">Google Maps</span> → cari lokasi → klik <span class="text-amber-400">Share → Embed a map</span> → salin URL dari atribut <span class="text-amber-400">src="..."</span> pada kode iframe yang diberikan.</p>
            </div>
        </div>

        <!-- Info -->
        <div class="flex items-start gap-3 px-4 py-3 bg-slate-900/50 border border-slate-800 rounded-xl">
            <svg class="w-4 h-4 text-slate-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-slate-500 text-xs font-mono">Data ini tampil di section <span class="text-violet-400">"Informasi Kontak"</span> pada halaman <span class="text-violet-400">/sekretariat</span>.</p>
        </div>

        <!-- Actions -->
        <div class="flex gap-4 pt-2">
            <a href="/dashboard" class="px-6 py-3.5 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-400 text-xs font-bold uppercase tracking-widest rounded-xl transition text-center">
                Batal
            </a>
            <button type="submit" class="flex-1 flex items-center justify-center gap-2 py-3.5 bg-violet-600 hover:bg-violet-700 text-white text-xs font-black uppercase tracking-widest rounded-xl transition shadow-lg shadow-violet-900/20">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Simpan Kontak
            </button>
        </div>
    </form>

</div>
</div>

<%- include('partials/footer') %>
