<%- include('partials/admin_header', { pageTitle: 'Pembayaran' }) %>

<main class="min-h-screen bg-slate-950 pt-6 pb-24">
<div class="max-w-7xl mx-auto px-4 md:px-6">

    <!-- PAGE HEADER -->
    <div class="mb-6 sm:mb-8">
        <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
            <div>
                <p class="text-[10px] font-mono text-slate-600 uppercase tracking-[0.3em] mb-1">Manajemen Keuangan</p>
                <h1 class="text-2xl font-black text-white tracking-tight">Pembayaran</h1>
                <p class="text-slate-500 text-xs mt-1">Kelola tagihan dan transaksi pembayaran</p>
            </div>
            <div class="flex items-center gap-2 flex-wrap shrink-0">
                <span class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[10px] font-mono <%= isProduction ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : 'bg-amber-500/10 text-amber-400 border border-amber-500/20' %>">
                    <span class="h-1.5 w-1.5 rounded-full <%= isProduction ? 'bg-emerald-500' : 'bg-amber-500' %>"></span>
                    <%= isProduction ? 'Production' : 'Sandbox' %>
                </span>
                <a href="/admin/payments/export/csv<%= filters.status ? '?status=' + filters.status : '' %><%= filters.q ? (filters.status ? '&' : '?') + 'q=' + encodeURIComponent(filters.q) : '' %>"
                    class="flex items-center gap-1.5 px-3 sm:px-4 py-2.5 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-300 text-xs font-bold rounded-xl transition"
                    title="Export ke Excel/CSV">
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <span class="hidden sm:inline">Export</span> CSV
                </a>
                <a href="/admin/payments/create" class="flex items-center gap-1.5 px-3 sm:px-4 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-xs font-black rounded-xl transition shadow-lg shadow-blue-900/30">
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    <span class="hidden sm:inline">Buat </span>Payment Link
                </a>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
        <div class="bg-slate-900/60 border border-slate-800 rounded-2xl px-4 sm:px-5 py-4">
            <p class="text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-1">Pendapatan Bulan Ini</p>
            <p class="text-base sm:text-xl font-black text-blue-400 truncate">Rp <%= summary.revenueMonth.toLocaleString('id-ID') %></p>
        </div>
        <div class="bg-slate-900/60 border border-slate-800 rounded-2xl px-4 sm:px-5 py-4">
            <p class="text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-1">Total Lunas</p>
            <p class="text-base sm:text-xl font-black text-emerald-400 truncate">Rp <%= summary.totalPaid.toLocaleString('id-ID') %></p>
            <p class="text-[11px] text-slate-600 mt-0.5"><%= summary.countPaid %> transaksi</p>
        </div>
        <div class="bg-slate-900/60 border border-slate-800 rounded-2xl px-4 sm:px-5 py-4">
            <p class="text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-1">Menunggu Bayar</p>
            <p class="text-base sm:text-xl font-black text-amber-400"><%= summary.countPending %></p>
            <p class="text-[11px] text-slate-600 mt-0.5">transaksi</p>
        </div>
        <div class="bg-slate-900/60 border border-slate-800 rounded-2xl px-4 sm:px-5 py-4">
            <p class="text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-1">Total Transaksi</p>
            <p class="text-base sm:text-xl font-black text-white"><%= totalCount %></p>
            <p class="text-[11px] text-slate-600 mt-0.5">semua waktu</p>
        </div>
    </div>

    <!-- FLASH -->
    <% if (success) { %>
    <div class="mb-6 flex items-center gap-3 px-4 py-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl">
        <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        <p class="text-emerald-400 text-xs font-bold"><%= success %></p>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="mb-6 flex items-center gap-3 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl">
        <svg class="w-4 h-4 text-red-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        <p class="text-red-400 text-xs font-bold"><%= error %></p>
    </div>
    <% } %>

    <!-- FILTER -->
    <form action="/admin/payments" method="GET" class="flex gap-2 sm:gap-3 mb-6 flex-wrap">
        <input type="text" name="q" value="<%= filters.q || '' %>" placeholder="Cari order ID / nama / email..."
            class="flex-1 min-w-0 w-full sm:w-auto px-4 py-2.5 bg-slate-900 border border-slate-700 text-white text-xs rounded-xl focus:outline-none focus:border-blue-500 placeholder-slate-600 transition">
        <div class="flex gap-2 w-full sm:w-auto">
            <select name="status" class="flex-1 sm:flex-none px-3 py-2.5 bg-slate-900 border border-slate-700 text-slate-300 text-xs rounded-xl focus:outline-none focus:border-blue-500 transition">
                <option value="">Semua Status</option>
                <% [['pending','Menunggu'],['success','Lunas'],['failed','Gagal'],['expired','Kedaluwarsa'],['refund','Refund']].forEach(([val,label]) => { %>
                <option value="<%= val %>" <%= filters.status === val ? 'selected' : '' %>><%= label %></option>
                <% }) %>
            </select>
            <button type="submit" class="px-4 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold rounded-xl transition shrink-0">
                <svg class="w-3.5 h-3.5 inline -mt-0.5 sm:mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <span class="hidden sm:inline">Cari</span>
            </button>
            <% if (filters.q || filters.status) { %>
            <a href="/admin/payments" class="px-4 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs font-bold rounded-xl transition border border-slate-700 shrink-0">Reset</a>
            <% } %>
        </div>
    </form>

    <!-- TABLE -->
    <div class="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-800 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <h2 class="text-sm font-bold text-white">Daftar Transaksi</h2>
                <span class="px-2 py-0.5 bg-slate-800 text-slate-400 text-[10px] font-mono rounded-lg"><%= totalCount %> total</span>
            </div>
        </div>
        <div class="overflow-x-auto -mx-px">
            <table class="w-full min-w-[540px]">
                <thead>
                    <tr class="border-b border-slate-800 bg-slate-900/40">
                        <th class="px-4 sm:px-5 py-3 text-left text-[10px] font-mono text-slate-500 uppercase tracking-wider">Invoice / Order</th>
                        <th class="px-4 sm:px-5 py-3 text-left text-[10px] font-mono text-slate-500 uppercase tracking-wider">Customer</th>
                        <th class="px-4 sm:px-5 py-3 text-right text-[10px] font-mono text-slate-500 uppercase tracking-wider whitespace-nowrap">Nominal</th>
                        <th class="px-4 sm:px-5 py-3 text-center text-[10px] font-mono text-slate-500 uppercase tracking-wider">Status</th>
                        <th class="px-4 sm:px-5 py-3 text-left text-[10px] font-mono text-slate-500 uppercase tracking-wider hidden md:table-cell">Tanggal</th>
                        <th class="px-4 sm:px-5 py-3 text-center text-[10px] font-mono text-slate-500 uppercase tracking-wider">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800/50">
                    <% if (transactions.length === 0) { %>
                    <tr><td colspan="6" class="px-6 py-16 text-center">
                        <svg class="w-10 h-10 text-slate-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                        <p class="text-slate-500 text-sm font-medium">Belum ada transaksi</p>
                        <p class="text-slate-700 text-xs mt-1">Buat payment link pertama untuk mulai menerima pembayaran</p>
                        <a href="/admin/payments/create" class="inline-flex items-center gap-2 mt-4 px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold rounded-xl transition">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                            Buat Payment Link
                        </a>
                    </td></tr>
                    <% } %>
                    <% transactions.forEach(t => { %>
                    <%
                    const statusCfg = {
                        success: { cls: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20', label: 'Lunas', dot: false },
                        pending: { cls: 'bg-amber-500/10 text-amber-400 border-amber-500/20',   label: 'Menunggu', dot: true },
                        failed:  { cls: 'bg-red-500/10 text-red-400 border-red-500/20',         label: 'Gagal', dot: false },
                        refund:  { cls: 'bg-orange-500/10 text-orange-400 border-orange-500/20',label: 'Refund', dot: false },
                        expired: { cls: 'bg-slate-700/50 text-slate-400 border-slate-600/30',   label: 'Kedaluwarsa', dot: false }
                    };
                    const sc = statusCfg[t.status] || statusCfg.expired;
                    %>
                    <tr class="hover:bg-slate-800/30 transition cursor-pointer group" onclick="location.href='/admin/payments/<%= t._id %>'">
                        <!-- Invoice/Order -->
                        <td class="px-4 sm:px-5 py-3.5 sm:py-4">
                            <% if (t.invoiceNumber) { %>
                            <p class="text-xs font-bold text-white"><%= t.invoiceNumber %></p>
                            <code class="text-[10px] text-slate-500 font-mono"><%= t.orderId %></code>
                            <% } else { %>
                            <code class="text-xs text-blue-400 bg-blue-500/10 px-2 py-0.5 rounded-lg break-all"><%= t.orderId %></code>
                            <% } %>
                            <% if (t.description && !t.invoiceNumber) { %>
                            <p class="text-[10px] text-slate-500 mt-0.5 max-w-[140px] truncate"><%= t.description %></p>
                            <% } %>
                        </td>
                        <!-- Customer -->
                        <td class="px-4 sm:px-5 py-3.5 sm:py-4">
                            <p class="text-sm text-white font-medium leading-tight"><%= t.customerName %></p>
                            <% if (t.customerEmail) { %><p class="text-[11px] text-slate-500 mt-0.5 hidden sm:block truncate max-w-[180px]"><%= t.customerEmail %></p><% } %>
                            <% if (t.customerPhone) { %><p class="text-[11px] text-slate-500 mt-0.5 sm:hidden"><%= t.customerPhone %></p><% } %>
                        </td>
                        <!-- Nominal -->
                        <td class="px-4 sm:px-5 py-3.5 sm:py-4 text-right">
                            <p class="text-sm font-bold text-white whitespace-nowrap">Rp <%= t.amount.toLocaleString('id-ID') %></p>
                        </td>
                        <!-- Status -->
                        <td class="px-4 sm:px-5 py-3.5 sm:py-4 text-center">
                            <span class="inline-flex items-center gap-1.5 px-2 sm:px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider border rounded-lg whitespace-nowrap <%= sc.cls %>">
                                <% if (sc.dot) { %><span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse shrink-0"></span><% } %>
                                <%= sc.label %>
                            </span>
                        </td>
                        <!-- Tanggal (hidden on mobile) -->
                        <td class="px-4 sm:px-5 py-3.5 sm:py-4 hidden md:table-cell">
                            <p class="text-xs text-slate-400 font-mono whitespace-nowrap"><%= new Date(t.createdAt).toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' }) %></p>
                            <% if (t.paidAt) { %>
                            <p class="text-[10px] text-emerald-500 font-mono mt-0.5 whitespace-nowrap">Lunas: <%= new Date(t.paidAt).toLocaleDateString('id-ID', { day:'2-digit', month:'short' }) %></p>
                            <% } %>
                        </td>
                        <!-- Aksi -->
                        <td class="px-4 sm:px-5 py-3.5 sm:py-4 text-center" onclick="event.stopPropagation()">
                            <div class="flex items-center justify-center gap-1.5">
                                <!-- Detail Admin -->
                                <a href="/admin/payments/<%= t._id %>"
                                    class="p-1.5 rounded-lg bg-slate-800 hover:bg-blue-600/20 text-slate-400 hover:text-blue-400 transition"
                                    title="Lihat Detail">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                </a>
                                <!-- Portal Customer -->
                                <% if (t.customerEmail) { %>
                                <a href="<%= getPortalUrl(t.customerEmail) %>" target="_blank"
                                    class="flex items-center gap-1.5 px-2 sm:px-2.5 py-1.5 rounded-lg bg-blue-600/15 hover:bg-blue-600/30 text-blue-400 border border-blue-500/20 transition text-[10px] font-bold"
                                    title="Buka Portal Customer — <%= t.customerEmail %>">
                                    <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                    <span class="hidden sm:inline">Portal</span>
                                </a>
                                <% } %>
                                <!-- WhatsApp kirim link portal -->
                                <% if (t.status !== 'success' && t.customerEmail) { %>
                                <%
                                const _portalLink = getPortalUrl(t.customerEmail);
                                const _waText = encodeURIComponent('Halo ' + t.customerName + ', tagihan Anda sudah tersedia.\nNo: ' + (t.invoiceNumber || t.orderId) + ' — Rp ' + t.amount.toLocaleString('id-ID') + '\n\nLihat & bayar tagihan Anda di portal:\n' + _portalLink);
                                %>
                                <a href="https://wa.me/?text=<%= _waText %>" target="_blank"
                                    class="p-1.5 rounded-lg bg-slate-800 hover:bg-green-600/20 text-slate-400 hover:text-green-400 transition"
                                    title="Kirim Link Portal via WhatsApp">
                                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                                </a>
                                <% } %>
                                <!-- Hapus (superadmin only) -->
                                <% if (isSuperAdmin) { %>
                                <form method="POST" action="/admin/payments/<%= t._id %>/delete"
                                    onsubmit="return confirm('Hapus transaksi <%= t.invoiceNumber || t.orderId %>?\nAksi ini tidak dapat dibatalkan.')">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button type="submit"
                                        class="p-1.5 rounded-lg bg-slate-800 hover:bg-red-600/20 text-slate-400 hover:text-red-400 transition"
                                        title="Hapus Transaksi">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                    </button>
                                </form>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        <% if (totalPages > 1) { %>
        <div class="px-6 py-4 border-t border-slate-800 flex items-center justify-between gap-4">
            <p class="text-xs text-slate-500">
                Halaman <span class="text-white font-bold"><%= currentPage %></span> dari <span class="text-white font-bold"><%= totalPages %></span>
            </p>
            <div class="flex gap-1.5">
                <% if (currentPage > 1) { %>
                <a href="/admin/payments?page=<%= currentPage-1 %><%= filters.q ? '&q='+filters.q : '' %><%= filters.status ? '&status='+filters.status : '' %>"
                    class="px-3 py-1.5 rounded-lg text-xs font-bold bg-slate-800 text-slate-400 hover:bg-slate-700 border border-slate-700 transition">←</a>
                <% } %>
                <% for (let i = Math.max(1, currentPage-2); i <= Math.min(totalPages, currentPage+2); i++) { %>
                <a href="/admin/payments?page=<%= i %><%= filters.q ? '&q='+filters.q : '' %><%= filters.status ? '&status='+filters.status : '' %>"
                    class="px-3 py-1.5 rounded-lg text-xs font-bold transition <%= currentPage === i ? 'bg-blue-600 text-white' : 'bg-slate-800 text-slate-400 hover:bg-slate-700 border border-slate-700' %>"><%= i %></a>
                <% } %>
                <% if (currentPage < totalPages) { %>
                <a href="/admin/payments?page=<%= currentPage+1 %><%= filters.q ? '&q='+filters.q : '' %><%= filters.status ? '&status='+filters.status : '' %>"
                    class="px-3 py-1.5 rounded-lg text-xs font-bold bg-slate-800 text-slate-400 hover:bg-slate-700 border border-slate-700 transition">→</a>
                <% } %>
            </div>
        </div>
        <% } %>
    </div>

</div>
</main>

<%- include('partials/footer') %>
