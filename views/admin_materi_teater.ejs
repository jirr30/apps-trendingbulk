<%- include('partials/admin_header', { pageTitle: pageTitle }) %>

<div class="max-w-6xl mx-auto px-4 md:px-6 py-8">

    <!-- Header -->
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-black uppercase tracking-tighter text-white">Materi Teater</h1>
            <p class="text-slate-500 text-xs font-mono mt-1">Kelola naskah dan materi teater</p>
        </div>
        <a href="/admin/materi-teater/add"
            class="flex items-center gap-2 px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-xs font-black uppercase tracking-widest rounded-xl transition shadow-lg shadow-blue-900/20">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Tambah Materi
        </a>
    </div>

    <!-- Alert -->
    <% if (success) { %>
    <div class="mb-6 px-4 py-3 bg-emerald-500/10 border border-emerald-500/30 rounded-xl text-emerald-400 text-xs font-mono">✓ <%= success %></div>
    <% } %>
    <% if (error) { %>
    <div class="mb-6 px-4 py-3 bg-red-500/10 border border-red-500/30 rounded-xl text-red-400 text-xs font-mono">✗ <%= error %></div>
    <% } %>

    <% if (items.length === 0) { %>
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-16 text-center">
        <p class="text-5xl mb-4">🎭</p>
        <p class="text-slate-400 font-bold text-sm">Belum ada materi teater</p>
        <p class="text-slate-600 text-xs font-mono mt-1">Klik tombol "Tambah Materi" untuk memulai</p>
    </div>
    <% } else { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% items.forEach(item => { %>
        <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden group hover:border-blue-500/40 transition">
            <!-- Thumbnail -->
            <div class="relative h-44 bg-slate-800 overflow-hidden">
                <% if (item.thumbnail) { %>
                <img src="<%= item.thumbnail %>" alt="<%= item.title %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
                <% } else { %>
                <div class="flex items-center justify-center h-full text-slate-700">
                    <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                </div>
                <% } %>
            </div>
            <!-- Info -->
            <div class="p-5">
                <h3 class="text-sm font-bold text-white mb-2 line-clamp-2"><%= item.title %></h3>
                <p class="text-xs text-slate-500 line-clamp-2 mb-4">
                    <%= item.content.replace(/<[^>]*>?/gm, '').substring(0, 100) %>...
                </p>
                <div class="flex items-center justify-between pt-3 border-t border-slate-800">
                    <span class="text-[10px] font-mono text-slate-600">
                        <%= item.createdAt.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                    </span>
                    <div class="flex items-center gap-2">
                        <a href="/admin/materi-teater/<%= item._id %>/edit"
                            class="p-1.5 rounded-lg text-slate-500 hover:text-blue-400 hover:bg-blue-500/10 transition">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                            </svg>
                        </a>
                        <form action="/admin/materi-teater/delete/<%= item._id %>" method="POST"
                              onsubmit="return confirm('Hapus materi ini?')">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="p-1.5 rounded-lg text-slate-500 hover:text-red-400 hover:bg-red-500/10 transition">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                </svg>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
    <% } %>
</div>

</body>
</html>
