<%- include('partials/header') %>

<div class="min-h-screen bg-slate-950 text-slate-200">

    <!-- ── HERO + MAPS ────────────────────────────────────────────── -->
    <section class="border-b border-slate-800/60">
        <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[460px]">

            <!-- Kiri: teks -->
            <div class="relative overflow-hidden flex items-center px-8 py-16 md:px-12"
                 style="background:linear-gradient(135deg,#0f172a 0%,#020817 60%,#0f172a 100%);">
                <div class="absolute inset-0 pointer-events-none" style="background-image:radial-gradient(rgba(124,58,237,0.08) 1px,transparent 1px);background-size:24px 24px;"></div>
                <div class="relative max-w-lg">
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-violet-500/30 bg-violet-500/10 mb-5">
                        <span class="h-1.5 w-1.5 rounded-full bg-violet-400 animate-pulse"></span>
                        <span class="text-[10px] font-mono text-violet-400 uppercase tracking-widest">Organisasi</span>
                    </div>
                    <h1 class="text-3xl sm:text-4xl md:text-5xl font-black text-white tracking-tighter leading-tight mb-4">
                        Sekretariat<br><span class="text-violet-400">Kami</span>
                    </h1>
                    <p class="text-slate-400 text-sm leading-relaxed">
                        Pusat administrasi dan informasi organisasi theater kami.
                    </p>
                </div>
            </div>

            <!-- Kanan: Google Maps -->
            <div class="relative bg-slate-900 border-t border-slate-800 lg:border-t-0 lg:border-l border-slate-800 min-h-[320px]">
                <% if (typeof sekretariat !== 'undefined' && sekretariat && sekretariat.mapEmbedUrl) { %>
                <iframe
                    src="<%= sekretariat.mapEmbedUrl %>"
                    class="absolute inset-0 w-full h-full border-0 block"
                    allowfullscreen="" loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade">
                </iframe>
                <% } else { %>
                <div class="absolute inset-0 flex flex-col items-center justify-center gap-4 p-8 text-center">
                    <div class="h-16 w-16 rounded-2xl bg-slate-800 border border-slate-700 flex items-center justify-center">
                        <svg class="w-8 h-8 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-slate-500 text-sm font-semibold">Peta belum dikonfigurasi</p>
                        <p class="text-slate-600 text-xs font-mono mt-1">Tambahkan Google Maps Embed URL<br>di Admin → Sekretariat → Kontak</p>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    </section>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 sidebar-grid">
      <div class="min-w-0">

    <!-- ── INFORMASI KONTAK ──────────────────────────────────── -->
    <section class="py-10 sm:py-12 border-b border-slate-900">
        <div>
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-violet-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Informasi Kontak</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5">Hubungi kami</p>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

                <!-- Alamat -->
                <div class="relative group bg-slate-900/60 border border-slate-800 hover:border-violet-500/40 rounded-2xl p-6 flex flex-col gap-4 transition-all duration-300 overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-b from-violet-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-2xl"></div>
                    <div class="h-11 w-11 rounded-xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center group-hover:bg-violet-500/15 group-hover:border-violet-500/40 transition-all duration-300">
                        <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-[10px] font-mono text-slate-500 uppercase tracking-widest mb-1.5">Alamat</p>
                        <p class="text-slate-200 text-sm font-semibold leading-relaxed">
                            <%= typeof sekretariat !== 'undefined' && sekretariat && sekretariat.alamat ? sekretariat.alamat : '-' %>
                        </p>
                    </div>
                </div>

                <!-- Email -->
                <% var emailVal = typeof sekretariat !== 'undefined' && sekretariat && sekretariat.email ? sekretariat.email : ''; %>
                <a href="<%= emailVal ? 'mailto:' + emailVal : '#' %>"
                   class="relative group bg-slate-900/60 border border-slate-800 hover:border-emerald-500/40 rounded-2xl p-6 flex flex-col gap-4 transition-all duration-300 overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-b from-emerald-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-2xl"></div>
                    <div class="h-11 w-11 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center group-hover:bg-emerald-500/15 group-hover:border-emerald-500/40 transition-all duration-300">
                        <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-[10px] font-mono text-slate-500 uppercase tracking-widest mb-1.5">Email</p>
                        <p class="text-slate-200 text-sm font-semibold group-hover:text-emerald-400 transition break-all">
                            <%= emailVal || '-' %>
                        </p>
                    </div>
                </a>

                <!-- Telepon -->
                <% var teleponVal = typeof sekretariat !== 'undefined' && sekretariat && sekretariat.telepon ? sekretariat.telepon : ''; %>
                <a href="<%= teleponVal ? 'tel:' + teleponVal.replace(/\s/g,'') : '#' %>"
                   class="relative group bg-slate-900/60 border border-slate-800 hover:border-blue-500/40 rounded-2xl p-6 flex flex-col gap-4 transition-all duration-300 overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-b from-blue-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-2xl"></div>
                    <div class="h-11 w-11 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center group-hover:bg-blue-500/15 group-hover:border-blue-500/40 transition-all duration-300">
                        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-[10px] font-mono text-slate-500 uppercase tracking-widest mb-1.5">Telepon / WhatsApp</p>
                        <p class="text-slate-200 text-sm font-semibold group-hover:text-blue-400 transition">
                            <%= teleponVal || '-' %>
                        </p>
                    </div>
                </a>

            </div>
        </div>
    </section>

    <!-- ── VISI & MISI ────────────────────────────────────────── -->
    <% if (typeof sekretariat !== 'undefined' && sekretariat && sekretariat.visiMisi) { %>
    <section class="py-10 sm:py-12 border-b border-slate-900">
        <div>
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-violet-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Visi & Misi</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5">Tujuan dan arah organisasi</p>
                </div>
            </div>
            <div class="bg-slate-900/40 border border-slate-800 rounded-2xl p-6 sm:p-8 text-slate-300 leading-relaxed sejarah-konten">
                <%- sekretariat.visiMisi %>
            </div>
        </div>
    </section>
    <% } %>

    <!-- ── STRUKTUR ORGANISASI ────────────────────────────────── -->
    <section class="py-10 sm:py-14 border-b border-slate-900">
        <div>

            <%
            var orgList = (typeof sekretariat !== 'undefined' && sekretariat && sekretariat.strukturOrganisasi) ? sekretariat.strukturOrganisasi : [];
            var avatarBgClass = [
                'bg-blue-500/20 text-blue-300 border-blue-500/30',
                'bg-violet-500/20 text-violet-300 border-violet-500/30',
                'bg-emerald-500/20 text-emerald-300 border-emerald-500/30',
                'bg-amber-500/20 text-amber-300 border-amber-500/30',
                'bg-rose-500/20 text-rose-300 border-rose-500/30',
                'bg-cyan-500/20 text-cyan-300 border-cyan-500/30'
            ];
            function getInitials(name) {
                if (!name) return '?';
                var parts = name.trim().split(/\s+/);
                return parts.length === 1 ? parts[0][0].toUpperCase() : (parts[0][0] + parts[parts.length-1][0]).toUpperCase();
            }
            %>

            <!-- Section header -->
            <div class="flex flex-wrap items-end justify-between gap-4 mb-10">
                <div class="flex items-center gap-3">
                    <div class="h-9 w-1 bg-blue-500 rounded-full shrink-0"></div>
                    <div>
                        <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Struktur Organisasi</h2>
                        <p class="text-slate-500 text-xs font-mono mt-0.5">Kepengurusan Teater Saphalta</p>
                    </div>
                </div>
                <% if (orgList.length > 0) { %>
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-slate-800/80 border border-slate-700/60 text-slate-400 text-[10px] font-mono">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <%= orgList.length %> anggota
                </span>
                <% } %>
            </div>

            <% if (orgList.length > 0) { %>

            <!-- ── LEADER CARD (item pertama, featured) ── -->
            <% var leader = orgList[0]; %>
            <button type="button" data-org-idx="0"
                class="group w-full text-left mb-6 relative bg-slate-900/50 border border-blue-500/20 rounded-3xl overflow-hidden hover:border-blue-500/40 hover:bg-slate-900/80 transition-all duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500">

                <!-- Ambient glow -->
                <div class="absolute inset-0 bg-gradient-to-br from-blue-600/5 via-transparent to-violet-600/5 pointer-events-none"></div>
                <!-- Dot pattern -->
                <div class="absolute inset-0 opacity-30 pointer-events-none" style="background-image:radial-gradient(rgba(59,130,246,0.15) 1px,transparent 1px);background-size:20px 20px;"></div>

                <div class="relative flex flex-col sm:flex-row items-center sm:items-start gap-6 p-6 sm:p-8">

                    <!-- Avatar / Foto -->
                    <div class="shrink-0">
                        <% if (leader.foto) { %>
                        <div class="h-24 w-24 sm:h-28 sm:w-28 rounded-2xl overflow-hidden border-2 border-blue-500/30 shadow-xl shadow-blue-900/20 group-hover:border-blue-400/50 transition-colors">
                            <img src="<%= leader.foto %>" alt="<%= leader.nama %>" class="h-full w-full object-cover object-center group-hover:scale-105 transition-transform duration-500">
                        </div>
                        <% } else { %>
                        <div class="h-24 w-24 sm:h-28 sm:w-28 rounded-2xl bg-blue-500/15 border-2 border-blue-500/30 flex items-center justify-center text-3xl font-black text-blue-300 shadow-xl shadow-blue-900/20">
                            <%- getInitials(leader.nama) %>
                        </div>
                        <% } %>
                    </div>

                    <!-- Info -->
                    <div class="flex-1 min-w-0 text-center sm:text-left">
                        <!-- Top row: jabatan + divisi badges -->
                        <div class="flex flex-wrap items-center justify-center sm:justify-start gap-2 mb-3">
                            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-blue-500/15 text-blue-300 border border-blue-500/25">
                                <span class="h-1.5 w-1.5 rounded-full bg-blue-400 animate-pulse"></span>
                                <%= leader.jabatan %>
                            </span>
                            <% if (leader.divisi) { %>
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-mono text-slate-400 bg-slate-800/80 border border-slate-700/60">
                                <%= leader.divisi %>
                            </span>
                            <% } %>
                        </div>

                        <!-- Nama -->
                        <h3 class="text-white text-xl sm:text-2xl font-black tracking-tight leading-tight mb-1 group-hover:text-blue-100 transition">
                            <%= leader.nama %>
                        </h3>

                        <!-- Periode -->
                        <% if (leader.periode) { %>
                        <p class="text-slate-500 text-[11px] font-mono flex items-center justify-center sm:justify-start gap-1.5 mb-3">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            Periode <%= leader.periode %>
                        </p>
                        <% } %>

                        <!-- Deskripsi (2 baris) -->
                        <% if (leader.deskripsi) { %>
                        <p class="text-slate-400 text-sm leading-relaxed line-clamp-2 max-w-xl mb-4"><%= leader.deskripsi %></p>
                        <% } %>

                        <!-- CTA -->
                        <div class="inline-flex items-center gap-1.5 text-[10px] font-black uppercase tracking-widest text-blue-400 group-hover:text-blue-300 transition">
                            Lihat Profil Lengkap
                            <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                        </div>
                    </div>

                </div>
            </button>

            <!-- ── ANGGOTA GRID (item 2+) ── -->
            <% if (orgList.length > 1) { %>
            <div class="mb-5 flex items-center gap-3">
                <div class="h-px flex-1 bg-slate-800/80"></div>
                <span class="text-[10px] font-mono text-slate-600 uppercase tracking-widest px-2">Tim Pengurus</span>
                <div class="h-px flex-1 bg-slate-800/80"></div>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
                <% for (var i = 1; i < orgList.length; i++) { %>
                <% var member = orgList[i]; var colorClass = avatarBgClass[i % avatarBgClass.length]; %>
                <button type="button" data-org-idx="<%= i %>"
                    class="group relative flex flex-col items-center text-center bg-slate-900/50 border border-slate-800 rounded-2xl p-5 hover:border-blue-500/35 hover:bg-slate-900 transition-all duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 overflow-hidden">

                    <!-- Hover glow -->
                    <div class="absolute inset-0 bg-gradient-to-b from-blue-500/0 to-blue-500/0 group-hover:from-blue-500/5 transition-all duration-300 pointer-events-none rounded-2xl"></div>

                    <!-- Foto / Avatar -->
                    <div class="relative mb-3">
                        <% if (member.foto) { %>
                        <div class="h-16 w-16 rounded-2xl overflow-hidden border border-slate-700 group-hover:border-blue-500/40 shadow-md transition-all duration-300 group-hover:shadow-blue-900/20 group-hover:shadow-lg">
                            <img src="<%= member.foto %>" alt="<%= member.nama %>" class="h-full w-full object-cover object-center group-hover:scale-110 transition-transform duration-500">
                        </div>
                        <% } else { %>
                        <div class="h-16 w-16 rounded-2xl border-2 <%= colorClass %> flex items-center justify-center text-base font-black group-hover:scale-105 transition-transform duration-300">
                            <%- getInitials(member.nama) %>
                        </div>
                        <% } %>
                    </div>

                    <!-- Jabatan -->
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-widest bg-slate-800 text-slate-500 border border-slate-700/80 group-hover:text-slate-400 group-hover:border-slate-600 transition max-w-full truncate mb-2">
                        <%= member.jabatan %>
                    </span>

                    <!-- Nama -->
                    <p class="text-slate-200 text-xs font-bold leading-snug group-hover:text-white transition line-clamp-2 w-full"><%= member.nama %></p>

                    <!-- Divisi -->
                    <% if (member.divisi) { %>
                    <p class="text-[10px] font-mono text-slate-600 truncate max-w-full mt-1 group-hover:text-slate-500 transition"><%= member.divisi %></p>
                    <% } %>

                    <!-- Bottom hint -->
                    <div class="mt-auto pt-3 flex items-center gap-1 text-[9px] font-mono text-slate-700 group-hover:text-blue-500/70 transition uppercase tracking-widest">
                        Profil
                        <svg class="w-2.5 h-2.5 opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                    </div>

                </button>
                <% } %>
            </div>
            <% } %>

            <% } else { %>
            <div class="text-center py-16 sm:py-24 border border-dashed border-slate-800 rounded-2xl">
                <div class="h-12 w-12 rounded-2xl bg-slate-800 border border-slate-700 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-6 h-6 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <p class="text-slate-500 font-medium text-sm">Belum ada data struktur organisasi.</p>
                <p class="text-slate-700 text-xs font-mono mt-1">Segera hadir</p>
            </div>
            <% } %>

        </div>
    </section>

    <!-- Data anggota (aman dari XSS — tidak dieksekusi browser) -->
    <script type="application/json" id="org-json"><%- JSON.stringify(
        (typeof sekretariat !== 'undefined' && sekretariat && sekretariat.strukturOrganisasi)
            ? sekretariat.strukturOrganisasi.map(function(m) {
                return { nama: m.nama||'', jabatan: m.jabatan||'', divisi: m.divisi||'', periode: m.periode||'', deskripsi: m.deskripsi||'', foto: m.foto||'' };
              })
            : []
    ) %></script>

    <script>
    (function() {
        /* ── Data ── */
        var ORG_DATA = JSON.parse(document.getElementById('org-json').textContent);

        var ABGC = ['rgba(59,130,246,.15)','rgba(139,92,246,.15)','rgba(16,185,129,.15)','rgba(245,158,11,.15)','rgba(244,63,94,.15)','rgba(6,182,212,.15)'];
        var ACOL = ['#93c5fd','#c4b5fd','#6ee7b7','#fcd34d','#fda4af','#67e8f9'];
        var ABRD = ['rgba(59,130,246,.35)','rgba(139,92,246,.35)','rgba(16,185,129,.35)','rgba(245,158,11,.35)','rgba(244,63,94,.35)','rgba(6,182,212,.35)'];

        function initials(n) {
            if (!n) return '?';
            var p = n.trim().split(/\s+/);
            return p.length === 1 ? p[0][0].toUpperCase() : (p[0][0]+p[p.length-1][0]).toUpperCase();
        }
        function esc(s) {
            return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        }

        /* ── Buat overlay HTML dan append ke body ── */
        var overlay = document.createElement('div');
        overlay.id = 'org-overlay';
        overlay.style.cssText = 'display:none;position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;background:rgba(2,8,23,.9);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);align-items:center;justify-content:center;padding:16px;';
        overlay.innerHTML =
            '<div id="org-modal" style="position:relative;width:100%;max-width:440px;max-height:92vh;background:#0f172a;border:1px solid rgba(148,163,184,.12);border-radius:28px;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 40px 100px rgba(0,0,0,.9),0 0 0 1px rgba(255,255,255,.03);">' +

                /* ── HEADER (foto atau gradient) ── */
                '<div id="op-header" style="position:relative;flex-shrink:0;overflow:hidden;">' +
                    /* foto bg */
                    '<div id="op-foto-bg" style="display:none;height:200px;overflow:hidden;">' +
                        '<img id="op-foto" src="" alt="" style="width:100%;height:100%;object-fit:cover;object-position:center 20%;filter:brightness(.5) saturate(1.1);">' +
                        '<div style="position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(to bottom,rgba(2,8,23,.1) 0%,rgba(2,8,23,.6) 60%,#0f172a 100%);"></div>' +
                    '</div>' +
                    /* gradient bg (no foto) */
                    '<div id="op-grad-bg" style="display:none;height:130px;"></div>' +

                    /* close button */
                    '<button id="op-close1" style="position:absolute;top:14px;right:14px;height:32px;width:32px;border-radius:50%;background:rgba(15,23,42,.75);border:1px solid rgba(148,163,184,.2);display:flex;align-items:center;justify-content:center;cursor:pointer;color:#94a3b8;z-index:2;transition:background .15s;">' +
                        '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>' +
                    '</button>' +

                    /* avatar + nama overlap di bawah header */
                    '<div style="display:flex;align-items:flex-end;gap:16px;padding:0 24px 20px;position:relative;z-index:1;">' +
                        '<div id="op-avatar" style="height:72px;width:72px;border-radius:18px;border:3px solid #0f172a;display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:900;flex-shrink:0;box-shadow:0 8px 24px rgba(0,0,0,.4);margin-bottom:-4px;overflow:hidden;"></div>' +
                        '<div style="flex:1;min-width:0;padding-bottom:4px;">' +
                            '<div id="op-badges" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px;"></div>' +
                            '<p id="op-nama" style="color:#f1f5f9;font-size:18px;font-weight:900;line-height:1.2;letter-spacing:-.02em;margin:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></p>' +
                        '</div>' +
                    '</div>' +
                '</div>' +

                /* ── BODY ── */
                '<div style="overflow-y:auto;flex:1;">' +
                    '<div style="padding:0 24px 24px;display:flex;flex-direction:column;gap:16px;">' +

                        /* meta row */
                        '<div id="op-meta" style="display:flex;flex-wrap:wrap;gap:12px;">' +
                            '<div id="op-periode-wrap" style="display:none;align-items:center;gap:6px;">' +
                                '<svg width="12" height="12" fill="none" stroke="#64748b" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>' +
                                '<span id="op-periode" style="color:#64748b;font-size:11px;font-family:monospace;"></span>' +
                            '</div>' +
                        '</div>' +

                        /* deskripsi */
                        '<div id="op-desc-wrap" style="display:none;border-top:1px solid #1e293b;padding-top:16px;">' +
                            '<p style="color:#475569;font-size:10px;font-family:monospace;text-transform:uppercase;letter-spacing:.12em;margin:0 0 10px;">Tentang</p>' +
                            '<p id="op-desc" style="color:#94a3b8;font-size:13px;line-height:1.8;white-space:pre-wrap;margin:0;"></p>' +
                        '</div>' +

                    '</div>' +
                '</div>' +

            '</div>';
        document.body.appendChild(overlay);

        /* ── Close handlers ── */
        function closePopup() {
            var modal = document.getElementById('org-modal');
            modal.style.transition = 'opacity .2s ease, transform .2s ease';
            modal.style.opacity = '0';
            modal.style.transform = 'translateY(14px) scale(.97)';
            setTimeout(function() {
                overlay.style.display = 'none';
                document.body.style.overflow = '';
            }, 210);
        }
        overlay.addEventListener('click', function(e) { if (e.target === overlay) closePopup(); });
        document.getElementById('op-close1').addEventListener('click', closePopup);
        document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && overlay.style.display !== 'none') closePopup(); });

        /* ── Open handler ── */
        function openPopup(idx) {
            var m = ORG_DATA[idx];
            if (!m) return;
            var ci = idx % ABGC.length;

            var fotoBg  = document.getElementById('op-foto-bg');
            var gradBg  = document.getElementById('op-grad-bg');
            var avatar  = document.getElementById('op-avatar');
            var header  = document.getElementById('op-header');

            if (m.foto) {
                /* mode foto: tampilkan hero foto, avatar = foto juga */
                document.getElementById('op-foto').src = m.foto;
                document.getElementById('op-foto').alt = m.nama;
                fotoBg.style.display = 'block';
                gradBg.style.display = 'none';
                /* avatar pakai img supaya konsisten */
                avatar.innerHTML = '<img src="' + m.foto + '" alt="" style="width:100%;height:100%;object-fit:cover;object-position:center top;">';
                avatar.style.background  = 'transparent';
                avatar.style.borderColor = 'rgba(255,255,255,.15)';
                avatar.style.color       = 'transparent';
                /* geser avatar supaya overlap dengan foto */
                header.style.paddingTop  = '0';
            } else {
                /* mode no-foto: gradient header */
                fotoBg.style.display = 'none';
                gradBg.style.display = 'block';
                gradBg.style.background = 'linear-gradient(135deg,' + ABGC[ci].replace('.15',',.25') + ' 0%,rgba(15,23,42,1) 100%)';
                avatar.innerHTML = initials(m.nama);
                avatar.style.background  = ABGC[ci];
                avatar.style.borderColor = ABRD[ci];
                avatar.style.color       = ACOL[ci];
                header.style.paddingTop  = '0';
            }

            /* badges */
            var badges = document.getElementById('op-badges');
            badges.innerHTML = '';
            if (m.jabatan) badges.innerHTML += '<span style="display:inline-flex;align-items:center;padding:3px 9px;border-radius:999px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;background:rgba(59,130,246,.15);color:#93c5fd;border:1px solid rgba(59,130,246,.3);">' + esc(m.jabatan) + '</span>';
            if (m.divisi)  badges.innerHTML += '<span style="display:inline-flex;align-items:center;padding:3px 9px;border-radius:999px;font-size:9px;font-family:monospace;color:#64748b;background:rgba(30,41,59,.8);border:1px solid #334155;">' + esc(m.divisi) + '</span>';

            /* nama */
            document.getElementById('op-nama').textContent = m.nama;

            /* periode */
            var pw = document.getElementById('op-periode-wrap');
            var pEl = document.getElementById('op-periode');
            pw.style.display = m.periode ? 'flex' : 'none';
            if (m.periode) pEl.textContent = 'Periode ' + m.periode;

            /* meta row visibility */
            var meta = document.getElementById('op-meta');
            meta.style.display = m.periode ? 'flex' : 'none';

            /* deskripsi */
            var dw = document.getElementById('op-desc-wrap');
            dw.style.display = m.deskripsi ? 'block' : 'none';
            if (m.deskripsi) document.getElementById('op-desc').textContent = m.deskripsi;

            /* tampilkan dengan animasi */
            var modal = document.getElementById('org-modal');
            modal.style.transition = 'none';
            modal.style.opacity    = '0';
            modal.style.transform  = 'translateY(20px) scale(.96)';
            overlay.style.display  = 'flex';
            document.body.style.overflow = 'hidden';
            requestAnimationFrame(function() {
                requestAnimationFrame(function() {
                    modal.style.transition = 'opacity .25s cubic-bezier(.16,1,.3,1), transform .25s cubic-bezier(.16,1,.3,1)';
                    modal.style.opacity    = '1';
                    modal.style.transform  = 'translateY(0) scale(1)';
                });
            });
        }

        /* ── Attach ke semua card ── */
        document.querySelectorAll('[data-org-idx]').forEach(function(btn) {
            btn.addEventListener('click', function() {
                openPopup(parseInt(this.getAttribute('data-org-idx'), 10));
            });
        });
    })();
    </script>

