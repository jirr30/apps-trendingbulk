<%- include('partials/header') %>

<div class="min-h-screen bg-slate-950 text-slate-200">

    <!-- ── HERO ─────────────────────────────────────────────────── -->
    <section class="relative overflow-hidden border-b border-slate-800/60 min-h-[500px]">

        <% if (typeof heroPhotos !== 'undefined' && heroPhotos.length > 0) { %>
        <div id="hero-slideshow" class="absolute inset-0 z-0">
            <% heroPhotos.forEach(function(photo, i) { %>
            <div class="hero-slide absolute inset-0" style="opacity:<%= i === 0 ? 1 : 0 %>;transition:opacity 1.4s ease;">
                <img src="<%= photo.fileUrl %>" alt="<%= photo.title %>" loading="lazy" class="w-full h-full object-cover block">
            </div>
            <% }) %>
            <div class="absolute inset-0 z-[1]" style="background:linear-gradient(to bottom,rgba(2,8,23,0.55) 0%,rgba(2,8,23,0.8) 60%,rgba(2,8,23,1) 100%);"></div>
        </div>
        <% } else { %>
        <div class="absolute inset-0 z-0" style="background:linear-gradient(135deg,#0f172a 0%,#020817 50%,#0f172a 100%);"></div>
        <% } %>

        <div class="max-w-4xl mx-auto relative px-5 py-16 sm:py-20 md:py-28 text-center z-[2]">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-amber-500/30 bg-amber-500/10 mb-5">
                <span class="h-1.5 w-1.5 rounded-full bg-amber-400 animate-pulse"></span>
                <span class="text-[10px] font-mono text-amber-400 uppercase tracking-widest">Live Updates</span>
            </div>
            <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-white mb-4 leading-tight tracking-tight">
                Berita <span class="text-amber-400">Terkini</span>
            </h1>
            <p class="text-slate-400 text-sm sm:text-base md:text-lg max-w-xl mx-auto leading-relaxed px-2">
                Informasi dan kabar terbaru dari kegiatan dan perkembangan kami.
            </p>
        </div>

        <% if (typeof heroPhotos !== 'undefined' && heroPhotos.length > 1) { %>
        <div id="hero-dots" class="absolute bottom-5 left-1/2 -translate-x-1/2 flex gap-2 z-[2]">
            <% heroPhotos.forEach(function(_, i) { %>
            <span class="hero-dot" data-index="<%= i %>"
                  style="width:<%= i === 0 ? '20px' : '7px' %>;height:7px;border-radius:9999px;cursor:pointer;transition:all 0.3s;background:<%= i === 0 ? '#f59e0b' : 'rgba(255,255,255,0.25)' %>;"></span>
            <% }) %>
        </div>
        <% } %>
    </section>

    <script>
    (function() {
        var slides = document.querySelectorAll('.hero-slide');
        var dots   = document.querySelectorAll('.hero-dot');
        if (slides.length < 2) return;
        var current = 0;
        function goTo(n) {
            dots[current].style.width = '7px';
            dots[current].style.background = 'rgba(255,255,255,0.25)';
            slides[current].style.opacity = 0;
            current = n % slides.length;
            slides[current].style.opacity = 1;
            dots[current].style.width = '20px';
            dots[current].style.background = '#f59e0b';
        }
        dots.forEach(function(dot) {
            dot.addEventListener('click', function() { goTo(parseInt(this.dataset.index)); });
        });
        setInterval(function() { goTo(current + 1); }, 4500);
    })();
    </script>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 sidebar-grid">
      <div class="min-w-0">

    <!-- ── BERITA ─────────────────────────────────────────────── -->
    <section class="py-10 sm:py-12 border-b border-slate-900">
        <div>

            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-amber-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Berita Terkini</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5">Informasi terbaru dari kami</p>
                </div>
                <% if (totalBerita > 0) { %>
                <span class="ml-auto text-[10px] font-mono bg-slate-900 text-slate-500 px-3 py-1 rounded-full border border-slate-800 shrink-0"><%= totalBerita %> berita</span>
                <% } %>
            </div>

            <% if (beritaList.length === 0) { %>
            <div class="text-center py-16 sm:py-24 border border-dashed border-slate-800 rounded-2xl">
                <div class="h-12 w-12 rounded-2xl bg-slate-800 border border-slate-700 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-6 h-6 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v10a2 2 0 01-2 2z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 4v6h-6"/>
                    </svg>
                </div>
                <p class="text-slate-500 font-medium text-sm">Belum ada berita.</p>
                <p class="text-slate-700 text-xs font-mono mt-1">Segera hadir</p>
            </div>

            <% } else { %>

            <% const _cms = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des']; %>
            <div class="flex flex-col gap-5">
            <% beritaList.forEach(function(berita, idx) { %>
            <%
                const _d = berita.createdAt;
                const _t = (berita.content || '').replace(/<[^>]*>/g,' ').replace(/\s+/g,' ').trim();
                const _e = _t.length > 200 ? _t.substring(0,200) + '...' : _t;
            %>
            <a href="/berita/<%= berita.slug || berita._id %>"
               class="group flex flex-col sm:flex-row bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden hover:border-amber-500/50 hover:bg-slate-900 transition-all duration-300">
                <!-- Gambar kiri — aspect-video konsisten semua breakpoint -->
                <div class="relative shrink-0 w-full sm:w-64 md:w-72 aspect-video">
                    <% if (berita.thumbnail) { %>
                    <img src="<%= berita.thumbnail %>" alt="<%= berita.title %>"
                         class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                    <% } else { %>
                    <div class="absolute inset-0 flex items-center justify-center bg-slate-800">
                        <svg class="w-10 h-10 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v10a2 2 0 01-2 2z"/>
                        </svg>
                    </div>
                    <% } %>
                    <div class="absolute top-3 left-3">
                        <% if (idx === 0) { %>
                        <span class="text-[9px] font-black uppercase tracking-widest px-2.5 py-1 rounded-lg bg-amber-500 text-slate-950">Terbaru</span>
                        <% } else { %>
                        <span class="inline-flex items-center justify-center h-7 w-7 rounded-lg bg-slate-950/80 border border-slate-700 text-[10px] font-black text-slate-400 font-mono"><%= String(idx + 1).padStart(2, '0') %></span>
                        <% } %>
                    </div>
                </div>
                <!-- Info kanan -->
                <div class="flex flex-col justify-between p-5 sm:p-6 flex-1 min-w-0">
                    <div>
                        <div class="flex items-center gap-2 mb-3">
                            <div class="h-5 w-5 rounded-md bg-amber-500/10 border border-amber-500/20 flex items-center justify-center">
                                <span class="text-[8px] font-black text-amber-400 uppercase">
                                    <%= berita.author ? berita.author.username.charAt(0).toUpperCase() : 'A' %>
                                </span>
                            </div>
                            <span class="text-[10px] font-bold text-slate-500">@<%= berita.author ? berita.author.username : 'admin' %></span>
                            <span class="text-slate-700">·</span>
                            <span class="text-[10px] font-mono text-slate-600"><%= _d.getDate() + ' ' + _cms[_d.getMonth()] + ' ' + _d.getFullYear() %></span>
                        </div>
                        <h2 class="text-base sm:text-lg font-black text-white group-hover:text-amber-300 transition leading-snug mb-3 line-clamp-2">
                            <%= berita.title %>
                        </h2>
                        <p class="text-slate-400 text-xs sm:text-sm leading-relaxed line-clamp-3">
                            <%= _e %>
                        </p>
                    </div>
                    <div class="flex items-center justify-end mt-4 pt-4 border-t border-slate-800/60">
                        <span class="inline-flex items-center gap-1.5 text-[10px] font-black uppercase tracking-widest text-amber-400 group-hover:gap-3 transition-all">
                            Baca Selengkapnya
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        </span>
                    </div>
                </div>
            </a>
            <% }) %>
            </div>

            <% } %>

            <!-- PAGINASI -->
            <% if (totalPages > 1) { %>
            <div class="flex items-center justify-center gap-2 mt-10">
                <% if (currentPage > 1) { %>
                <a href="/berita?page=<%= currentPage - 1 %>"
                   class="flex items-center gap-1.5 px-4 py-2 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-300 text-xs font-bold rounded-xl transition">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
                    Sebelumnya
                </a>
                <% } %>
                <% for (var p = 1; p <= totalPages; p++) { %>
                    <% if (p === currentPage) { %>
                    <span class="w-9 h-9 flex items-center justify-center bg-amber-500 text-slate-950 text-xs font-black rounded-xl">
                        <%= p %>
                    </span>
                    <% } else if (p === 1 || p === totalPages || (p >= currentPage - 1 && p <= currentPage + 1)) { %>
                    <a href="/berita?page=<%= p %>"
                       class="w-9 h-9 flex items-center justify-center bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-400 hover:text-white text-xs font-bold rounded-xl transition">
                        <%= p %>
                    </a>
                    <% } else if (p === currentPage - 2 || p === currentPage + 2) { %>
                    <span class="w-9 h-9 flex items-center justify-center text-slate-600 text-xs">…</span>
                    <% } %>
                <% } %>
                <% if (currentPage < totalPages) { %>
                <a href="/berita?page=<%= currentPage + 1 %>"
                   class="flex items-center gap-1.5 px-4 py-2 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-300 text-xs font-bold rounded-xl transition">
                    Selanjutnya
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                </a>
                <% } %>
            </div>
            <p class="text-center text-[10px] font-mono text-slate-600 mt-3">
                Halaman <%= currentPage %> dari <%= totalPages %> &bull; <%= totalBerita %> berita
            </p>
            <% } %>

        </div>
    </section>

    <!-- SECTION: JELAJAHI HALAMAN LAIN (mobile) -->
    <section class="lg:hidden py-12 sm:py-16 border-b border-slate-900">
        <div>
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-emerald-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Jelajahi Lebih Lanjut</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5">Temukan lebih banyak dari Teater Saphalta</p>
                </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <a href="/" class="group relative bg-slate-900/60 border border-slate-800 hover:border-blue-500/50 rounded-2xl p-5 transition-all duration-300 overflow-hidden flex flex-col gap-3">
                    <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-2xl"></div>
                    <div class="h-11 w-11 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center group-hover:bg-blue-500/20 transition">
                        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-white group-hover:text-blue-300 transition mb-1">Tentang Kami</h3>
                        <p class="text-slate-500 text-xs leading-relaxed">Profil Teater Saphalta</p>
                    </div>
                    <div class="mt-auto flex items-center gap-1 text-[10px] font-black uppercase tracking-widest text-blue-500 group-hover:gap-2 transition-all">Lihat Profil <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
                </a>
                <a href="/galeri" class="group relative bg-slate-900/60 border border-slate-800 hover:border-blue-500/50 rounded-2xl p-5 transition-all duration-300 overflow-hidden flex flex-col gap-3">
                    <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-2xl"></div>
                    <div class="h-11 w-11 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center group-hover:bg-blue-500/20 transition">
                        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-white group-hover:text-blue-300 transition mb-1">Galeri Foto & Video</h3>
                        <p class="text-slate-500 text-xs leading-relaxed">Dokumentasi kegiatan kami</p>
                    </div>
                    <div class="mt-auto flex items-center gap-1 text-[10px] font-black uppercase tracking-widest text-blue-500 group-hover:gap-2 transition-all">Lihat Galeri <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
                </a>
                <a href="/articles" class="group relative bg-slate-900/60 border border-slate-800 hover:border-emerald-500/50 rounded-2xl p-5 transition-all duration-300 overflow-hidden flex flex-col gap-3">
                    <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-2xl"></div>
                    <div class="h-11 w-11 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center group-hover:bg-emerald-500/20 transition">
                        <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-white group-hover:text-emerald-300 transition mb-1">Artikel & Materi</h3>
                        <p class="text-slate-500 text-xs leading-relaxed">Naskah, materi & jadwal latihan</p>
                    </div>
                    <div class="mt-auto flex items-center gap-1 text-[10px] font-black uppercase tracking-widest text-emerald-500 group-hover:gap-2 transition-all">Lihat Artikel <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
                </a>
                <a href="/sekretariat" class="group relative bg-slate-900/60 border border-slate-800 hover:border-violet-500/50 rounded-2xl p-5 transition-all duration-300 overflow-hidden flex flex-col gap-3">
                    <div class="absolute inset-0 bg-gradient-to-br from-violet-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-2xl"></div>
                    <div class="h-11 w-11 rounded-xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center group-hover:bg-violet-500/20 transition">
                        <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-white group-hover:text-violet-300 transition mb-1">Sekretariat</h3>
                        <p class="text-slate-500 text-xs leading-relaxed">Struktur organisasi & kontak</p>
                    </div>
                    <div class="mt-auto flex items-center gap-1 text-[10px] font-black uppercase tracking-widest text-violet-500 group-hover:gap-2 transition-all">Lihat Info <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
                </a>
            </div>
        </div>
    </section>

      </div><!-- end main column -->

      <aside class="hidden lg:block">
        <div class="sticky top-24 py-10 flex flex-col gap-2">
          <div class="flex items-center gap-2 mb-3">
            <div class="h-7 w-1 bg-emerald-500 rounded-full shrink-0"></div>
            <div>
              <h2 class="text-sm font-black text-white tracking-tight">Jelajahi Lebih Lanjut</h2>
              <p class="text-slate-500 text-[10px] font-mono mt-0.5">Temukan lebih banyak</p>
