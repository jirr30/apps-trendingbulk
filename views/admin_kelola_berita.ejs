<%- include('partials/admin_header', { pageTitle: 'Kelola Berita' }) %>

<div class="min-h-screen bg-slate-950">

    <!-- Page Header -->
    <div class="border-b border-slate-800/60 bg-slate-900/30 backdrop-blur-sm sticky top-14 z-20">
        <div class="max-w-7xl mx-auto px-4 md:px-6 py-4 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
            <div class="flex items-center gap-3">
                <div class="h-8 w-8 bg-blue-600 rounded-xl flex items-center justify-center shadow-lg shadow-blue-900/30 shrink-0">
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                </div>
                <div>
                    <h1 class="text-sm font-black text-white uppercase tracking-tight">Kelola Berita</h1>
                    <p class="text-[10px] font-mono text-slate-500 mt-0.5">
                        <span class="text-blue-400"><%= beritaList.length %></span> artikel · input, edit & hapus
                    </p>
                </div>
            </div>
            <div class="flex items-center gap-2 shrink-0">
                <!-- Preview public page -->
                <a href="/berita" target="_blank"
                   class="inline-flex items-center gap-2 px-4 py-2.5 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-400 hover:text-white text-[10px] font-bold uppercase tracking-widest rounded-xl transition">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                    Lihat Publik
                </a>
                <a href="/admin/berita/add"
                   class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-[10px] font-black uppercase tracking-widest rounded-xl transition shadow-lg shadow-blue-900/20">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
                    </svg>
                    Tulis Berita
                </a>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 md:px-6 py-8 space-y-8">

        <!-- Stats Cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-5 relative overflow-hidden group hover:border-blue-500/40 transition">
                <div class="absolute top-0 right-0 h-20 w-20 bg-blue-600/5 rounded-full -translate-y-6 translate-x-6 group-hover:bg-blue-600/10 transition"></div>
                <div class="relative">
                    <div class="flex items-center justify-between mb-3">
                        <div class="h-8 w-8 bg-blue-600/10 border border-blue-500/20 rounded-xl flex items-center justify-center">
                            <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                            </svg>
                        </div>
                        <span class="text-[9px] font-mono text-blue-400/60 uppercase tracking-widest">Total</span>
                    </div>
                    <p class="text-3xl font-black text-white"><%= stats.total %></p>
                    <p class="text-[10px] font-mono text-slate-500 mt-1">Semua Berita</p>
                </div>
            </div>

            <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-5 relative overflow-hidden group hover:border-emerald-500/40 transition">
                <div class="absolute top-0 right-0 h-20 w-20 bg-emerald-600/5 rounded-full -translate-y-6 translate-x-6 group-hover:bg-emerald-600/10 transition"></div>
                <div class="relative">
                    <div class="flex items-center justify-between mb-3">
                        <div class="h-8 w-8 bg-emerald-600/10 border border-emerald-500/20 rounded-xl flex items-center justify-center">
                            <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <span class="text-[9px] font-mono text-emerald-400/60 uppercase tracking-widest">Baru</span>
                    </div>
                    <p class="text-3xl font-black text-white"><%= stats.thisMonth %></p>
                    <p class="text-[10px] font-mono text-slate-500 mt-1">Bulan Ini</p>
                </div>
            </div>

            <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-5 relative overflow-hidden group hover:border-violet-500/40 transition">
                <div class="absolute top-0 right-0 h-20 w-20 bg-violet-600/5 rounded-full -translate-y-6 translate-x-6 group-hover:bg-violet-600/10 transition"></div>
                <div class="relative">
                    <div class="flex items-center justify-between mb-3">
                        <div class="h-8 w-8 bg-violet-600/10 border border-violet-500/20 rounded-xl flex items-center justify-center">
                            <svg class="w-4 h-4 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <span class="text-[9px] font-mono text-violet-400/60 uppercase tracking-widest">Media</span>
                    </div>
                    <p class="text-3xl font-black text-white"><%= stats.withThumbnail %></p>
                    <p class="text-[10px] font-mono text-slate-500 mt-1">Ada Thumbnail</p>
                </div>
            </div>

            <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-5 relative overflow-hidden group hover:border-red-500/40 transition">
                <div class="absolute top-0 right-0 h-20 w-20 bg-red-600/5 rounded-full -translate-y-6 translate-x-6 group-hover:bg-red-600/10 transition"></div>
                <div class="relative">
                    <div class="flex items-center justify-between mb-3">
                        <div class="h-8 w-8 bg-red-600/10 border border-red-500/20 rounded-xl flex items-center justify-center">
                            <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <span class="text-[9px] font-mono text-red-400/60 uppercase tracking-widest">Video</span>
                    </div>
                    <p class="text-3xl font-black text-white"><%= stats.withVideo %></p>
                    <p class="text-[10px] font-mono text-slate-500 mt-1">Ada Video</p>
                </div>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="flex flex-col sm:flex-row gap-3 items-stretch sm:items-center">
            <div class="relative flex-1">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <input id="search-input" type="text" placeholder="Cari judul atau penulis..."
                    class="w-full pl-10 pr-4 py-2.5 bg-slate-900 border border-slate-800 rounded-xl text-sm text-white placeholder-slate-600 outline-none focus:border-blue-500/50 focus:ring-1 focus:ring-blue-500/20 transition font-mono">
                <div class="absolute inset-y-0 right-0 pr-4 flex items-center">
                    <span class="text-[10px] font-mono text-slate-600 hidden" id="search-result-text"></span>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <select id="sort-select"
                    class="bg-slate-900 border border-slate-800 text-slate-400 text-xs rounded-xl px-3 py-2.5 outline-none focus:border-blue-500/50 transition cursor-pointer font-mono">
                    <option value="newest">Terbaru</option>
                    <option value="oldest">Terlama</option>
                    <option value="title">A–Z Judul</option>
                </select>
                <div class="flex items-center bg-slate-900 border border-slate-800 rounded-xl p-1 gap-1">
                    <button id="btn-view-table" title="Tampilan Tabel"
                        class="p-1.5 rounded-lg bg-slate-800 text-white transition">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
                        </svg>
                    </button>
                    <button id="btn-view-grid" title="Tampilan Grid"
                        class="p-1.5 rounded-lg text-slate-600 hover:text-slate-300 transition">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- TABLE VIEW -->
        <div id="view-table">
            <div class="bg-slate-900/30 border border-slate-800 rounded-2xl overflow-hidden">
                <table class="w-full text-left">
                    <thead>
                        <tr class="border-b border-slate-800 bg-slate-900/60">
                            <th class="px-5 py-4 text-[10px] font-black text-slate-500 uppercase tracking-widest w-12">#</th>
                            <th class="px-5 py-4 text-[10px] font-black text-slate-500 uppercase tracking-widest">Berita</th>
                            <th class="px-5 py-4 text-[10px] font-black text-slate-500 uppercase tracking-widest hidden md:table-cell">Penulis</th>
                            <th class="px-5 py-4 text-[10px] font-black text-slate-500 uppercase tracking-widest hidden lg:table-cell">Tanggal</th>
                            <th class="px-5 py-4 text-[10px] font-black text-slate-500 uppercase tracking-widest hidden lg:table-cell">Media</th>
                            <th class="px-5 py-4 text-[10px] font-black text-slate-500 uppercase tracking-widest text-right">Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="table-body" class="divide-y divide-slate-800/40">
                        <% beritaList.forEach((article, index) => { %>
                        <tr class="article-row hover:bg-slate-800/20 transition-colors group"
                            data-title="<%= article.title.toLowerCase() %>"
                            data-author="<%= article.author ? article.author.username.toLowerCase() : 'admin' %>"
                            data-date="<%= article.createdAt.getTime() %>">
                            <td class="px-5 py-4">
                                <span class="text-[11px] font-mono text-slate-600"><%= String(index + 1).padStart(2, '0') %></span>
                            </td>
                            <td class="px-5 py-4">
                                <div class="flex items-center gap-4">
                                    <div class="shrink-0 h-12 w-16 rounded-xl overflow-hidden bg-slate-800 border border-slate-700">
                                        <% if (article.thumbnail) { %>
                                            <img src="<%= article.thumbnail %>" alt="" class="h-full w-full object-cover group-hover:scale-105 transition duration-300">
                                        <% } else { %>
                                            <div class="h-full w-full flex items-center justify-center">
                                                <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                                </svg>
                                            </div>
                                        <% } %>
                                    </div>
                                    <div class="min-w-0">
                                        <span class="text-slate-200 font-bold text-sm line-clamp-1 block leading-snug mb-1"><%= article.title %></span>
                                        <p class="text-[10px] font-mono text-slate-600 line-clamp-1 hidden sm:block">
                                            <%
                                                const plainText = article.content.replace(/<[^>]*>/g, ' ').replace(/\s+/g,' ').trim();
                                                const excerpt = plainText.length > 80 ? plainText.substring(0, 80) + '...' : plainText;
                                            %>
                                            <%= excerpt %>
                                        </p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-5 py-4 hidden md:table-cell">
                                <div class="flex items-center gap-2">
                                    <div class="h-6 w-6 rounded-lg bg-slate-800 border border-slate-700 flex items-center justify-center">
                                        <span class="text-[9px] font-black text-slate-400 uppercase">
                                            <%= article.author ? article.author.username.charAt(0).toUpperCase() : 'A' %>
                                        </span>
                                    </div>
                                    <span class="text-xs font-bold text-slate-400">@<%= article.author ? article.author.username : 'admin' %></span>
                                </div>
                            </td>
                            <td class="px-5 py-4 hidden lg:table-cell">
                                <%
                                    const d = article.createdAt;
                                    const months = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
                                %>
                                <p class="text-xs font-mono text-slate-400"><%= d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear() %></p>
                                <p class="text-[9px] font-mono text-slate-600 mt-0.5"><%= String(d.getHours()).padStart(2,'0') %>:<%= String(d.getMinutes()).padStart(2,'0') %> WIB</p>
                            </td>
                            <td class="px-5 py-4 hidden lg:table-cell">
                                <div class="flex items-center gap-1.5">
                                    <% if (article.thumbnail) { %>
                                        <span class="inline-flex items-center gap-1 text-[9px] font-bold px-2 py-1 rounded-lg bg-violet-500/10 text-violet-400 border border-violet-500/20 uppercase">
                                            <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                            Foto
                                        </span>
                                    <% } %>
                                    <% if (article.videoUrl) { %>
                                        <span class="inline-flex items-center gap-1 text-[9px] font-bold px-2 py-1 rounded-lg bg-red-500/10 text-red-400 border border-red-500/20 uppercase">
                                            <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                            Video
                                        </span>
                                    <% } %>
                                    <% if (!article.thumbnail && !article.videoUrl) { %>
                                        <span class="text-[9px] font-mono text-slate-700">—</span>
                                    <% } %>
                                </div>
                            </td>
                            <td class="px-5 py-4">
                                <div class="flex items-center justify-end gap-1">
                                    <a href="/berita/detail/<%= article._id %>" target="_blank"
                                       class="p-2 text-slate-600 hover:text-blue-400 hover:bg-blue-500/10 rounded-lg transition" title="Preview">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                        </svg>
                                    </a>
                                    <a href="/admin/berita/edit/<%= article._id %>"
                                       class="p-2 text-slate-600 hover:text-emerald-400 hover:bg-emerald-500/10 rounded-lg transition" title="Edit">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                        </svg>
                                    </a>
                                    <form action="/admin/berita/delete/<%= article._id %>" method="POST"
                                          onsubmit="return confirm('Hapus berita ini?');">
                                        <button type="submit" class="p-2 text-slate-600 hover:text-red-400 hover:bg-red-500/10 rounded-lg transition" title="Hapus">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>

                <!-- Empty state -->
                <div id="table-empty" class="hidden py-16 text-center">
                    <svg class="w-8 h-8 text-slate-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <p class="text-slate-500 font-bold text-sm">Tidak ada hasil</p>
                    <p class="text-slate-600 text-xs font-mono mt-1">Coba kata kunci lain</p>
                </div>

                <div class="border-t border-slate-800/40 px-5 py-3 bg-slate-900/20">
                    <p class="text-[10px] font-mono text-slate-600">
                        Menampilkan <span id="visible-count" class="text-slate-400"><%= beritaList.length %></span> dari <span class="text-slate-400"><%= beritaList.length %></span> berita
                    </p>
                </div>
            </div>
        </div>

        <!-- GRID VIEW -->
        <div id="view-grid" class="hidden">
            <div id="grid-container" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
                <% beritaList.forEach(article => { %>
                <div class="article-card bg-slate-900/40 border border-slate-800 rounded-2xl overflow-hidden group hover:border-blue-500/40 hover:shadow-xl hover:shadow-blue-900/10 transition-all duration-300"
                     data-title="<%= article.title.toLowerCase() %>"
                     data-author="<%= article.author ? article.author.username.toLowerCase() : 'admin' %>"
                     data-date="<%= article.createdAt.getTime() %>">

                    <div class="aspect-video relative overflow-hidden bg-slate-800">
                        <% if (article.thumbnail) { %>
                            <img src="<%= article.thumbnail %>" alt="" class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
                            <div class="absolute inset-0 bg-gradient-to-t from-slate-950/70 to-transparent"></div>
                        <% } else { %>
                            <div class="w-full h-full flex items-center justify-center">
                                <svg class="w-8 h-8 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v10a2 2 0 01-2 2z"/>
                                </svg>
                            </div>
                        <% } %>
                        <% if (article.videoUrl) { %>
                            <div class="absolute top-2.5 right-2.5">
                                <span class="flex items-center gap-1 text-[9px] font-bold px-2 py-1 rounded-lg bg-red-600/90 text-white uppercase backdrop-blur-sm">
                                    <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                    Video
                                </span>
                            </div>
                        <% } %>
                    </div>

                    <div class="p-4">
                        <p class="text-slate-100 font-bold text-sm line-clamp-2 leading-snug mb-2"><%= article.title %></p>
                        <p class="text-[10px] font-mono text-slate-600 line-clamp-2 mb-3">
                            <%
                                const pt2 = article.content.replace(/<[^>]*>/g, ' ').replace(/\s+/g,' ').trim();
                                const ex2 = pt2.length > 90 ? pt2.substring(0, 90) + '...' : pt2;
                            %>
                            <%= ex2 %>
                        </p>
                        <div class="flex items-center justify-between pt-3 border-t border-slate-800/60 mb-3">
                            <div class="flex items-center gap-1.5">
                                <div class="h-5 w-5 rounded-md bg-slate-800 flex items-center justify-center">
                                    <span class="text-[8px] font-black text-slate-400 uppercase"><%= article.author ? article.author.username.charAt(0).toUpperCase() : 'A' %></span>
                                </div>
                                <span class="text-[10px] font-bold text-slate-500">@<%= article.author ? article.author.username : 'admin' %></span>
                            </div>
                            <%
                                const dc = article.createdAt;
                                const ms = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
                            %>
                            <span class="text-[9px] font-mono text-slate-600"><%= dc.getDate() + ' ' + ms[dc.getMonth()] %></span>
                        </div>
                        <!-- Actions -->
                        <div class="flex items-center gap-2 pt-3 border-t border-slate-800/60">
                            <a href="/berita/detail/<%= article._id %>" target="_blank"
                               class="p-2 text-slate-600 hover:text-blue-400 hover:bg-blue-500/10 rounded-lg transition" title="Preview">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                            </a>
                            <a href="/admin/berita/edit/<%= article._id %>"
                               class="flex-1 flex items-center justify-center gap-1.5 py-2 text-[10px] font-bold uppercase tracking-wide text-slate-400 hover:text-emerald-400 bg-slate-800/60 hover:bg-emerald-500/10 border border-slate-700 hover:border-emerald-500/30 rounded-xl transition">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                                Edit
                            </a>
                            <form action="/admin/berita/delete/<%= article._id %>" method="POST"
                                  onsubmit="return confirm('Hapus berita ini?');" class="flex-1">
                                <button type="submit"
                                        class="w-full flex items-center justify-center gap-1.5 py-2 text-[10px] font-bold uppercase tracking-wide text-slate-400 hover:text-red-400 bg-slate-800/60 hover:bg-red-500/10 border border-slate-700 hover:border-red-500/30 rounded-xl transition">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                    Hapus
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>

            <div id="grid-empty" class="hidden py-16 text-center">
                <svg class="w-8 h-8 text-slate-700 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-slate-500 font-bold text-sm">Tidak ada hasil</p>
                <p class="text-slate-600 text-xs font-mono mt-1">Coba kata kunci lain</p>
            </div>
        </div>

        <!-- Empty state total 0 -->
        <% if (beritaList.length === 0) { %>
        <div class="text-center py-24">
            <div class="h-20 w-20 bg-slate-900 border border-slate-800 rounded-3xl flex items-center justify-center mx-auto mb-6 shadow-inner">
                <svg class="w-9 h-9 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v10a2 2 0 01-2 2z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 4v6h-6"/>
                </svg>
            </div>
            <h3 class="text-white font-black text-lg uppercase tracking-tight mb-2">Belum Ada Berita</h3>
            <p class="text-slate-500 text-sm mb-6 font-mono">Mulai dengan menulis berita pertama</p>
            <a href="/admin/berita/add"
               class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white text-xs font-black uppercase tracking-widest rounded-xl transition shadow-lg shadow-blue-900/20">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Tulis Berita Pertama
            </a>
        </div>
        <% } %>

    </div>
</div>

<script>
(function () {
    const rowsTable    = Array.from(document.querySelectorAll('tr.article-row'));
    const cardsGrid    = Array.from(document.querySelectorAll('.article-card'));
    const searchInput  = document.getElementById('search-input');
    const sortSelect   = document.getElementById('sort-select');
    const visibleCount = document.getElementById('visible-count');
    const resultText   = document.getElementById('search-result-text');
    const tableEmpty   = document.getElementById('table-empty');
    const gridEmpty    = document.getElementById('grid-empty');
    const tableBody    = document.getElementById('table-body');
    const gridContainer= document.getElementById('grid-container');
    const viewTable    = document.getElementById('view-table');
    const viewGrid     = document.getElementById('view-grid');
    const btnTable     = document.getElementById('btn-view-table');
    const btnGrid      = document.getElementById('btn-view-grid');
    let currentView    = 'table';

    function setView(v) {
        currentView = v;
        viewTable.classList.toggle('hidden', v !== 'table');
        viewGrid.classList.toggle('hidden', v !== 'grid');
        btnTable.classList.toggle('bg-slate-800', v === 'table');
        btnTable.classList.toggle('text-white',   v === 'table');
        btnTable.classList.toggle('text-slate-600', v !== 'table');
        btnGrid.classList.toggle('bg-slate-800', v === 'grid');
        btnGrid.classList.toggle('text-white',   v === 'grid');
        btnGrid.classList.toggle('text-slate-600', v !== 'grid');
        filterAndSort();
    }

    btnTable.addEventListener('click', () => setView('table'));
    btnGrid.addEventListener('click', () => setView('grid'));

    function filterAndSort() {
        const q       = searchInput.value.trim().toLowerCase();
        const sortVal = sortSelect.value;
        const items   = currentView === 'table' ? rowsTable : cardsGrid;

        const visible = items.filter(el => {
            const match = !q || el.dataset.title.includes(q) || el.dataset.author.includes(q);
            el.classList.toggle('hidden', !match);
            return match;
        });

        const parent = currentView === 'table' ? tableBody : gridContainer;
        visible.sort((a, b) => {
            if (sortVal === 'newest') return Number(b.dataset.date) - Number(a.dataset.date);
            if (sortVal === 'oldest') return Number(a.dataset.date) - Number(b.dataset.date);
            if (sortVal === 'title')  return a.dataset.title.localeCompare(b.dataset.title);
            return 0;
        });
        visible.forEach(el => parent.appendChild(el));

        if (currentView === 'table') tableEmpty.classList.toggle('hidden', visible.length > 0);
        else gridEmpty.classList.toggle('hidden', visible.length > 0);

        if (visibleCount) visibleCount.textContent = visible.length;
        if (q) {
            resultText.textContent = visible.length + ' hasil untuk "' + q + '"';
            resultText.classList.remove('hidden');
        } else {
            resultText.classList.add('hidden');
        }
    }

    searchInput.addEventListener('input', filterAndSort);
    sortSelect.addEventListener('change', filterAndSort);

    const obs = new MutationObserver(() => {
        tableBody.querySelectorAll('tr.article-row:not(.hidden)').forEach((r, i) => {
            const c = r.querySelector('td:first-child span');
            if (c) c.textContent = String(i + 1).padStart(2, '0');
        });
    });
    if (tableBody) obs.observe(tableBody, { childList: true });
})();
</script>

<%- include('partials/footer') %>
