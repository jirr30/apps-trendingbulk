<%- include('partials/admin_header', { pageTitle: pageTitle }) %>

<div class="max-w-7xl mx-auto px-4 md:px-6 py-8">

    <!-- Page Header -->
    <div class="mb-8 flex items-center justify-between">
        <div class="flex items-center gap-4">
            <a href="/admin/jadwal-latihan" class="p-2 rounded-xl text-slate-500 hover:text-white hover:bg-slate-800 transition">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
            </a>
            <div>
                <h1 class="text-2xl font-black uppercase tracking-tighter text-white">Materi Latihan</h1>
                <p class="text-slate-500 text-xs font-mono mt-1">Kelola daftar materi latihan</p>
            </div>
        </div>
        <a href="/admin/materi-latihan/add"
            class="flex items-center gap-2 px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-xs font-black uppercase tracking-widest rounded-xl transition shadow-lg shadow-blue-900/20">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Tambah Materi
        </a>
    </div>

    <!-- Alert -->
    <% if (success) { %>
    <div class="mb-6 px-4 py-3 bg-emerald-500/10 border border-emerald-500/30 rounded-xl text-emerald-400 text-xs font-mono">
        ✓ <%= success %>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="mb-6 px-4 py-3 bg-red-500/10 border border-red-500/30 rounded-xl text-red-400 text-xs font-mono">
        ✗ <%= error %>
    </div>
    <% } %>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-4">
            <p class="text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-1">Total Materi</p>
            <p class="text-2xl font-black text-white"><%= materi.length %></p>
        </div>
        <% const kategoriAktif = kategoriList.filter(k => grouped[k].length > 0); %>
        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-4">
            <p class="text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-1">Kategori</p>
            <p class="text-2xl font-black text-white"><%= kategoriAktif.length %></p>
        </div>
        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-4">
            <p class="text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-1">Total Durasi</p>
            <p class="text-2xl font-black text-white"><%= materi.reduce((a, m) => a + (m.durasi || 0), 0) %> <span class="text-sm font-normal text-slate-500">mnt</span></p>
        </div>
        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-4">
            <p class="text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-1">Terbanyak</p>
            <p class="text-sm font-black text-white truncate">
                <% const top = kategoriAktif.sort((a,b) => grouped[b].length - grouped[a].length)[0]; %>
                <%= top || '-' %>
            </p>
        </div>
    </div>

    <% if (materi.length === 0) { %>
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-16 text-center">
        <p class="text-5xl mb-4">📚</p>
        <p class="text-slate-400 font-bold text-sm">Belum ada materi latihan</p>
        <p class="text-slate-600 text-xs font-mono mt-1">Klik tombol "Tambah Materi" untuk memulai</p>
    </div>
    <% } else { %>

    <!-- Warna per kategori -->
    <%
    const kategoriColor = {
        'Teknik':  { bg: 'bg-blue-500/10',    text: 'text-blue-400',    border: 'border-blue-500/20',    dot: 'bg-blue-500' },
        'Fisik':   { bg: 'bg-orange-500/10',   text: 'text-orange-400',  border: 'border-orange-500/20',  dot: 'bg-orange-500' },
        'Taktik':  { bg: 'bg-purple-500/10',   text: 'text-purple-400',  border: 'border-purple-500/20',  dot: 'bg-purple-500' },
        'Mental':  { bg: 'bg-emerald-500/10',  text: 'text-emerald-400', border: 'border-emerald-500/20', dot: 'bg-emerald-500' },
        'Sparring':{ bg: 'bg-red-500/10',      text: 'text-red-400',     border: 'border-red-500/20',     dot: 'bg-red-500' },
        'Lainnya': { bg: 'bg-slate-500/10',    text: 'text-slate-400',   border: 'border-slate-500/20',   dot: 'bg-slate-500' },
    };
    %>

    <div class="space-y-6">
        <% kategoriList.forEach(kat => { %>
        <% if (grouped[kat] && grouped[kat].length > 0) { %>
        <% const c = kategoriColor[kat] || kategoriColor['Lainnya']; %>
        <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-800 flex items-center gap-3">
                <span class="h-2 w-2 rounded-full <%= c.dot %>"></span>
                <h2 class="text-sm font-black uppercase tracking-widest text-white"><%= kat %></h2>
                <span class="text-[10px] font-mono bg-slate-800 text-slate-400 px-2 py-0.5 rounded-lg border border-slate-700">
                    <%= grouped[kat].length %> materi
                </span>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-slate-800">
                            <th class="text-left px-6 py-3 text-[10px] font-mono uppercase tracking-widest text-slate-500">Nama Materi</th>
                            <th class="text-left px-6 py-3 text-[10px] font-mono uppercase tracking-widest text-slate-500">Deskripsi</th>
                            <th class="text-left px-6 py-3 text-[10px] font-mono uppercase tracking-widest text-slate-500">Durasi</th>
                            <th class="px-6 py-3"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800/50">
                        <% grouped[kat].forEach(item => { %>
                        <tr class="hover:bg-slate-800/30 transition group">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <span class="inline-block h-1.5 w-1.5 rounded-full <%= c.dot %>"></span>
                                    <span class="text-xs font-bold text-slate-200"><%= item.nama %></span>
                                </div>
                            </td>
                            <td class="px-6 py-4 max-w-xs">
                                <span class="text-xs text-slate-400 line-clamp-2"><%= item.deskripsi || '-' %></span>
                            </td>
                            <td class="px-6 py-4">
                                <% if (item.durasi) { %>
                                <span class="text-xs font-mono text-slate-300"><%= item.durasi %> mnt</span>
                                <% } else { %>
                                <span class="text-xs text-slate-600">-</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition justify-end">
                                    <a href="/admin/materi-latihan/<%= item._id %>/edit"
                                        class="p-1.5 rounded-lg text-slate-500 hover:text-blue-400 hover:bg-blue-500/10 transition">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                        </svg>
                                    </a>
                                    <form action="/admin/materi-latihan/delete/<%= item._id %>" method="POST"
                                          onsubmit="return confirm('Hapus materi ini?')">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit"
                                            class="p-1.5 rounded-lg text-slate-500 hover:text-red-400 hover:bg-red-500/10 transition">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } %>
        <% }) %>
    </div>
    <% } %>
</div>

</body>
</html>
