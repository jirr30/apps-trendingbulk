<%- include('partials/header') %>

<div class="min-h-screen bg-slate-950 text-slate-200">

    <!-- ── HERO ─────────────────────────────────────────────────── -->
    <section class="relative overflow-hidden border-b border-slate-800/60 min-h-[520px] pb-[52px]">

        <% if (typeof heroPhotos !== 'undefined' && heroPhotos.length > 0) { %>
        <div id="hero-slideshow" class="absolute inset-0 z-0">
            <% heroPhotos.forEach(function(photo, i) { %>
            <div class="hero-slide absolute inset-0" style="opacity:<%= i === 0 ? 1 : 0 %>;transition:opacity 1.4s ease;">
                <img src="<%= photo.fileUrl %>" alt="<%= photo.title %>" class="w-full h-full object-cover block">
            </div>
            <% }) %>
            <div class="absolute inset-0 z-[1]" style="background:linear-gradient(to bottom,rgba(2,8,23,0.55) 0%,rgba(2,8,23,0.8) 60%,rgba(2,8,23,1) 100%);"></div>
        </div>
        <% } else { %>
        <div class="absolute inset-0 z-0" style="background:linear-gradient(135deg,#0f172a 0%,#020817 50%,#0f172a 100%);"></div>
        <% } %>

        <div class="max-w-6xl mx-auto relative px-5 py-16 sm:py-20 md:py-24 z-[2]">
            <div class="max-w-2xl">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/10 mb-5">
                    <span class="h-1.5 w-1.5 rounded-full bg-blue-400 animate-pulse"></span>
                    <span class="text-[10px] font-mono text-blue-400 uppercase tracking-widest">Selamat Datang</span>
                </div>
                <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-white mb-4 leading-tight tracking-tight">
                    Dunia <span class="text-blue-500">Teater</span> &<br>Seni Pertunjukan
                </h1>
                <p class="text-slate-400 text-sm sm:text-base md:text-lg leading-relaxed mb-8">
                    Temukan kisah di balik panggung, karya-karya terbaik, dan setiap cerita yang kami hadirkan untuk Anda.
                </p>
                <div class="flex flex-wrap items-center gap-3">
                    <a href="/profile" class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-xl transition-all duration-200 shadow-lg shadow-blue-900/40">
                        Jelajahi Karya
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                    </a>
                    <a href="/sekretariat" class="inline-flex items-center gap-2 px-6 py-3 border border-slate-600 hover:border-slate-400 bg-slate-900/60 hover:bg-slate-800/80 text-slate-300 hover:text-white text-sm font-bold rounded-xl transition-all duration-200">
                        Tentang Kami
                    </a>
                </div>
            </div>
        </div>

        <!-- Stats bar -->
        <div class="absolute bottom-0 left-0 right-0 z-[2] border-t border-slate-800/60" style="background:rgba(2,8,23,0.85);backdrop-filter:blur(8px);">
            <div class="max-w-6xl mx-auto px-5 py-3 flex flex-wrap items-center justify-start gap-6 sm:gap-10">
                <% if (typeof pencapaianList !== 'undefined' && pencapaianList.length > 0) { %>
                <div class="flex items-center gap-2">
                    <span class="text-xl font-black text-amber-400"><%= pencapaianList.length %>+</span>
                    <span class="text-[10px] text-slate-500 font-mono uppercase tracking-wider leading-tight">Penghargaan</span>
                </div>
                <% } %>
                <% if (typeof templates !== 'undefined' && templates.length > 0) { %>
                <div class="flex items-center gap-2">
                    <span class="text-xl font-black text-blue-400"><%= templates.length %>+</span>
                    <span class="text-[10px] text-slate-500 font-mono uppercase tracking-wider leading-tight">Pementasan</span>
                </div>
                <% } %>
                <% if (typeof beritaList !== 'undefined' && beritaList.length > 0) { %>
                <div class="flex items-center gap-2">
                    <span class="text-xl font-black text-emerald-400"><%= beritaList.length %>+</span>
                    <span class="text-[10px] text-slate-500 font-mono uppercase tracking-wider leading-tight">Berita</span>
                </div>
                <% } %>
                <% if (typeof sejarah !== 'undefined' && sejarah && sejarah.tahunBerdiri) { %>
                <div class="flex items-center gap-2">
                    <span class="text-xl font-black text-violet-400"><%= sejarah.tahunBerdiri %></span>
                    <span class="text-[10px] text-slate-500 font-mono uppercase tracking-wider leading-tight">Aktif Sejak</span>
                </div>
                <% } %>
            </div>
        </div>

        <% if (typeof heroPhotos !== 'undefined' && heroPhotos.length > 1) { %>
        <div id="hero-dots" class="absolute bottom-5 right-6 flex gap-2 z-[2]">
            <% heroPhotos.forEach(function(_, i) { %>
            <span class="hero-dot" data-index="<%= i %>"
                  style="width:<%= i === 0 ? '20px' : '7px' %>;height:7px;border-radius:9999px;cursor:pointer;transition:all 0.3s;background:<%= i === 0 ? '#3b82f6' : 'rgba(255,255,255,0.25)' %>;"></span>
            <% }) %>
        </div>
        <% } %>
    </section>

    <script>
    (function() {
        var slides = document.querySelectorAll('.hero-slide');
        var dots   = document.querySelectorAll('.hero-dot');
        if (slides.length < 2) return;
        var current = 0;
        function goTo(n) {
            dots[current].style.width = '7px';
            dots[current].style.background = 'rgba(255,255,255,0.25)';
            slides[current].style.opacity = 0;
            current = n % slides.length;
            slides[current].style.opacity = 1;
            dots[current].style.width = '20px';
            dots[current].style.background = '#3b82f6';
        }
        dots.forEach(function(dot) {
            dot.addEventListener('click', function() { goTo(parseInt(this.dataset.index)); });
        });
        setInterval(function() { goTo(current + 1); }, 4500);
    })();
    </script>

    <!-- SECTION: BERITA TERKINI -->
    <section class="px-4 sm:px-6 py-10 sm:py-12 border-b border-slate-900">
        <div class="max-w-6xl mx-auto">
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-amber-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Berita Terkini</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5">Informasi terbaru dari kami</p>
                </div>
                <a href="/berita" class="ml-auto inline-flex items-center gap-1.5 text-[10px] font-black uppercase tracking-widest text-amber-400 hover:text-amber-300 transition shrink-0">
                    Lihat Semua
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>

            <% if (typeof beritaList !== 'undefined' && beritaList.length > 0) { %>
            <%
                const bms = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
                const featuredBerita = beritaList[0];
                const restBerita = beritaList.slice(1);
                const fbd = featuredBerita.createdAt;
                const fbt = (featuredBerita.content || '').replace(/<[^>]*>/g,' ').replace(/\s+/g,' ').trim();
                const fbe = fbt.length > 200 ? fbt.substring(0,200) + '...' : fbt;
            %>
            <div class="flex flex-col lg:flex-row gap-4">
                <!-- Featured berita -->
                <a href="/berita/<%= featuredBerita.slug || featuredBerita._id %>" class="group relative lg:w-[55%] shrink-0 bg-slate-900/60 border border-slate-800 hover:border-amber-500/50 rounded-2xl overflow-hidden transition-all duration-300 flex flex-col">
                    <div class="relative aspect-video overflow-hidden bg-slate-800">
                        <% if (featuredBerita.thumbnail) { %>
                        <img src="<%= featuredBerita.thumbnail %>" alt="<%= featuredBerita.title %>"
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
                        <% } else { %>
                        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-800 to-slate-900">
                            <svg class="w-10 h-10 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v10a2 2 0 01-2 2z"/></svg>
                        </div>
                        <% } %>
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-950/20 to-transparent"></div>
                        <div class="absolute top-3 left-3">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-amber-500 text-[10px] font-black uppercase tracking-widest text-slate-950">
                                <span class="h-1.5 w-1.5 rounded-full bg-slate-900 animate-pulse"></span>Terbaru
                            </span>
                        </div>
                    </div>
                    <div class="p-5 flex flex-col flex-1">
                        <h3 class="text-base font-black text-white group-hover:text-amber-300 transition leading-snug mb-2 line-clamp-2"><%= featuredBerita.title %></h3>
                        <p class="text-slate-500 text-xs leading-relaxed line-clamp-3 mb-4"><%= fbe %></p>
                        <div class="mt-auto flex items-center justify-between">
                            <span class="text-[10px] text-slate-600 font-mono"><%= fbd.getDate() + ' ' + bms[fbd.getMonth()] + ' ' + fbd.getFullYear() %></span>
                            <span class="inline-flex items-center gap-1 text-[10px] font-black uppercase tracking-widest text-amber-500 group-hover:gap-2 transition-all">
                                Baca Selengkapnya <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                            </span>
                        </div>
                    </div>
                </a>
                <!-- Rest of berita -->
                <div class="flex flex-col gap-3 flex-1 min-w-0">
                    <% if (restBerita.length === 0) { %>
                    <div class="flex-1 flex items-center justify-center border border-dashed border-slate-800 rounded-2xl">
                        <p class="text-slate-600 text-xs font-mono">Belum ada berita lain</p>
                    </div>
                    <% } %>
                    <% restBerita.forEach(function(berita, idx) {
                        const bd2 = berita.createdAt;
                        const bt2 = (berita.content || '').replace(/<[^>]*>/g,' ').replace(/\s+/g,' ').trim();
                        const be2 = bt2.length > 80 ? bt2.substring(0,80) + '...' : bt2;
                    %>
                    <a href="/berita/<%= berita.slug || berita._id %>" class="group bg-slate-900/60 border border-slate-800 hover:border-amber-500/40 hover:bg-slate-900 rounded-2xl overflow-hidden transition-all duration-300 flex">
                        <div class="relative w-24 sm:w-28 shrink-0 overflow-hidden bg-slate-800">
                            <% if (berita.thumbnail) { %>
                            <img src="<%= berita.thumbnail %>" alt="<%= berita.title %>"
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 absolute inset-0">
                            <% } else { %>
                            <div class="absolute inset-0 flex items-center justify-center">
                                <svg class="w-6 h-6 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v10a2 2 0 01-2 2z"/></svg>
                            </div>
                            <% } %>
                        </div>
                        <div class="flex flex-col justify-between p-3.5 flex-1 min-w-0">
                            <div>
                                <h3 class="text-xs font-bold text-white mb-1 group-hover:text-amber-400 transition leading-snug line-clamp-2"><%= berita.title %></h3>
                                <p class="text-slate-600 text-[11px] leading-relaxed line-clamp-2"><%= be2 %></p>
                            </div>
                            <span class="text-[10px] text-slate-700 font-mono mt-1.5"><%= bd2.getDate() + ' ' + bms[bd2.getMonth()] + ' ' + bd2.getFullYear() %></span>
                        </div>
                    </a>
                    <% }) %>
                </div>
            </div>
            <% } else { %>
            <div class="text-center py-16 border border-dashed border-slate-800 rounded-2xl">
                <p class="text-slate-500 font-medium text-sm">Belum ada berita.</p>
                <p class="text-slate-700 text-xs font-mono mt-1">Segera hadir</p>
            </div>
            <% } %>
        </div>
    </section>

    <!-- SECTION: RIWAYAT PEMENTASAN -->
    <section class="px-4 sm:px-6 py-10 sm:py-12 border-b border-slate-900">
        <div class="max-w-6xl mx-auto">
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-blue-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Riwayat Pementasan</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5">Koleksi produksi dan pementasan karya Teater Saphalta</p>
                </div>
                <a href="/profile#pementasan" class="ml-auto inline-flex items-center gap-1.5 text-[10px] font-black uppercase tracking-widest text-blue-400 hover:text-blue-300 transition shrink-0">
                    Lihat Semua
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>

            <% if (templates && templates.length > 0) { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                <% templates.forEach(function(item, idx) { %>
                <a href="/detail/<%= item._id %>" class="group relative bg-slate-900/60 border border-slate-800 hover:border-blue-500/40 rounded-2xl overflow-hidden transition-all duration-300 flex flex-col">
                    <div class="relative aspect-video overflow-hidden bg-slate-800">
                        <img src="<%= item.imageUrl %>" alt="<%= item.title %>"
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-950/80 to-transparent"></div>
                        <div class="absolute top-2 left-2 h-6 w-6 rounded-md bg-slate-950/80 border border-slate-700 flex items-center justify-center">
                            <span class="text-[9px] font-black text-slate-400 font-mono"><%= String(idx + 1).padStart(2,'0') %></span>
                        </div>
                        <% if (item.labelKarya) { %>
                        <div class="absolute bottom-2 left-2">
                            <span class="text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-md bg-blue-500/20 text-blue-300 border border-blue-500/30"><%= item.labelKarya %></span>
                        </div>
                        <% } %>
                    </div>
                    <div class="p-4 flex flex-col flex-1">
                        <h3 class="text-sm font-bold text-white group-hover:text-blue-400 transition leading-snug line-clamp-2 mb-1"><%= item.title %></h3>
                        <p class="text-slate-500 text-xs leading-relaxed line-clamp-2 mb-3"><%= item.description %></p>
                        <div class="mt-auto flex items-center justify-between">
                            <span class="text-[10px] font-mono text-slate-600"><%= item.createdAt.toLocaleDateString('id-ID', { year:'numeric', month:'short' }) %></span>
                            <span class="inline-flex items-center gap-1 text-[10px] font-black text-blue-500 uppercase tracking-widest">
                                Detail <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                            </span>
                        </div>
                    </div>
                </a>
                <% }) %>
            </div>
            <% } else { %>
            <div class="text-center py-16 border border-dashed border-slate-800 rounded-2xl">
                <p class="text-slate-500 font-medium text-sm">Belum ada pementasan.</p>
                <p class="text-slate-700 text-xs font-mono mt-1">Segera hadir</p>
            </div>
            <% } %>
        </div>
    </section>

    <!-- SECTION: PENCAPAIAN -->
    <section class="px-4 sm:px-6 py-10 sm:py-12 border-b border-slate-900">
        <div class="max-w-6xl mx-auto">
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-amber-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Pencapaian Kami</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5">Penghargaan dan prestasi Teater Saphalta</p>
                </div>
                <a href="/profile#pencapaian" class="ml-auto inline-flex items-center gap-1.5 text-[10px] font-black uppercase tracking-widest text-amber-400 hover:text-amber-300 transition shrink-0">
                    Lihat Semua
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>

            <% if (typeof pencapaianList !== 'undefined' && pencapaianList.length > 0) { %>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <% pencapaianList.forEach(function(item, idx) { %>
                <div class="relative bg-slate-900/60 border border-slate-800 hover:border-amber-500/40 rounded-2xl p-5 transition group flex flex-col items-center text-center overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-b from-amber-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl pointer-events-none"></div>
                    <div class="relative mb-4">
                        <div class="h-16 w-16 rounded-full bg-amber-500/10 border border-amber-500/20 flex items-center justify-center group-hover:bg-amber-500/15 transition-all duration-300">
                            <svg class="w-8 h-8 text-amber-400 group-hover:text-amber-300 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0"/>
                            </svg>
                        </div>
                        <div class="absolute -top-1 -right-1 h-5 w-5 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center">
                            <span class="text-[9px] font-black text-slate-400 font-mono"><%= String(idx + 1).padStart(2,'0') %></span>
                        </div>
                    </div>
                    <h3 class="text-sm font-bold text-white leading-snug mb-3 line-clamp-2 group-hover:text-amber-300 transition"><%= item.namaEvent %></h3>
                    <div class="flex flex-wrap justify-center gap-1.5 mt-auto">
                        <% if (item.kategori) { %>
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-emerald-500/10 text-emerald-400 border border-emerald-500/20"><%= item.kategori %></span>
                        <% } %>
                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10px] font-black font-mono text-amber-400 bg-amber-500/10 border border-amber-500/20">
                            <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            <%= item.tahun %>
                        </span>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } else { %>
            <div class="text-center py-16 border border-dashed border-slate-800 rounded-2xl">
                <p class="text-slate-500 font-medium text-sm">Belum ada pencapaian.</p>
                <p class="text-slate-700 text-xs font-mono mt-1">Segera hadir</p>
            </div>
            <% } %>
        </div>
    </section>

    <!-- SECTION: SEJARAH -->
    <% if (typeof sejarah !== 'undefined' && sejarah && sejarah.konten) { %>
    <section class="px-4 sm:px-6 py-10 sm:py-12 border-b border-slate-900">
        <div class="max-w-6xl mx-auto">
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-violet-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Sejarah Kami</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5">Perjalanan dan jejak langkah kami</p>
                </div>
                <a href="/profile#sejarah" class="ml-auto inline-flex items-center gap-1.5 text-[10px] font-black uppercase tracking-widest text-violet-400 hover:text-violet-300 transition shrink-0">
                    Selengkapnya
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>
            <div class="flex flex-col lg:flex-row gap-8 lg:gap-10">
                <% if (typeof heroPhotos !== 'undefined' && heroPhotos.length > 0) { %>
                <div class="w-full lg:w-72 xl:w-80 shrink-0">
                    <div class="grid grid-cols-2 gap-2">
                        <% heroPhotos.slice(0, 4).forEach(function(photo) { %>
                        <div class="aspect-square overflow-hidden rounded-xl border border-slate-800">
                            <img src="<%= photo.fileUrl %>" alt="<%= photo.title %>"
                                 class="w-full h-full object-cover hover:scale-105 transition-transform duration-500">
                        </div>
                        <% }) %>
                    </div>
                </div>
                <% } %>
                <div class="flex-1 min-w-0 flex flex-col justify-between gap-6">
                    <p class="text-slate-300 text-sm leading-relaxed line-clamp-6">
                        <%= sejarah.konten.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim().substring(0, 500) %>...
                    </p>
                    <a href="/profile#sejarah" class="self-start inline-flex items-center gap-2 px-5 py-2.5 bg-violet-600 hover:bg-violet-500 text-white text-xs font-bold rounded-xl transition shadow-lg shadow-violet-900/20">
                        Baca Selengkapnya
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </section>
    <% } %>

    <!-- SECTION: KISAH TERBARU (Articles) -->
    <section class="px-4 sm:px-6 py-10 sm:py-12 border-b border-slate-900">
        <div class="max-w-6xl mx-auto">
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-emerald-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Kisah Terbaru</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5">Artikel dan cerita dari panggung kami</p>
                </div>
                <a href="/articles" class="ml-auto inline-flex items-center gap-1.5 text-[10px] font-black uppercase tracking-widest text-emerald-400 hover:text-emerald-300 transition shrink-0">
                    Lihat Semua
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>

            <% if (articles && articles.length > 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <% articles.forEach(function(article) { %>
                <a href="/article/<%= article._id %>" class="group flex gap-4 bg-slate-900/60 border border-slate-800 hover:border-emerald-500/40 hover:bg-slate-900 rounded-2xl p-4 sm:p-5 transition-all duration-300">
                    <div class="shrink-0 w-20 h-20 rounded-xl overflow-hidden bg-slate-800 border border-slate-700">
                        <% if (article.thumbnail) { %>
                        <img src="<%= article.thumbnail %>" alt="<%= article.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <% } else { %>
                        <div class="w-full h-full flex items-center justify-center">
                            <svg class="w-6 h-6 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        </div>
                        <% } %>
                    </div>
                    <div class="flex-1 min-w-0">
                        <h3 class="text-sm font-bold text-white group-hover:text-emerald-400 transition mb-1 line-clamp-2 leading-snug"><%= article.title %></h3>
                        <p class="text-xs text-slate-500 line-clamp-2 leading-relaxed mb-3">
                            <%= (article.content || '').replace(/<[^>]*>/g, '').substring(0, 100) %>...
                        </p>
                        <div class="flex items-center gap-2">
                            <span class="text-[10px] font-mono text-slate-600"><%= article.createdAt.toLocaleDateString('id-ID') %></span>
                            <span class="text-slate-700">·</span>
                            <span class="text-[10px] font-bold text-slate-500">@<%= article.author ? article.author.username : 'admin' %></span>
                        </div>
                    </div>
                </a>
                <% }) %>
            </div>
            <% } else { %>
            <div class="text-center py-16 border border-dashed border-slate-800 rounded-2xl">
                <p class="text-slate-500 font-medium text-sm">Belum ada artikel tersedia.</p>
                <p class="text-slate-700 text-xs font-mono mt-1">Segera hadir</p>
            </div>
            <% } %>
        </div>
    </section>

    <!-- SECTION: PREVIEW GALERI -->
    <% if (typeof galeriList !== 'undefined' && galeriList.length > 0) { %>
    <section class="px-4 sm:px-6 py-10 sm:py-12 border-b border-slate-900">
        <div class="max-w-6xl mx-auto">
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-blue-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Galeri Terbaru</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5">Dokumentasi kegiatan dan pementasan kami</p>
                </div>
                <a href="/galeri" class="ml-auto inline-flex items-center gap-1.5 text-[10px] font-black uppercase tracking-widest text-blue-400 hover:text-blue-300 transition shrink-0">
                    Lihat Semua
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 sm:gap-3">
                <% galeriList.forEach(function(photo, idx) { %>
                <a href="/galeri" class="group relative aspect-square overflow-hidden rounded-xl border border-slate-800 hover:border-blue-500/40 transition-all duration-300 block bg-slate-800 <%= idx === 0 ? 'col-span-2 row-span-2' : '' %>">
                    <img src="<%= photo.fileUrl %>" alt="<%= photo.title %>"
                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                    <div class="absolute inset-0 bg-slate-950/0 group-hover:bg-slate-950/30 transition-all duration-300"></div>
                    <% if (idx === 0) { %>
                    <div class="absolute bottom-3 left-3">
                        <span class="text-[9px] font-black uppercase tracking-widest px-2.5 py-1 rounded-lg bg-blue-500 text-white">Terbaru</span>
                    </div>
                    <% } %>
                </a>
                <% }) %>
            </div>
        </div>
    </section>
    <% } %>

    <!-- SECTION: JELAJAHI HALAMAN LAIN -->
    <section class="px-4 sm:px-6 py-12 sm:py-16 border-b border-slate-900">
        <div class="max-w-6xl mx-auto">
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-emerald-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Jelajahi Lebih Lanjut</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5">Temukan lebih banyak dari Teater Saphalta</p>
                </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                <a href="/profile" class="group relative bg-slate-900/60 border border-slate-800 hover:border-blue-500/50 rounded-2xl p-5 transition-all duration-300 overflow-hidden flex flex-col gap-3">
                    <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-2xl"></div>
                    <div class="h-11 w-11 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center group-hover:bg-blue-500/20 transition">
                        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-white group-hover:text-blue-300 transition mb-1">Tentang Kami</h3>
                        <p class="text-slate-500 text-xs leading-relaxed">Sejarah, pencapaian dan pementasan kami</p>
                    </div>
                    <div class="mt-auto flex items-center gap-1 text-[10px] font-black uppercase tracking-widest text-blue-500 group-hover:gap-2 transition-all">Lihat Profil <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
                </a>
                <a href="/berita" class="group relative bg-slate-900/60 border border-slate-800 hover:border-amber-500/50 rounded-2xl p-5 transition-all duration-300 overflow-hidden flex flex-col gap-3">
                    <div class="absolute inset-0 bg-gradient-to-br from-amber-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-2xl"></div>
                    <div class="h-11 w-11 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center group-hover:bg-amber-500/20 transition">
                        <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v10a2 2 0 01-2 2z"/><path stroke-linecap="round" stroke-linejoin="round" d="M17 4v6h-6"/></svg>
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-white group-hover:text-amber-300 transition mb-1">Berita Terkini</h3>
                        <p class="text-slate-500 text-xs leading-relaxed">Informasi dan kabar terbaru kegiatan kami</p>
                    </div>
                    <div class="mt-auto flex items-center gap-1 text-[10px] font-black uppercase tracking-widest text-amber-500 group-hover:gap-2 transition-all">Lihat Berita <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
                </a>
                <a href="/galeri" class="group relative bg-slate-900/60 border border-slate-800 hover:border-blue-500/50 rounded-2xl p-5 transition-all duration-300 overflow-hidden flex flex-col gap-3">
                    <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-2xl"></div>
                    <div class="h-11 w-11 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center group-hover:bg-blue-500/20 transition">
                        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-white group-hover:text-blue-300 transition mb-1">Galeri Foto & Video</h3>
                        <p class="text-slate-500 text-xs leading-relaxed">Dokumentasi kegiatan dan pementasan</p>
                    </div>
                    <div class="mt-auto flex items-center gap-1 text-[10px] font-black uppercase tracking-widest text-blue-500 group-hover:gap-2 transition-all">Lihat Galeri <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
                </a>
                <a href="/sekretariat" class="group relative bg-slate-900/60 border border-slate-800 hover:border-violet-500/50 rounded-2xl p-5 transition-all duration-300 overflow-hidden flex flex-col gap-3">
                    <div class="absolute inset-0 bg-gradient-to-br from-violet-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-2xl"></div>
                    <div class="h-11 w-11 rounded-xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center group-hover:bg-violet-500/20 transition">
                        <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-white group-hover:text-violet-300 transition mb-1">Sekretariat</h3>
                        <p class="text-slate-500 text-xs leading-relaxed">Struktur organisasi dan kontak kami</p>
                    </div>
                    <div class="mt-auto flex items-center gap-1 text-[10px] font-black uppercase tracking-widest text-violet-500 group-hover:gap-2 transition-all">Lihat Info <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div>
                </a>
            </div>
        </div>
