    <!-- SECTION: CTA PENUTUP -->
    <section class="px-4 sm:px-6 py-16 sm:py-20">
        <div class="max-w-3xl mx-auto text-center">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/10 mb-6">
                <span class="h-1.5 w-1.5 rounded-full bg-blue-400 animate-pulse"></span>
                <span class="text-[10px] font-mono text-blue-400 uppercase tracking-widest">Bergabung Bersama Kami</span>
            </div>
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-white mb-4 leading-tight tracking-tight">
                Tertarik Menjadi Bagian dari<br><span class="text-blue-500">Teater Saphalta?</span>
            </h2>
            <p class="text-slate-400 text-sm sm:text-base leading-relaxed max-w-xl mx-auto mb-8">
                Bergabunglah bersama kami dan ekspresikan kreativitasmu melalui seni pertunjukan teater yang penuh makna.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-3">
                <a href="/sekretariat" class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-xl transition shadow-lg shadow-blue-900/30">
                    Hubungi Kami
                </a>
                <a href="/galeri" class="px-6 py-3 border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-white text-sm font-bold rounded-xl transition">
                    Lihat Karya Kami
                </a>
            </div>
        </div>
    </section>

</div>

<%- include('partials/footer') %>
