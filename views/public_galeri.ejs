<%- include('partials/header', { page: 'galeri' }) %>

<div class="min-h-screen bg-slate-950 text-slate-200">

    <!-- ── HERO ───────────────────────────────────────────────────── -->
    <section class="relative overflow-hidden border-b border-slate-800/60 min-h-[500px]">

        <% if (typeof heroPhotos !== 'undefined' && heroPhotos.length > 0) { %>
        <div id="hero-slideshow" class="absolute inset-0 z-0">
            <% heroPhotos.forEach(function(photo, i) { %>
            <div class="hero-slide absolute inset-0" style="opacity:<%= i===0?1:0 %>;transition:opacity 1.4s ease;">
                <img src="<%= photo.fileUrl %>" alt="<%= photo.title %>"
                     loading="<%= i===0?'eager':'lazy' %>"
                     class="w-full h-full object-cover block">
            </div>
            <% }) %>
            <div class="absolute inset-0 z-[1]" style="background:linear-gradient(to bottom,rgba(2,8,23,0.55) 0%,rgba(2,8,23,0.82) 60%,rgba(2,8,23,1) 100%);"></div>
        </div>
        <% } else { %>
        <div class="absolute inset-0 z-0" style="background:linear-gradient(135deg,#0f172a 0%,#020817 50%,#0f172a 100%);"></div>
        <% } %>

        <div class="max-w-4xl mx-auto relative px-5 py-16 sm:py-20 md:py-24 text-center z-[2]">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/10 mb-5">
                <span class="h-1.5 w-1.5 rounded-full bg-blue-400 animate-pulse"></span>
                <span class="text-[10px] font-mono text-blue-400 uppercase tracking-widest">Dokumentasi</span>
            </div>
            <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-white mb-4 leading-tight tracking-tight">
                Galeri <span class="text-blue-500">Foto & Video</span>
            </h1>
            <p class="text-slate-400 text-sm sm:text-base max-w-xl mx-auto leading-relaxed px-2">
                Kumpulan dokumentasi foto dan video dari setiap kegiatan dan pementasan kami.
            </p>
            <%
                var totalFotoPublik = fotoGroups.reduce(function(s,g){ return s+g.photos.length; }, 0);
                var albumCount      = fotoGroups.filter(function(g){ return g.photos.length > 1; }).length;
                var videoUpload     = videos.filter(function(v){ return v.source !== 'youtube'; });
                var videoYoutube    = videos.filter(function(v){ return v.source === 'youtube'; });
            %>
            <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
                <% if (albumCount > 0) { %>
                <a href="#album" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-xl transition shadow-lg shadow-blue-900/30">
                    <%= albumCount %> Album
                </a>
                <% } %>
                <% if (totalFotoPublik > 0) { %>
                <a href="#foto" class="px-5 py-2.5 border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-white text-sm font-bold rounded-xl transition">
                    <%= totalFotoPublik %> Foto
                </a>
                <% } %>
                <% if (videoUpload.length > 0) { %>
                <a href="#video" class="px-5 py-2.5 border border-slate-700 hover:border-amber-500/50 text-slate-300 hover:text-amber-300 text-sm font-bold rounded-xl transition">
                    <%= videoUpload.length %> Video
                </a>
                <% } %>
                <% if (videoYoutube.length > 0) { %>
                <a href="#youtube" class="px-5 py-2.5 border border-red-800/40 hover:border-red-500/60 bg-red-900/10 text-red-400 hover:text-red-300 text-sm font-bold rounded-xl transition flex items-center gap-2">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    <%= videoYoutube.length %> YouTube
                </a>
                <% } %>
            </div>
        </div>

        <% if (typeof heroPhotos !== 'undefined' && heroPhotos.length > 1) { %>
        <div id="hero-dots" class="absolute bottom-5 left-1/2 -translate-x-1/2 flex gap-2 z-[2]">
            <% heroPhotos.forEach(function(_, i) { %>
            <span class="hero-dot" data-index="<%= i %>"
                  style="width:<%= i===0?'20px':'7px' %>;height:7px;border-radius:9999px;cursor:pointer;transition:all 0.3s;background:<%= i===0?'#3b82f6':'rgba(255,255,255,0.25)' %>;"></span>
            <% }) %>
        </div>
        <% } %>
    </section>

    <script>
    (function() {
        var slides = document.querySelectorAll('.hero-slide');
        var dots   = document.querySelectorAll('.hero-dot');
        if (slides.length < 2) return;
        var current = 0;
        function goTo(n) {
            dots[current].style.width = '7px';
            dots[current].style.background = 'rgba(255,255,255,0.25)';
            slides[current].style.opacity = 0;
            current = n % slides.length;
            slides[current].style.opacity = 1;
            dots[current].style.width = '20px';
            dots[current].style.background = '#3b82f6';
        }
        dots.forEach(function(d) { d.addEventListener('click', function() { goTo(parseInt(this.dataset.index)); }); });
        setInterval(function() { goTo(current + 1); }, 4500);
    })();
    </script>

    <%
        var albumGroups  = fotoGroups.filter(function(g){ return g.photos.length > 1; });
        var singleGroups = fotoGroups.filter(function(g){ return g.photos.length === 1; });
    %>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 sidebar-grid">
      <div class="min-w-0">

    <!-- ====== SECTION ALBUM ====== -->
    <% if (albumGroups.length > 0) { %>
    <section id="album" class="py-10 sm:py-12 border-b border-slate-900">
        <div>
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-violet-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Album Foto</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5">
                        <%= albumGroups.length %> album &bull; <%= albumGroups.reduce(function(s,g){ return s+g.photos.length; },0) %> foto
                    </p>
                </div>
            </div>

            <div class="flex flex-col gap-4">
                <% albumGroups.forEach(function(group, idx) {
                    var gi = fotoGroups.indexOf(group);
                    var cover = group.photos[0];
                %>
                <div class="group bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden hover:border-violet-500/50 hover:bg-slate-900 transition-all duration-300 flex flex-col sm:flex-row cursor-pointer btn-buka-album"
                     data-group="<%= gi %>" data-title="<%= group.description %>">

                    <!-- Cover kiri -->
                    <div class="relative sm:w-52 md:w-60 shrink-0 aspect-video sm:aspect-auto overflow-hidden bg-slate-800 min-h-0">
                        <img src="<%= cover.fileUrl %>" alt="<%= cover.title %>"
                             loading="lazy"
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 sm:absolute sm:inset-0">
                        <!-- Nomor urut -->
                        <div class="absolute top-3 left-3 h-7 w-7 rounded-lg bg-slate-950/80 border border-slate-700 flex items-center justify-center">
                            <span class="text-[10px] font-black text-slate-400 font-mono"><%= String(idx+1).padStart(2,'0') %></span>
                        </div>
                        <!-- Badge jumlah foto -->
                        <div class="absolute top-3 right-3">
                            <span class="text-[9px] font-black uppercase tracking-wider px-2 py-1 rounded-lg bg-black/60 backdrop-blur-sm border border-white/10 text-white">
                                📷 <%= group.photos.length %>
                            </span>
                        </div>
                    </div>

                    <!-- Info kanan -->
                    <div class="flex flex-col justify-between p-4 sm:p-5 flex-1 min-w-0">
                        <div>
                            <h3 class="text-sm sm:text-base font-bold text-white mb-1.5 group-hover:text-violet-400 transition leading-snug line-clamp-2">
                                <%= group.description %>
                            </h3>
                            <!-- Preview thumbnail strip -->
                            <div class="flex gap-1.5 mt-3 flex-wrap">
                                <% group.photos.slice(1, 5).forEach(function(p) { %>
                                <div class="w-10 h-10 rounded-lg overflow-hidden border border-slate-700 bg-slate-800 shrink-0">
                                    <img src="<%= p.fileUrl %>" alt="" loading="lazy" class="w-full h-full object-cover">
                                </div>
                                <% }) %>
                                <% if (group.photos.length > 5) { %>
                                <div class="w-10 h-10 rounded-lg bg-slate-800 border border-slate-700 flex items-center justify-center shrink-0">
                                    <span class="text-[10px] font-black text-slate-400">+<%= group.photos.length - 5 %></span>
                                </div>
                                <% } %>
                            </div>
                        </div>
                        <div class="flex flex-wrap items-center justify-between gap-3 mt-4 pt-4 border-t border-slate-800/60">
                            <span class="text-[11px] text-slate-600 font-mono">
                                <%= new Date(group.createdAt).toLocaleDateString('id-ID', { day:'numeric', month:'long', year:'numeric' }) %>
                            </span>
                            <span class="inline-flex items-center gap-1.5 px-4 py-2 bg-slate-800 group-hover:bg-violet-600 text-white text-xs font-bold rounded-lg transition duration-300 border border-slate-700 group-hover:border-violet-500">
                                Lihat Album
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                                </svg>
                            </span>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </section>
    <% } %>

    <!-- ====== SECTION FOTO SINGLE ====== -->
    <% if (singleGroups.length > 0) { %>
    <section id="foto" class="py-10 sm:py-12 border-b border-slate-900">
        <div>
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-blue-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Foto</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5"><%= singleGroups.length %> foto</p>
                </div>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
                <% singleGroups.forEach(function(group, idx) {
                    var gi = fotoGroups.indexOf(group);
                    var foto = group.photos[0];
                %>
                <div class="relative group bg-slate-900/60 border border-slate-800 hover:border-blue-500/50 rounded-2xl overflow-hidden transition-all duration-300">
                    <!-- Glow on hover -->
                    <div class="absolute inset-0 bg-gradient-to-b from-blue-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl pointer-events-none"></div>

                    <div class="relative aspect-square overflow-hidden bg-slate-800">
                        <img src="<%= foto.fileUrl %>" alt="<%= foto.title %>"
                             loading="lazy"
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <div class="absolute top-2 left-2 h-6 w-6 rounded-md bg-slate-950/80 border border-slate-700 flex items-center justify-center">
                            <span class="text-[9px] font-black text-slate-500 font-mono"><%= String(idx+1).padStart(2,'0') %></span>
                        </div>
                    </div>

                    <div class="p-4">
                        <h3 class="text-xs font-bold text-white truncate mb-0.5 group-hover:text-blue-400 transition"><%= foto.title %></h3>
                        <p class="text-[9px] font-mono text-slate-600 mb-3">
                            <%= new Date(foto.createdAt).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' }) %>
                        </p>
                        <button class="btn-lihat-foto w-full py-2 rounded-xl text-[10px] font-bold uppercase tracking-widest
                                       bg-slate-800 border border-slate-700/60 text-slate-400
                                       hover:bg-blue-600 hover:border-blue-500 hover:text-white transition"
                                data-url="<%= foto.fileUrl %>"
                                data-title="<%= foto.title %>"
                                data-desc="<%= foto.description || '' %>">
                            Lihat Foto
                        </button>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </section>
    <% } %>

    <!-- ====== EMPTY STATE ====== -->
    <% if (fotoGroups.length === 0 && videoUpload.length === 0 && videoYoutube.length === 0) { %>
    <section class="py-24">
        <div>
            <div class="text-center py-16 sm:py-24 border border-dashed border-slate-800 rounded-2xl">
                <div class="h-14 w-14 rounded-2xl bg-slate-800 border border-slate-700 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-7 h-7 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                </div>
                <p class="text-slate-500 font-medium text-sm">Belum ada media yang dipublikasikan.</p>
                <p class="text-slate-700 text-xs font-mono mt-1">Segera hadir</p>
            </div>
        </div>
    </section>
    <% } %>

    <!-- ====== SECTION VIDEO UPLOAD ====== -->
    <% if (videoUpload.length > 0) { %>
    <section id="video" class="py-10 sm:py-12 border-b border-slate-900">
        <div>
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-amber-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Video</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5"><%= videoUpload.length %> video dokumentasi</p>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                <% videoUpload.forEach(function(item, idx) { %>
                <div class="group bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden hover:border-amber-500/50 hover:bg-slate-900 transition-all duration-300">
                    <div class="relative aspect-video overflow-hidden bg-slate-900">
                        <% if (item.thumbnail) { %>
                        <img src="<%= item.thumbnail %>" alt="<%= item.title %>"
                             loading="lazy"
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 absolute inset-0">
                        <% } else { %>
                        <video preload="none" muted class="w-full h-full object-cover absolute inset-0">
                            <source src="<%= item.fileUrl %>">
                        </video>
                        <% } %>
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-950/60 via-transparent to-transparent"></div>
                        <div class="absolute top-3 left-3 h-7 w-7 rounded-lg bg-slate-950/80 border border-slate-700 flex items-center justify-center">
                            <span class="text-[10px] font-black text-slate-400 font-mono"><%= String(idx+1).padStart(2,'0') %></span>
                        </div>
                        <div class="absolute inset-0 flex items-center justify-center">
                            <div class="w-14 h-14 bg-black/50 backdrop-blur-sm rounded-full flex items-center justify-center border border-white/15
                                        group-hover:bg-amber-600/80 group-hover:border-amber-400/50 transition-all duration-300 shadow-xl">
                                <svg class="w-6 h-6 text-white ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                            </div>
                        </div>
                    </div>
                    <div class="flex flex-col justify-between p-4 sm:p-5">
                        <div>
                            <h3 class="text-sm font-bold text-white mb-1 group-hover:text-amber-400 transition leading-snug line-clamp-1"><%= item.title %></h3>
                            <% if (item.description) { %>
                            <p class="text-xs text-slate-500 leading-relaxed line-clamp-2"><%= item.description %></p>
                            <% } %>
                        </div>
                        <div class="flex flex-wrap items-center justify-between gap-3 mt-4 pt-4 border-t border-slate-800/60">
                            <span class="text-[11px] text-slate-600 font-mono">
                                <%= new Date(item.createdAt).toLocaleDateString('id-ID', { day:'numeric', month:'long', year:'numeric' }) %>
                            </span>
                            <button class="btn-lihat-video inline-flex items-center gap-1.5 px-4 py-2 bg-slate-800 hover:bg-amber-600 text-white text-xs font-bold rounded-lg transition duration-300 border border-slate-700 hover:border-amber-500"
                                    data-url="<%= item.fileUrl %>"
                                    data-title="<%= item.title %>"
                                    data-desc="<%= item.description || '' %>"
                                    data-source="upload">
                                Putar Video
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </section>
    <% } %>

    <!-- ====== SECTION YOUTUBE ====== -->
    <% if (videoYoutube.length > 0) { %>
    <section id="youtube" class="py-10 sm:py-12">
        <div>
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-red-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight flex items-center gap-2">
                        <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                        YouTube
                    </h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5"><%= videoYoutube.length %> video dari YouTube</p>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                <% videoYoutube.forEach(function(item, idx) {
                    var ytId = item.fileUrl.indexOf('/embed/') > -1
                        ? item.fileUrl.split('/embed/')[1].split('?')[0]
                        : '';
                    var ytWatch = 'https://www.youtube.com/watch?v=' + ytId;
                %>
                <div class="group bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden hover:border-red-500/40 hover:bg-slate-900 transition-all duration-300">
                    <!-- Thumbnail — klik buka popup -->
                    <div class="yt-thumb-wrap relative aspect-video overflow-hidden bg-slate-900 cursor-pointer"
                         data-vid="<%= ytId %>"
                         data-title="<%= item.title %>"
                         data-desc="<%= item.description || '' %>">
                        <img src="<%= item.thumbnail %>" alt="<%= item.title %>"
                             loading="lazy"
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 absolute inset-0"
                             onerror="this.style.display='none'">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-950/70 via-transparent to-transparent"></div>
                        <div class="absolute top-3 left-3">
                            <span class="inline-flex items-center gap-1 text-[9px] font-black uppercase tracking-wider px-2 py-1 rounded-lg bg-red-600/90 backdrop-blur-sm text-white border border-red-400/20">
                                <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                                YouTube
                            </span>
                        </div>
                        <div class="absolute top-3 right-3 h-7 w-7 rounded-lg bg-slate-950/80 border border-slate-700 flex items-center justify-center">
                            <span class="text-[10px] font-black text-slate-400 font-mono"><%= String(idx+1).padStart(2,'0') %></span>
                        </div>
                        <div class="absolute inset-0 flex items-center justify-center">
                            <div class="w-16 h-16 bg-red-600/80 backdrop-blur-sm rounded-full flex items-center justify-center border border-red-400/30
                                        group-hover:bg-red-600 group-hover:scale-110 transition-all duration-300 shadow-xl shadow-red-900/40">
                                <svg class="w-7 h-7 text-white ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col justify-between p-4 sm:p-5">
                        <div>
                            <h3 class="text-sm font-bold text-white mb-1 group-hover:text-red-400 transition leading-snug line-clamp-1"><%= item.title %></h3>
                            <% if (item.description) { %>
                            <p class="text-xs text-slate-500 leading-relaxed line-clamp-2"><%= item.description %></p>
                            <% } %>
                        </div>
                        <div class="flex flex-wrap items-center justify-between gap-3 mt-4 pt-4 border-t border-slate-800/60">
                            <span class="text-[11px] text-slate-600 font-mono">
                                <%= new Date(item.createdAt).toLocaleDateString('id-ID', { day:'numeric', month:'long', year:'numeric' }) %>
                            </span>
                            <!-- Tombol Tonton = link langsung ke YouTube (selalu berhasil) -->
                            <a href="<%= ytWatch %>" target="_blank" rel="noopener"
                               class="inline-flex items-center gap-1.5 px-4 py-2 bg-red-600 hover:bg-red-500 text-white text-xs font-bold rounded-lg transition duration-300 shadow-md shadow-red-900/30">
                                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                                Tonton di YouTube
                            </a>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </section>
    <% } %>

