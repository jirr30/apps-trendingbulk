            document.getElementById('dlg-foto-title').textContent = this.dataset.title;
            document.getElementById('dlg-foto-desc').textContent  = this.dataset.desc;
            document.getElementById('dlg-foto-img').src           = this.dataset.url;
            dlgFoto.showModal();
        });
    });
    document.getElementById('dlg-foto-close').addEventListener('click', function() { dlgFoto.close(); });
    dlgFoto.addEventListener('click', function(e) { if (e.target === dlgFoto) dlgFoto.close(); });

    // ── ALBUM ──
    var albumIdx = 0, albumData = [];

    function albumRender(i) {
        albumIdx = (i + albumData.length) % albumData.length;
        document.getElementById('dlg-album-img').src = albumData[albumIdx].url;
        document.getElementById('dlg-album-counter').textContent = (albumIdx + 1) + ' / ' + albumData.length;
        document.querySelectorAll('.album-thumb').forEach(function(t, ti) {
            t.style.outline = ti === albumIdx ? '2px solid #7c3aed' : '2px solid transparent';
            t.style.opacity = ti === albumIdx ? '1' : '0.45';
        });
        var thumbEl = document.querySelectorAll('.album-thumb')[albumIdx];
        if (thumbEl) thumbEl.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
    }

    function albumOpen(gi) {
        var group = ALBUM_DATA[gi];
        albumData = group.photos;
        document.getElementById('dlg-album-title').textContent = group.title;

        // deskripsi album
        var descSection = document.getElementById('dlg-album-desc-section');
        var descEl      = document.getElementById('dlg-album-desc');
        if (group.description && group.description.trim()) {
            descEl.textContent       = group.description;
            descSection.style.display = 'block';
        } else {
            descSection.style.display = 'none';
        }

        var strip = document.getElementById('dlg-album-thumbs');
        strip.innerHTML = '';
        albumData.forEach(function(p, i) {
            var img = document.createElement('img');
            img.src = p.url; img.alt = p.title; img.className = 'album-thumb';
            img.style.cssText = 'width:72px;height:54px;object-fit:cover;border-radius:8px;cursor:pointer;flex-shrink:0;transition:opacity 0.2s;';
            img.addEventListener('click', function() { albumRender(i); });
            strip.appendChild(img);
        });
        albumRender(0);
        dlgAlbum.showModal();
    }

    document.querySelectorAll('.btn-buka-album').forEach(function(btn) {
        btn.addEventListener('click', function() { albumOpen(parseInt(this.dataset.group)); });
    });
    document.getElementById('dlg-album-prev').addEventListener('click', function() { albumRender(albumIdx - 1); });
    document.getElementById('dlg-album-next').addEventListener('click', function() { albumRender(albumIdx + 1); });
    document.getElementById('dlg-album-close').addEventListener('click', function() { dlgAlbum.close(); });
    dlgAlbum.addEventListener('click', function(e) { if (e.target === dlgAlbum) dlgAlbum.close(); });
    document.addEventListener('keydown', function(e) {
        if (!dlgAlbum.open) return;
        if (e.key === 'ArrowLeft')  albumRender(albumIdx - 1);
        if (e.key === 'ArrowRight') albumRender(albumIdx + 1);
    });

    // ── VIDEO UPLOAD ──
    document.querySelectorAll('.btn-lihat-video').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.getElementById('dlg-video-title').textContent = this.dataset.title;
            document.getElementById('dlg-video-desc').textContent  = this.dataset.desc;
            vid.src = this.dataset.url; vid.load();
            dlgVideo.showModal();
            vid.play().catch(function(){});
        });
    });
    document.getElementById('dlg-video-close').addEventListener('click', function() { vid.pause(); vid.src = ''; dlgVideo.close(); });
    dlgVideo.addEventListener('click', function(e) { if (e.target === dlgVideo) { vid.pause(); vid.src = ''; dlgVideo.close(); } });
    dlgVideo.addEventListener('close', function() { vid.pause(); vid.src = ''; });

    // ── YOUTUBE POPUP ──
    var ytPopup      = document.getElementById('yt-popup');
    var ytPopupFrame = document.getElementById('yt-popup-frame');

    function openYtPopup(vid, title, desc) {
        var embedUrl = 'https://www.youtube.com/embed/' + vid + '?rel=0&modestbranding=1';
        var watchUrl = 'https://www.youtube.com/watch?v=' + vid;
        document.getElementById('yt-popup-title').textContent = title || '';
        document.getElementById('yt-popup-watchlink').href    = watchUrl;
        var descEl = document.getElementById('yt-popup-desc');
        descEl.textContent     = desc || '';
        descEl.style.display   = desc ? 'block' : 'none';
        descEl.style.marginBottom = desc ? '10px' : '0';
        ytPopupFrame.src = embedUrl;
        ytPopup.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeYtPopup() {
        ytPopupFrame.src = '';
        ytPopup.style.display = 'none';
        document.body.style.overflow = '';
    }

    document.querySelectorAll('.yt-thumb-wrap').forEach(function(el) {
        el.addEventListener('click', function() {
            openYtPopup(this.dataset.vid, this.dataset.title, this.dataset.desc);
        });
    });

    document.getElementById('yt-popup-close').addEventListener('click', closeYtPopup);
    ytPopup.addEventListener('click', function(e) {
        if (e.target === ytPopup) closeYtPopup();
    });
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && ytPopup.style.display === 'flex') closeYtPopup();
    });
});
</script>

