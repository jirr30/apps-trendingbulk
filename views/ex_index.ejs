<%- include('partials/header') %>
<style>
    /* Sembunyikan navbar bawaan header.ejs hanya di halaman dashboard */
    nav.sticky, header nav { display: none !important; }
    body { padding-top: 0 !important; background-color: #020617; }
</style>

<div class="min-h-screen bg-slate-950 text-slate-200">
    <header class="bg-slate-900 border-b border-slate-800 sticky top-0 z-[100]">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="flex items-center gap-4">
                <a href="/dashboard" class="flex items-center group">
                    <h1 class="text-white font-black tracking-tighter text-xl">
                        TRENDING<span class="text-blue-500">BULK</span>
                        <span class="ml-2 text-[10px] bg-slate-800 text-slate-400 px-2 py-1 rounded font-mono uppercase tracking-widest group-hover:bg-slate-700 transition">Admin</span>
                    </h1>
                </a>
            </div>
            
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2">
                    <a href="/upload" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-[11px] font-bold transition flex items-center gap-2 uppercase tracking-wider">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                        + Template
                    </a>
                    <a href="/admin/article/add" class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-lg text-[11px] font-bold transition flex items-center gap-2 uppercase tracking-wider">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                        + Artikel
                    </a>
                </div>
                <div class="h-6 w-[1px] bg-slate-700 mx-2"></div>
                <a href="/logout" class="flex items-center gap-2 text-slate-400 hover:text-red-500 transition font-bold text-[11px] uppercase tracking-[0.2em]">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                    Logout
                </a>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto p-6 space-y-12">
        <section>
            <div class="flex items-center gap-3 mb-8">
                <div class="h-1 w-12 bg-blue-600 rounded-full"></div>
                <h2 class="text-xs font-black text-slate-500 uppercase tracking-[0.4em]">Manage Templates</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <% if (templates && templates.length > 0) { %>
                    <% templates.forEach(item => { %>
                        <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden group hover:border-blue-500/50 transition">
                            <div class="relative h-44">
                                <img src="<%= item.imageUrl %>" class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition duration-500">
                                <div class="absolute top-2 right-2 flex gap-2">
                                    <a href="/admin/template/edit/<%= item._id %>" class="bg-blue-600/20 hover:bg-blue-600 text-blue-400 hover:text-white p-2 rounded-lg backdrop-blur-md transition border border-blue-500/20 shadow-lg">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </a>
                                    <form action="/delete/<%= item._id %>" method="POST" onsubmit="return confirm('Hapus template ini?')">
                                        <button class="bg-red-600/20 hover:bg-red-600 text-red-500 hover:text-white p-2 rounded-lg backdrop-blur-md transition border border-red-500/20 shadow-lg">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <div class="p-4">
                                <h3 class="text-white font-bold text-sm truncate"><%= item.title %></h3>
                                <p class="text-slate-500 text-[11px] line-clamp-2 mt-1 leading-relaxed"><%= item.description %></p>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full py-12 text-center border-2 border-dashed border-slate-800 rounded-3xl text-slate-600 font-mono text-xs uppercase tracking-widest">NO_DATA_AVAILABLE</div>
                <% } %>
            </div>
        </section>

        <section>
            <div class="flex items-center gap-3 mb-8">
                <div class="h-1 w-12 bg-emerald-600 rounded-full"></div>
                <h2 class="text-xs font-black text-slate-500 uppercase tracking-[0.4em]">Manage Articles</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% if (articles && articles.length > 0) { %>
                    <% articles.forEach(article => { %>
                        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 hover:border-emerald-500/50 transition flex flex-col group">
                            <div class="flex justify-between items-start mb-4">
                                <span class="text-[9px] font-mono text-emerald-500 bg-emerald-500/10 px-2 py-1 rounded border border-emerald-500/20 uppercase tracking-widest">Document</span>
                                <div class="flex items-center gap-3">
                                    <a href="/admin/article/edit/<%= article._id %>" class="text-slate-500 hover:text-blue-500 transition p-1">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </a>
                                    <form action="/admin/article/delete/<%= article._id %>" method="POST" onsubmit="return confirm('Hapus artikel ini?')">
                                        <button class="text-slate-500 hover:text-red-500 transition p-1">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <h3 class="text-white font-bold text-base mb-3 group-hover:text-emerald-400 transition leading-tight"><%= article.title %></h3>
                            <div class="text-slate-500 text-xs line-clamp-2 font-light opacity-80 leading-relaxed mb-6">
                                <%= article.content.replace(/<[^>]*>?/gm, '') %>
                            </div>
                            <div class="mt-auto pt-4 border-t border-slate-800/50 flex justify-between items-center text-[10px] text-slate-600 font-mono">
                                <span><%= article.createdAt.toDateString() %></span>
                                <span class="opacity-50">ID: <%= article._id.toString().substring(18) %></span>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full py-12 text-center border-2 border-dashed border-slate-800 rounded-3xl text-slate-600 font-mono text-xs uppercase tracking-widest">NO_ARTICLE_AVAILABLE</div>
                <% } %>
            </div>
        </section>
    </main>
</div>
<%- include('partials/footer') %>
