<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><% if (notLoggedIn) { %>Masuk<% } else if (notFound) { %>Tagihan Tidak Ditemukan<% } else { %>Tagihan <%= trx.invoiceNumber || ('#' + trx.orderId) %><% } %> | <%= siteSetting.siteTitle || 'TrendingBulk' %></title>
    <meta name="robots" content="noindex, nofollow">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .pulse-dot { animation: pulse 2s cubic-bezier(0.4,0,0.6,1) infinite; }
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
        .fade-in { animation: fadeIn .35s ease both; }
        @keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:none} }
    </style>
</head>
<body class="bg-slate-950 min-h-screen">

<% if (notLoggedIn) { %>
<!-- LOGIN REQUIRED -->
<div class="min-h-screen flex items-center justify-center p-4">
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8 w-full max-w-sm shadow-2xl fade-in">
        <!-- Logo -->
        <% const _logo = siteSetting && siteSetting.logoUrl; const _name = (siteSetting && siteSetting.siteTitle) || 'TrendingBulk'; %>
        <div class="flex items-center justify-center gap-2 mb-6">
            <% if (_logo) { %>
            <img src="<%= _logo %>" alt="Logo" class="h-7 w-auto object-contain">
            <% } else { %>
            <div class="w-7 h-7 rounded-lg bg-blue-600 flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <% } %>
            <span class="text-white font-bold text-sm"><%= _name %></span>
        </div>

        <h2 class="text-xl font-black text-white text-center mb-1">Masuk untuk Melanjutkan</h2>
        <p class="text-slate-500 text-xs text-center mb-6">Halaman ini memerlukan autentikasi.</p>

        <% if (loginError) { %>
        <div class="mb-4 flex items-center gap-2 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl">
            <svg class="w-4 h-4 text-red-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-red-400 text-xs"><%= loginError %></p>
        </div>
        <% } %>

        <form action="/login" method="POST" class="space-y-4">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="redirect_to" value="<%= redirectTo %>">
            <div>
                <label class="block text-[11px] text-slate-500 uppercase tracking-wider mb-1.5">Username / Email</label>
                <input type="text" name="identifier" required autocomplete="username"
                    class="w-full bg-slate-800 border border-slate-700 focus:border-blue-500 text-white text-sm rounded-xl px-4 py-3 outline-none transition placeholder-slate-600"
                    placeholder="Masukkan username atau email">
            </div>
            <div>
                <label class="block text-[11px] text-slate-500 uppercase tracking-wider mb-1.5">Password</label>
                <input type="password" name="password" required autocomplete="current-password"
                    class="w-full bg-slate-800 border border-slate-700 focus:border-blue-500 text-white text-sm rounded-xl px-4 py-3 outline-none transition placeholder-slate-600"
                    placeholder="Masukkan password">
            </div>
            <button type="submit"
                class="w-full flex items-center justify-center gap-2 px-6 py-3.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-xl transition mt-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
                Masuk
            </button>
        </form>

        <p class="text-[11px] text-slate-700 text-center mt-6">
            Halaman tagihan pembayaran aman
        </p>
    </div>
</div>

<% } else if (notFound) { %>
<!-- NOT FOUND -->
<div class="min-h-screen flex items-center justify-center p-4">
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-10 text-center max-w-md w-full shadow-2xl fade-in">
        <div class="w-20 h-20 bg-red-500/10 border-2 border-red-500/20 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
        </div>
        <h2 class="text-2xl font-black text-white mb-2">Tagihan Tidak Ditemukan</h2>
        <p class="text-slate-400 text-sm mb-6">Tagihan tidak ditemukan atau mungkin sudah kedaluwarsa.</p>
        <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-xl transition">
            Kembali ke Beranda
        </a>
    </div>
</div>

<% } else { %>
<!-- TAGIHAN PAGE -->
<%
const sc = {
    success: { bg: 'bg-emerald-500/10', border: 'border-emerald-500/30', text: 'text-emerald-400', dot: false, label: 'Lunas' },
    pending: { bg: 'bg-amber-500/10',   border: 'border-amber-500/30',   text: 'text-amber-400',   dot: true,  label: 'Menunggu Pembayaran' },
    failed:  { bg: 'bg-red-500/10',     border: 'border-red-500/30',     text: 'text-red-400',     dot: false, label: 'Gagal' },
    refund:  { bg: 'bg-orange-500/10',  border: 'border-orange-500/30',  text: 'text-orange-400',  dot: false, label: 'Refund' },
    expired: { bg: 'bg-slate-700/40',   border: 'border-slate-600/30',   text: 'text-slate-400',   dot: false, label: 'Kedaluwarsa' }
};
const s = sc[trx.status] || sc.expired;

const companyName = siteSetting.siteTitle || 'TrendingBulk';
const companyLogo = siteSetting.logoUrl   || null;

const now = new Date();
const isOverdue = trx.dueDate && new Date(trx.dueDate) < now && trx.status === 'pending';

function fmtDate(d) {
    return new Date(d).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' });
}
function fmtRp(n) {
    return 'Rp ' + Number(n).toLocaleString('id-ID');
}
%>

<!-- Header -->
<header class="border-b border-slate-800 bg-slate-900/80 backdrop-blur sticky top-0 z-10">
    <div class="max-w-2xl mx-auto px-4 py-3.5 flex items-center justify-between">
        <div class="flex items-center gap-2.5">
            <% if (companyLogo) { %>
            <img src="<%= companyLogo %>" alt="Logo" class="h-7 w-auto object-contain">
            <% } else { %>
            <div class="w-7 h-7 rounded-lg bg-blue-600 flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
            </div>
            <% } %>
            <span class="text-white font-bold text-sm"><%= companyName %></span>
        </div>
        <span class="text-[10px] font-mono text-slate-500 uppercase tracking-wider hidden sm:block">Tagihan Pembayaran</span>
    </div>
</header>

<main class="max-w-2xl mx-auto px-4 py-8 pb-20 fade-in">

    <!-- Status Banner (success / overdue) -->
    <% if (trx.status === 'success') { %>
    <div class="mb-5 flex items-center gap-3 px-5 py-4 bg-emerald-500/10 border border-emerald-500/20 rounded-2xl">
        <svg class="w-5 h-5 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
            <p class="text-emerald-400 text-sm font-bold">Pembayaran Berhasil</p>
            <p class="text-emerald-500/70 text-xs">Terima kasih, pembayaran Anda telah diterima.</p>
        </div>
    </div>
    <% } else if (isOverdue) { %>
    <div class="mb-5 flex items-center gap-3 px-5 py-4 bg-red-500/10 border border-red-500/20 rounded-2xl">
        <svg class="w-5 h-5 text-red-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
            <p class="text-red-400 text-sm font-bold">Tagihan Jatuh Tempo</p>
            <p class="text-red-500/70 text-xs">Tagihan ini sudah melewati tanggal jatuh tempo. Segera selesaikan pembayaran.</p>
        </div>
    </div>
    <% } %>

    <!-- Kartu Utama -->
    <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-2xl mb-5">

        <!-- Top bar: invoice number + status -->
        <div class="bg-gradient-to-r from-blue-900/40 to-slate-900 px-6 py-5 border-b border-slate-800">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-0.5">
                        <% if (trx.invoiceNumber) { %>Nomor Invoice<% } else { %>Order ID<% } %>
                    </p>
                    <code class="text-base font-black text-blue-400">
                        <%= trx.invoiceNumber || trx.orderId %>
                    </code>
                    <% if (trx.invoiceNumber && trx.orderId !== trx.invoiceNumber) { %>
                    <p class="text-[10px] text-slate-600 font-mono mt-0.5">ref: <%= trx.orderId %></p>
                    <% } %>
                </div>
                <span class="flex items-center gap-1.5 px-3 py-1.5 text-[11px] font-bold uppercase tracking-wide border rounded-xl shrink-0 <%= s.bg %> <%= s.border %> <%= s.text %>">
                    <% if (s.dot) { %><span class="w-1.5 h-1.5 rounded-full bg-amber-400 pulse-dot"></span><% } %>
                    <%= s.label %>
                </span>
            </div>
        </div>

        <!-- Nominal -->
        <div class="px-6 py-6 border-b border-slate-800">
            <p class="text-[10px] font-mono text-slate-500 uppercase tracking-wider mb-1">Total Tagihan</p>
            <p class="text-4xl font-black text-white"><%= fmtRp(trx.amount) %></p>
            <% if (trx.description && (!trx.items || !trx.items.length)) { %>
            <p class="text-sm text-slate-400 mt-2"><%= trx.description %></p>
            <% } %>
        </div>

        <!-- Rincian Item (jika ada) -->
        <% if (trx.items && trx.items.length > 0) { %>
        <div class="border-b border-slate-800">
            <div class="px-6 py-3 bg-slate-800/40">
                <p class="text-[10px] font-mono text-slate-500 uppercase tracking-wider">Rincian Item</p>
            </div>
            <div class="divide-y divide-slate-800/60">
                <% trx.items.forEach(function(item) { %>
                <div class="px-6 py-3 flex items-center justify-between gap-4">
                    <div class="flex-1 min-w-0">
                        <p class="text-sm text-white font-medium truncate"><%= item.description %></p>
                        <p class="text-xs text-slate-500 mt-0.5">
                            <%= item.qty %> × <%= fmtRp(item.unitPrice) %>
                        </p>
                    </div>
                    <p class="text-sm font-bold text-slate-300 shrink-0"><%= fmtRp(item.subtotal) %></p>
                </div>
                <% }) %>
                <div class="px-6 py-3 flex items-center justify-between bg-slate-800/30">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-wide">Total</p>
                    <p class="text-base font-black text-white"><%= fmtRp(trx.amount) %></p>
                </div>
            </div>
        </div>
        <% } %>

        <!-- Detail Rows -->
        <div class="divide-y divide-slate-800/60">
            <div class="px-6 py-3.5 flex justify-between items-center">
                <span class="text-xs text-slate-500">Tagihan Kepada</span>
                <span class="text-sm text-white font-medium"><%= trx.customerName %></span>
            </div>
            <% if (trx.customerEmail) { %>
            <div class="px-6 py-3.5 flex justify-between items-center">
                <span class="text-xs text-slate-500">Email</span>
                <span class="text-xs text-slate-300 truncate max-w-[200px]"><%= trx.customerEmail %></span>
            </div>
            <% } %>
            <% if (trx.customerPhone) { %>
            <div class="px-6 py-3.5 flex justify-between items-center">
                <span class="text-xs text-slate-500">Telepon</span>
                <span class="text-xs text-slate-300"><%= trx.customerPhone %></span>
            </div>
            <% } %>
            <div class="px-6 py-3.5 flex justify-between items-center">
                <span class="text-xs text-slate-500">Tanggal Tagihan</span>
                <span class="text-xs text-slate-300 font-mono"><%= fmtDate(trx.createdAt) %></span>
            </div>
            <% if (trx.dueDate) { %>
            <div class="px-6 py-3.5 flex justify-between items-center">
                <span class="text-xs text-slate-500">Jatuh Tempo</span>
                <span class="text-xs font-mono font-bold <%= isOverdue ? 'text-red-400' : 'text-amber-400' %>">
                    <%= fmtDate(trx.dueDate) %>
                    <% if (isOverdue) { %> &bull; Lewat Jatuh Tempo<% } %>
                </span>
            </div>
            <% } %>
            <% if (trx.paidAt) { %>
            <div class="px-6 py-3.5 flex justify-between items-center">
                <span class="text-xs text-slate-500">Dibayar Pada</span>
                <span class="text-xs text-emerald-400 font-mono"><%= new Date(trx.paidAt).toLocaleString('id-ID') %></span>
            </div>
            <% } %>
            <% if (trx.midtransPaymentType) { %>
            <div class="px-6 py-3.5 flex justify-between items-center">
                <span class="text-xs text-slate-500">Metode Bayar</span>
                <span class="text-xs text-slate-300 capitalize">
                    <%= trx.midtransPaymentType.replace(/_/g, ' ') %>
                    <% if (trx.bank) { %>&bull; <%= trx.bank.toUpperCase() %><% } %>
                </span>
            </div>
            <% } %>
            <% if (trx.midtransVaNumber) { %>
            <div class="px-6 py-3.5 flex justify-between items-center">
                <span class="text-xs text-slate-500">No. Virtual Account</span>
                <code class="text-sm text-white font-bold"><%= trx.midtransVaNumber %></code>
            </div>
            <% } %>
        </div>
    </div>

    <!-- Action Area -->
    <% if (trx.status === 'pending' && trx.snapToken) { %>
    <div class="bg-slate-900 border border-blue-500/20 rounded-2xl p-6 text-center mb-5">
        <div class="w-12 h-12 bg-blue-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
            </svg>
        </div>
        <p class="text-white font-bold mb-1">Selesaikan Pembayaran</p>
        <p class="text-slate-400 text-xs mb-5 leading-relaxed">
            Tersedia pilihan pembayaran: Transfer Bank, Virtual Account, QRIS, GoPay, OVO, dan lainnya.
        </p>
        <button id="pay-btn"
            class="w-full flex items-center justify-center gap-3 px-6 py-4 bg-gradient-to-r from-blue-600 to-cyan-600 hover:from-blue-500 hover:to-cyan-500 text-white font-black text-base rounded-xl transition shadow-lg shadow-blue-900/40 active:scale-[0.98]">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
            </svg>
            Bayar Sekarang
        </button>
    </div>

    <% } else if (trx.status === 'pending' && trx.paymentUrl) { %>
    <div class="bg-slate-900 border border-blue-500/20 rounded-2xl p-6 text-center mb-5">
        <p class="text-white font-bold mb-1">Selesaikan Pembayaran</p>
        <p class="text-slate-400 text-xs mb-5">Klik tombol di bawah untuk melanjutkan ke halaman pembayaran.</p>
        <a href="<%= trx.paymentUrl %>" target="_blank"
            class="w-full flex items-center justify-center gap-3 px-6 py-4 bg-gradient-to-r from-blue-600 to-cyan-600 hover:from-blue-500 hover:to-cyan-500 text-white font-black text-base rounded-xl transition shadow-lg shadow-blue-900/40">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
            </svg>
            Bayar Sekarang
        </a>
    </div>

    <% } else if (trx.status === 'expired' || trx.status === 'failed') { %>
    <div class="bg-slate-900 border border-red-500/20 rounded-2xl p-6 text-center mb-5">
        <div class="w-12 h-12 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
        </div>
        <p class="text-red-400 font-bold mb-1">
            Tagihan <%= trx.status === 'expired' ? 'Kedaluwarsa' : 'Gagal' %>
        </p>
        <p class="text-slate-500 text-xs">Hubungi admin untuk mendapatkan tagihan baru.</p>
    </div>
    <% } %>

    <!-- Footer -->
    <p class="text-center text-[11px] text-slate-600 mt-4">
        Pembayaran aman &bull; <span class="text-slate-500"><%= companyName %></span>
    </p>

</main>

<% if (trx.status === 'pending' && trx.snapToken) { %>
<script src="https://app.<%= isProduction ? '' : 'sandbox.' %>midtrans.com/snap/snap.js" data-client-key="<%= clientKey %>"></script>
<script>
const payBtn = document.getElementById('pay-btn');
const snapToken = '<%= trx.snapToken %>';

payBtn.addEventListener('click', function() {
    this.disabled = true;
    this.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Memuat...';

    snap.pay(snapToken, {
        onSuccess: function() { location.reload(); },
        onPending: function() { location.reload(); },
        onError:   function(result) {
            console.error('Snap error:', result);
            resetBtn('Gagal memuat. Coba lagi.');
        },
        onClose:   function() { resetBtn(); }
    });
});

function resetBtn(label) {
    payBtn.disabled = false;
    payBtn.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg> ${label || 'Bayar Sekarang'}`;
}
</script>
<% } %>

<% } %>
</body>
</html>
