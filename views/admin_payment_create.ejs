<%- include('partials/admin_header') %>

<main class="min-h-screen bg-slate-950 pt-6 pb-24">
<div class="max-w-3xl mx-auto px-4 md:px-6">

    <div class="mb-8 flex items-center gap-4">
        <a href="/admin/payments" class="p-2 rounded-xl bg-slate-900 border border-slate-800 text-slate-400 hover:text-white transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <div>
            <p class="text-[10px] font-mono text-slate-600 uppercase tracking-[0.3em] mb-1">Midtrans Snap</p>
            <h1 class="text-2xl font-black text-white tracking-tight">Buat Payment Link</h1>
        </div>
    </div>

    <% if (error) { %>
    <div class="mb-6 flex items-center gap-3 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl">
        <svg class="w-4 h-4 text-red-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        <p class="text-red-400 text-xs font-bold"><%= error %></p>
    </div>
    <% } %>

    <!-- Info box -->
    <div class="mb-6 flex items-start gap-3 px-4 py-3 bg-blue-500/10 border border-blue-500/20 rounded-xl">
        <svg class="w-4 h-4 text-blue-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <p class="text-blue-300 text-xs">Payment link mendukung semua metode Midtrans: Transfer Bank, Virtual Account, QRIS, GoPay, OVO, ShopeePay, Kartu Kredit, dan lainnya.</p>
    </div>

    <form action="/admin/payments/create" method="POST" class="space-y-6">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <!-- Informasi Pembayaran -->
        <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-6">
            <h2 class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-5">Detail Pembayaran</h2>
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-slate-300 mb-1.5">Order ID <span class="text-red-400">*</span></label>
                    <div class="flex gap-2">
                        <input type="text" name="orderId" id="orderId" value="<%= transaction ? transaction.orderId || suggestedOrderId : suggestedOrderId %>"
                            class="flex-1 px-4 py-2.5 bg-slate-800 border border-slate-700 text-white text-sm rounded-xl focus:outline-none focus:border-blue-500 font-mono" required>
                        <button type="button" onclick="generateId()" class="px-4 py-2.5 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-300 text-xs font-bold rounded-xl transition whitespace-nowrap">
                            <svg class="w-3.5 h-3.5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>Generate
                        </button>
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-300 mb-1.5">Nominal <span class="text-red-400">*</span></label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 text-sm font-bold">Rp</span>
                        <input type="number" name="amount" id="amount" value="<%= transaction ? transaction.amount || '' : '' %>"
                            class="w-full pl-10 pr-4 py-2.5 bg-slate-800 border border-slate-700 text-white text-sm rounded-xl focus:outline-none focus:border-blue-500"
                            placeholder="100000" min="1000" required oninput="updatePreview()">
                    </div>
                    <p id="amountPreview" class="text-xs text-blue-400 font-mono mt-1.5"></p>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-300 mb-1.5">Keterangan</label>
                    <input type="text" name="description" value="<%= transaction ? transaction.description || '' : '' %>"
                        class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 text-white text-sm rounded-xl focus:outline-none focus:border-blue-500"
                        placeholder="Contoh: Iuran Anggota, Tiket Pertunjukan...">
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-300 mb-1.5">Catatan Internal</label>
                    <textarea name="notes" rows="2"
                        class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 text-white text-sm rounded-xl focus:outline-none focus:border-blue-500 resize-none"
                        placeholder="Catatan tambahan (tidak ditampilkan ke customer)"><%= transaction ? transaction.notes || '' : '' %></textarea>
                </div>
            </div>
        </div>

        <!-- Informasi Customer -->
        <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-6">
            <h2 class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-5">Informasi Customer</h2>
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-slate-300 mb-1.5">Nama <span class="text-red-400">*</span></label>
                    <input type="text" name="customerName" value="<%= transaction ? transaction.customerName || '' : '' %>"
                        class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 text-white text-sm rounded-xl focus:outline-none focus:border-blue-500"
                        placeholder="Nama lengkap" required>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-slate-300 mb-1.5">Email <span class="text-slate-600 font-normal">(opsional)</span></label>
                        <input type="email" name="customerEmail" value="<%= transaction ? transaction.customerEmail || '' : '' %>"
                            class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 text-white text-sm rounded-xl focus:outline-none focus:border-blue-500"
                            placeholder="email@example.com">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-300 mb-1.5">Nomor HP <span class="text-slate-600 font-normal">(opsional)</span></label>
                        <input type="text" name="customerPhone" value="<%= transaction ? transaction.customerPhone || '' : '' %>"
                            class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 text-white text-sm rounded-xl focus:outline-none focus:border-blue-500"
                            placeholder="08xxxxxxxxxx">
                    </div>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3 flex-wrap">
            <button type="submit" class="flex items-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white text-sm font-black rounded-xl transition shadow-lg shadow-blue-900/30">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                Generate Payment Link
            </button>
            <a href="/admin/payments" class="px-6 py-3 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-300 text-sm font-bold rounded-xl transition">Batal</a>
        </div>
    </form>

</div>
</main>

<script>
function generateId() {
    const ts = Date.now().toString().slice(-7);
    const rand = Math.random().toString(36).substring(2,5).toUpperCase();
    document.getElementById('orderId').value = `SAPHALTA-${ts}-${rand}`;
}
function updatePreview() {
    const val = parseFloat(document.getElementById('amount').value);
    const el = document.getElementById('amountPreview');
    el.textContent = val && !isNaN(val) ? `= Rp ${val.toLocaleString('id-ID')}` : '';
}
</script>

<%- include('partials/footer') %>
