<%- include('partials/admin_header', { pageTitle: 'Edit Jadwal Latihan' }) %>

<div class="max-w-2xl mx-auto px-4 md:px-6 py-8">

    <div class="mb-8 flex items-center gap-4">
        <a href="/admin/jadwal-latihan" class="p-2 rounded-xl text-slate-500 hover:text-white hover:bg-slate-800 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
        </a>
        <div>
            <h1 class="text-2xl font-black uppercase tracking-tighter text-white">Edit Jadwal Latihan</h1>
            <p class="text-slate-500 text-xs font-mono mt-1">Perbarui data jadwal latihan</p>
        </div>
    </div>

    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6">
        <form action="/admin/jadwal-latihan/update/<%= jadwal._id %>" method="POST" class="space-y-5">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-2">Hari <span class="text-red-500">*</span></label>
                    <select name="hari" required
                        class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-sm text-slate-200 focus:outline-none focus:border-blue-500/60 transition">
                        <% ['Senin','Selasa','Rabu','Kamis','Jumat','Sabtu','Minggu'].forEach(h => { %>
                        <option value="<%= h %>" <%= jadwal.hari === h ? 'selected' : '' %>><%= h %></option>
                        <% }) %>
                    </select>
                </div>
                <div>
                    <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-2">Pelatih <span class="text-red-500">*</span></label>
                    <input type="text" name="pelatih" required value="<%= jadwal.pelatih %>"
                        class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-sm text-slate-200 focus:outline-none focus:border-blue-500/60 transition">
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-2">Waktu Mulai <span class="text-red-500">*</span></label>
                    <input type="time" name="waktu_mulai" required value="<%= jadwal.waktu_mulai %>"
                        class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-sm text-slate-200 focus:outline-none focus:border-blue-500/60 transition">
                </div>
                <div>
                    <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-2">Waktu Selesai <span class="text-red-500">*</span></label>
                    <input type="time" name="waktu_selesai" required value="<%= jadwal.waktu_selesai %>"
                        class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-sm text-slate-200 focus:outline-none focus:border-blue-500/60 transition">
                </div>
            </div>

            <div>
                <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-2">Materi <span class="text-red-500">*</span></label>
                <input type="text" name="materi" required value="<%= jadwal.materi %>"
                    class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-sm text-slate-200 focus:outline-none focus:border-blue-500/60 transition">
            </div>

            <div>
                <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-2">Tempat <span class="text-red-500">*</span></label>
                <input type="text" name="tempat" required value="<%= jadwal.tempat %>"
                    class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-sm text-slate-200 focus:outline-none focus:border-blue-500/60 transition">
            </div>

            <div>
                <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-2">Keterangan</label>
                <textarea name="keterangan" rows="3"
                    class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-sm text-slate-200 focus:outline-none focus:border-blue-500/60 transition resize-none"><%= jadwal.keterangan || '' %></textarea>
            </div>

            <div class="flex gap-3 pt-2">
                <a href="/admin/jadwal-latihan"
                    class="flex-1 py-3 text-center bg-slate-800 hover:bg-slate-700 text-slate-400 text-xs font-bold uppercase tracking-widest rounded-xl transition">
                    Batal
                </a>
                <button type="submit"
                    class="flex-1 py-3 bg-blue-600 hover:bg-blue-700 text-white text-xs font-black uppercase tracking-widest rounded-xl transition shadow-lg shadow-blue-900/20">
                    Perbarui Jadwal
                </button>
            </div>
        </form>
    </div>
</div>

</body>
</html>
