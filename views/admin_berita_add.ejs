<%- include('partials/admin_header', { pageTitle: 'Tambah Berita' }) %>

<script src="https://cdn.ckeditor.com/ckeditor5/41.1.0/classic/ckeditor.js"></script>

<div class="min-h-screen bg-slate-950 py-10 px-4 md:px-6">
<div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="mb-8 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <div class="h-9 w-9 bg-blue-600 rounded-xl flex items-center justify-center shadow-lg shadow-blue-900/30">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
            </div>
            <div>
                <h1 class="text-xl font-black text-white uppercase tracking-tight">Tambah Berita</h1>
                <p class="text-slate-500 text-[10px] font-mono mt-0.5">Isi form berikut untuk publish berita baru</p>
            </div>
        </div>
        <a href="/admin/berita" class="flex items-center gap-2 text-slate-400 hover:text-white text-xs font-bold border border-slate-800 hover:border-slate-600 px-4 py-2 rounded-xl bg-slate-900/50 uppercase tracking-wider transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Kembali
        </a>
    </div>

    <form id="berita-form" action="/admin/berita/save" method="POST" enctype="multipart/form-data" class="space-y-6">

        <!-- Judul -->
        <div class="space-y-2">
            <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500">Judul Berita <span class="text-red-500">*</span></label>
            <input type="text" name="title" id="input-title" required placeholder="Masukkan judul berita..."
                class="w-full px-4 py-3 bg-slate-900 border border-slate-800 rounded-xl text-white text-sm placeholder-slate-600 outline-none focus:border-blue-500/60 focus:ring-1 focus:ring-blue-500/20 transition">
            <p id="title-count" class="text-[10px] font-mono text-slate-600 text-right">0 karakter</p>
        </div>

        <!-- Thumbnail -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-5">
            <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500 mb-3">Thumbnail / Cover</label>
            <div class="flex flex-col md:flex-row gap-5 items-start">
                <div id="thumb-preview-wrap" class="hidden shrink-0">
                    <div class="relative">
                        <span class="absolute -top-2 -left-2 bg-blue-600 text-[8px] font-black px-2 py-0.5 rounded uppercase z-10">Preview</span>
                        <img id="thumb-preview" class="h-28 w-44 object-cover rounded-xl border border-slate-700 shadow-xl">
                    </div>
                </div>
                <div class="flex-1 w-full">
                    <label id="thumb-drop" class="block w-full border-2 border-dashed border-slate-700 rounded-xl p-6 text-center cursor-pointer hover:border-blue-500/50 hover:bg-blue-500/5 transition group">
                        <input type="file" name="thumbnail" id="thumb-input" accept="image/jpeg,image/jpg,image/png,image/webp,image/gif" class="hidden">
                        <div id="thumb-label">
                            <svg class="w-8 h-8 text-slate-600 mx-auto mb-2 group-hover:text-blue-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            <p class="text-xs text-slate-500">Klik atau drag & drop gambar di sini</p>
                            <p class="text-[10px] text-slate-600 mt-1 font-mono">JPG, PNG, WEBP · Maks 5MB</p>
                        </div>
                    </label>
                </div>
            </div>
        </div>

        <!-- Konten -->
        <div class="space-y-2">
            <div class="flex items-center justify-between">
                <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500">Isi Berita <span class="text-red-500">*</span></label>
                <span id="word-count" class="text-[10px] font-mono text-slate-600">0 kata</span>
            </div>
            <div class="rounded-xl overflow-hidden border border-slate-700 shadow-xl">
                <textarea id="berita_editor"></textarea>
                <input type="hidden" id="content-hidden" name="content">
            </div>
            <p id="content-error" class="text-[10px] font-mono text-red-500 hidden">Isi berita tidak boleh kosong.</p>
        </div>

        <!-- SEO Panel -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
            <!-- Header toggle -->
            <button type="button" id="seo-toggle"
                class="w-full flex items-center justify-between px-5 py-4 text-left hover:bg-slate-800/50 transition">
                <div class="flex items-center gap-3">
                    <div class="h-7 w-7 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center">
                        <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-xs font-black text-white uppercase tracking-wider">SEO & Meta</p>
                        <p class="text-[10px] font-mono text-slate-500 mt-0.5">Optimasi mesin pencari</p>
                    </div>
                </div>
                <svg id="seo-chevron" class="w-4 h-4 text-slate-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>
            <!-- Body (collapsible) -->
            <div id="seo-body" class="hidden border-t border-slate-800 px-5 py-5 space-y-5">

                <!-- Slug -->
                <div class="space-y-1.5">
                    <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500">URL Slug</label>
                    <div class="flex items-center gap-0 bg-slate-800/60 border border-slate-700 rounded-xl overflow-hidden focus-within:border-blue-500/60 transition">
                        <span class="px-3 py-3 text-[10px] font-mono text-slate-500 bg-slate-800 border-r border-slate-700 whitespace-nowrap">/berita/</span>
                        <input type="text" name="slug" id="input-slug"
                            class="flex-1 px-3 py-3 bg-transparent text-slate-200 text-xs font-mono outline-none placeholder-slate-600"
                            placeholder="judul-berita-anda">
                    </div>
                    <p class="text-[10px] font-mono text-slate-600">Kosongkan untuk auto-generate dari judul.</p>
                </div>

                <!-- Meta Title -->
                <div class="space-y-1.5">
                    <div class="flex items-center justify-between">
                        <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500">Meta Title</label>
                        <span id="meta-title-count" class="text-[10px] font-mono text-slate-600">0 / 60</span>
                    </div>
                    <input type="text" name="metaTitle" id="input-meta-title" maxlength="100"
                        class="w-full px-4 py-3 bg-slate-800/60 border border-slate-700 rounded-xl text-slate-200 text-sm placeholder-slate-600 outline-none focus:border-blue-500/60 transition"
                        placeholder="Judul SEO (default: judul berita)">
                    <p id="meta-title-warn" class="text-[10px] font-mono text-amber-500 hidden">Lebih dari 60 karakter — mungkin terpotong di hasil pencarian.</p>
                </div>

                <!-- Meta Description -->
                <div class="space-y-1.5">
                    <div class="flex items-center justify-between">
                        <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500">Meta Description</label>
                        <span id="meta-desc-count" class="text-[10px] font-mono text-slate-600">0 / 160</span>
                    </div>
                    <textarea name="metaDescription" id="input-meta-desc" rows="3" maxlength="300"
                        class="w-full px-4 py-3 bg-slate-800/60 border border-slate-700 rounded-xl text-slate-200 text-sm placeholder-slate-600 outline-none focus:border-blue-500/60 transition resize-none"
                        placeholder="Deskripsi singkat untuk hasil pencarian (maks 160 karakter)..."></textarea>
                    <p id="meta-desc-warn" class="text-[10px] font-mono text-amber-500 hidden">Lebih dari 160 karakter — mungkin terpotong di hasil pencarian.</p>
                </div>

                <!-- Meta Keywords -->
                <div class="space-y-1.5">
                    <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500">Meta Keywords</label>
                    <input type="text" name="metaKeywords"
                        class="w-full px-4 py-3 bg-slate-800/60 border border-slate-700 rounded-xl text-slate-200 text-sm placeholder-slate-600 outline-none focus:border-blue-500/60 transition"
                        placeholder="teater, saphalta, berita, pementasan">
                    <p class="text-[10px] font-mono text-slate-600">Pisahkan dengan koma.</p>
                </div>

                <!-- Category & Tags -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="space-y-1.5">
                        <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500">Kategori</label>
                        <input type="text" name="category"
                            class="w-full px-4 py-3 bg-slate-800/60 border border-slate-700 rounded-xl text-slate-200 text-sm placeholder-slate-600 outline-none focus:border-blue-500/60 transition"
                            placeholder="Pementasan, Kegiatan, Pengumuman...">
                    </div>
                    <div class="space-y-1.5">
                        <label class="block text-[10px] font-mono uppercase tracking-widest text-slate-500">Tags</label>
                        <input type="text" name="tags"
                            class="w-full px-4 py-3 bg-slate-800/60 border border-slate-700 rounded-xl text-slate-200 text-sm placeholder-slate-600 outline-none focus:border-blue-500/60 transition"
                            placeholder="tag1, tag2, tag3">
                    </div>
                </div>

                <!-- Preview card -->
                <div class="bg-slate-800/40 border border-slate-700/50 rounded-xl p-4">
                    <p class="text-[10px] font-mono text-slate-500 uppercase tracking-widest mb-3">Preview Google</p>
                    <p id="seo-preview-url" class="text-[11px] font-mono text-emerald-500 mb-1">/berita/...</p>
                    <p id="seo-preview-title" class="text-sm font-semibold text-blue-400 leading-snug mb-1">—</p>
                    <p id="seo-preview-desc" class="text-xs text-slate-400 leading-relaxed line-clamp-2">—</p>
                </div>

            </div>
        </div>

        <!-- Actions -->
        <div class="flex gap-4 pt-2">
            <a href="/admin/berita"
               class="px-6 py-3.5 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-400 text-xs font-bold uppercase tracking-widest rounded-xl transition text-center">
                Batal
            </a>
            <button type="submit" id="btn-submit"
                class="flex-1 flex items-center justify-center gap-2 py-3.5 bg-blue-600 hover:bg-blue-700 text-white text-xs font-black uppercase tracking-widest rounded-xl transition shadow-lg shadow-blue-900/20">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Publish Berita
            </button>
        </div>
    </form>
</div>
</div>

<style>
    .ck.ck-editor__main .ck-editor__editable {
        min-height: 400px !important;
        background: #ffffff !important;
        color: #1e293b !important;
        font-family: 'Inter', sans-serif !important;
        font-size: 15px !important;
        line-height: 1.8 !important;
        padding: 2rem 2.5rem !important;
    }
    .ck.ck-toolbar { background: #f8fafc !important; border-bottom: 1px solid #e2e8f0 !important; padding: 6px 8px !important; }
    .ck.ck-editor { border-radius: 0 !important; border: none !important; }
    .ck.ck-editor__top .ck-sticky-panel .ck-toolbar { border-radius: 0 !important; }
    .ck.ck-editor__main .ck-editor__editable h1 { font-size: 2em !important; font-weight: 700 !important; line-height: 1.3 !important; margin: 0.5em 0 0.25em !important; }
    .ck.ck-editor__main .ck-editor__editable h2 { font-size: 1.6em !important; font-weight: 700 !important; line-height: 1.35 !important; margin: 0.5em 0 0.25em !important; }
    .ck.ck-editor__main .ck-editor__editable h3 { font-size: 1.3em !important; font-weight: 600 !important; line-height: 1.4 !important; margin: 0.5em 0 0.25em !important; }
    .ck.ck-editor__main .ck-editor__editable h4 { font-size: 1.1em !important; font-weight: 600 !important; line-height: 1.45 !important; margin: 0.5em 0 0.25em !important; }
</style>

<script>
let editorInstance = null;

ClassicEditor.create(document.querySelector('#berita_editor'), {
    removePlugins: ['Autoformat', 'TextTransformation'],
    simpleUpload: { uploadUrl: '/upload-image', withCredentials: true },
    heading: {
        options: [
            { model: 'paragraph', title: 'Paragraph', class: 'ck-heading_paragraph' },
            { model: 'heading1', view: 'h1', title: 'Heading 1', class: 'ck-heading_heading1' },
            { model: 'heading2', view: 'h2', title: 'Heading 2', class: 'ck-heading_heading2' },
            { model: 'heading3', view: 'h3', title: 'Heading 3', class: 'ck-heading_heading3' },
            { model: 'heading4', view: 'h4', title: 'Heading 4', class: 'ck-heading_heading4' },
        ]
    },
    toolbar: {
        items: ['heading', '|', 'bold', 'italic', 'underline', '|', 'link', 'bulletedList', 'numberedList', '|', 'uploadImage', 'blockQuote', '|', 'undo', 'redo'],
        shouldNotGroupWhenFull: true
    }
}).then(editor => {
    editorInstance = editor;
    window._ckEditor = editor;
    editor.model.document.on('change:data', () => {
        const text  = editor.getData().replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
        const words = text ? text.split(' ').length : 0;
        document.getElementById('word-count').textContent = words + ' kata';
    });
}).catch(err => {
    console.error(err);
    const el = document.querySelector('#berita_editor');
    el.style.cssText = 'display:block;min-height:300px;width:100%;padding:1rem;background:#fff;color:#1e293b;';
});

document.getElementById('input-title').addEventListener('input', function() {
    document.getElementById('title-count').textContent = this.value.length + ' karakter';
});

document.getElementById('thumb-input').addEventListener('change', function() {
    if (this.files && this.files[0]) {
        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById('thumb-preview').src = e.target.result;
            document.getElementById('thumb-preview-wrap').classList.remove('hidden');
            document.getElementById('thumb-label').innerHTML = '<p class="text-xs text-blue-400 font-mono">' + this.files[0].name + '</p>';
        };
        reader.readAsDataURL(this.files[0]);
    }
});

// SEO panel toggle
document.getElementById('seo-toggle').addEventListener('click', function() {
    const body = document.getElementById('seo-body');
    const chevron = document.getElementById('seo-chevron');
    body.classList.toggle('hidden');
    chevron.style.transform = body.classList.contains('hidden') ? '' : 'rotate(180deg)';
});

// Slug auto-gen from title
document.getElementById('input-title').addEventListener('input', function() {
    document.getElementById('title-count').textContent = this.value.length + ' karakter';
    const slugField = document.getElementById('input-slug');
    if (!slugField._manualEdit) {
        slugField.value = this.value.toLowerCase().replace(/[^a-z0-9\s-]/g,'').replace(/\s+/g,'-').replace(/-+/g,'-').trim();
        updateSeoPreview();
    }
});
document.getElementById('input-slug').addEventListener('input', function() {
    this._manualEdit = true;
    updateSeoPreview();
});

// Meta title counter + preview
document.getElementById('input-meta-title').addEventListener('input', function() {
    const len = this.value.length;
    document.getElementById('meta-title-count').textContent = len + ' / 60';
    document.getElementById('meta-title-count').className = 'text-[10px] font-mono ' + (len > 60 ? 'text-amber-400' : 'text-slate-600');
    document.getElementById('meta-title-warn').classList.toggle('hidden', len <= 60);
    updateSeoPreview();
});

// Meta desc counter + preview
document.getElementById('input-meta-desc').addEventListener('input', function() {
    const len = this.value.length;
    document.getElementById('meta-desc-count').textContent = len + ' / 160';
    document.getElementById('meta-desc-count').className = 'text-[10px] font-mono ' + (len > 160 ? 'text-amber-400' : 'text-slate-600');
    document.getElementById('meta-desc-warn').classList.toggle('hidden', len <= 160);
    updateSeoPreview();
});

function updateSeoPreview() {
    const title   = document.getElementById('input-meta-title').value || document.getElementById('input-title').value || '—';
    const desc    = document.getElementById('input-meta-desc').value || '—';
    const slug    = document.getElementById('input-slug').value || '...';
    document.getElementById('seo-preview-title').textContent = title.substring(0, 60) + (title.length > 60 ? '...' : '');
    document.getElementById('seo-preview-desc').textContent  = desc.substring(0, 160) + (desc.length > 160 ? '...' : '');
    document.getElementById('seo-preview-url').textContent   = window.location.origin + '/berita/' + slug;
}

document.getElementById('berita-form').addEventListener('submit', function(e) {
    const content = editorInstance ? editorInstance.getData() : '';
    if (!content.trim()) {
        e.preventDefault();
        document.getElementById('content-error').classList.remove('hidden');
        return;
    }
    document.getElementById('content-hidden').value = content;
    document.getElementById('content-error').classList.add('hidden');
    document.getElementById('btn-submit').innerHTML = '<svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Menyimpan...';
    document.getElementById('btn-submit').disabled = true;
});
</script>

<%- include('partials/footer') %>
