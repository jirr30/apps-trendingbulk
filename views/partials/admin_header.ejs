<script>
    (function() {
        const sidebar  = document.getElementById('admin-sidebar');
        const overlay  = document.getElementById('sidebar-overlay');
        const btnOpen  = document.getElementById('btn-toggle-sidebar');
        const btnClose = document.getElementById('btn-close-sidebar');

        function openSidebar() {
            sidebar.classList.remove('-translate-x-full');
            overlay.classList.remove('hidden');
            setTimeout(() => overlay.classList.replace('opacity-0', 'opacity-100'), 10);
        }

        function closeSidebar() {
            sidebar.classList.add('-translate-x-full');
            overlay.classList.replace('opacity-100', 'opacity-0');
            setTimeout(() => overlay.classList.add('hidden'), 300);
        }

        function toggleSidebar() {
            sidebar.classList.contains('-translate-x-full') ? openSidebar() : closeSidebar();
        }

        btnOpen.addEventListener('click', toggleSidebar);
        btnClose.addEventListener('click', closeSidebar);
        overlay.addEventListener('click', closeSidebar);
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeSidebar(); });

        // Fix: tap di luar CKEditor → blur editor + cegah duplikasi teks Android IME
        // Android IME men-"commit" composition saat editor blur → teks terduplikasi.
        // Solusi: simpan data sebelum blur, restore via CKEditor API jika terjadi perubahan.
        var ckSentinel = document.getElementById('ck-sentinel');
        function moveFocusFromCK(e) {
            if (e.target.closest('.ck')) return;
            var active = document.activeElement;
            if (!active || typeof active.getAttribute !== 'function') return;
            if (active.getAttribute('contenteditable') !== 'true') return;

            var ed = window._ckEditor;
            var dataBefore = ed ? ed.getData() : null;

            // Fokus sentinel agar browser handle transisi fokus secara natural
            ckSentinel.focus();

            // Setelah blur selesai (termasuk IME composition commit), cek & restore jika duplikasi
            if (dataBefore !== null && ed) {
                setTimeout(function() {
                    try {
                        if (ed.getData() !== dataBefore) {
                            ed.setData(dataBefore);
                        }
                    } catch(ex) {}
                }, 0);
            }
        }
        document.addEventListener('pointerdown', moveFocusFromCK, true);
        document.addEventListener('touchstart', moveFocusFromCK, { capture: true, passive: true });

        // Theme toggle (3 mode: default → dark → light)
        const themeToggle  = document.getElementById('theme-toggle');
        const iconThemeDef = document.getElementById('icon-theme-default');
        const iconSun      = document.getElementById('icon-sun');
        const iconMoon     = document.getElementById('icon-moon');
        const themes       = ['default', 'dark', 'light'];

        function applyTheme(theme) {
            document.documentElement.setAttribute('data-theme', theme);
            iconThemeDef.classList.toggle('hidden', theme !== 'default');
            iconMoon.classList.toggle('hidden', theme !== 'dark');
            iconSun.classList.toggle('hidden', theme !== 'light');
        }

        applyTheme(localStorage.getItem('theme') || 'default');

        themeToggle.addEventListener('click', () => {
            const current = localStorage.getItem('theme') || 'default';
            const next = themes[(themes.indexOf(current) + 1) % themes.length];
            localStorage.setItem('theme', next);
            applyTheme(next);
        });

        // Profile dropdown submenu
        const btnProfileDropdown = document.getElementById('btn-profile-dropdown');
        const profileSubmenu     = document.getElementById('profile-submenu');
        const profileChevron     = document.getElementById('icon-profile-chevron');

        btnProfileDropdown.addEventListener('click', () => {
            const isOpen = !profileSubmenu.classList.contains('hidden');
            profileSubmenu.classList.toggle('hidden', isOpen);
            profileChevron.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
        });

        // Blog dropdown submenu
        const btnBlogDropdown = document.getElementById('btn-blog-dropdown');
        const blogSubmenu     = document.getElementById('blog-submenu');
        const blogChevron     = document.getElementById('icon-blog-chevron');

        btnBlogDropdown.addEventListener('click', () => {
            const isOpen = !blogSubmenu.classList.contains('hidden');
            blogSubmenu.classList.toggle('hidden', isOpen);
            blogChevron.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
        });

        // Sekretariat dropdown submenu
        const btnSekretariatDropdown = document.getElementById('btn-sekretariat-dropdown');
        const sekretariatSubmenu     = document.getElementById('sekretariat-submenu');
        const sekretariatChevron     = document.getElementById('icon-sekretariat-chevron');

        btnSekretariatDropdown.addEventListener('click', () => {
            const isOpen = !sekretariatSubmenu.classList.contains('hidden');
            sekretariatSubmenu.classList.toggle('hidden', isOpen);
            sekretariatChevron.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
        });
    })();
</script>
