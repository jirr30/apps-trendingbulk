                        <h1 class="text-white font-black tracking-tighter text-xl uppercase italic leading-none">
                            TEATER <span class="<%= accentClasses.text %> group-hover:opacity-80 transition">SAPHALTA</span>
                        </h1>
                        <p class="text-[9px] text-slate-500 font-mono tracking-wide mt-0.5 leading-tight">Berkarya melalui seni pertunjukan</p>
                        <p class="text-[9px] font-mono tracking-wide leading-tight">
