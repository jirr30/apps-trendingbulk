        <div class="flex items-center justify-between gap-4">

            <!-- Kiri: Hamburger + Brand -->
            <div class="flex items-center gap-4">
                <button id="btn-toggle-sidebar" class="p-2 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition shrink-0" aria-label="Menu">
