                <button id="theme-toggle" class="p-2 rounded-lg hover:bg-slate-800 transition" aria-label="Toggle theme">
                    <svg id="icon-theme-default" class="w-4 h-4 text-orange-500" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2a10 10 0 100 20A10 10 0 0012 2zm0 2a8 8 0 110 16A8 8 0 0112 4z"/>
