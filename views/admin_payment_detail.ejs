<%- include('partials/admin_header') %>

<%
const statusCfg = {
    success: { cls: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20', label: 'Berhasil' },
    pending: { cls: 'bg-amber-500/10 text-amber-400 border-amber-500/20', label: 'Menunggu' },
    failed:  { cls: 'bg-red-500/10 text-red-400 border-red-500/20', label: 'Gagal' },
    refund:  { cls: 'bg-orange-500/10 text-orange-400 border-orange-500/20', label: 'Refund' },
    expired: { cls: 'bg-slate-700/50 text-slate-400 border-slate-600/30', label: 'Expired' }
};
const sc = statusCfg[trx.status] || statusCfg.expired;
const _isPaidSrc         = trx.source === 'payments-dashboard';
const _invoiceRef        = trx.invoiceNumber || trx.orderId;
const _portalInvoiceLink = trx.portalLink || null;
const _portalLoginLink   = portalUrl || null;
const _directPayLink     = (trx.paymentUrl && trx.status !== 'success') ? trx.paymentUrl : null;
const _waLink = _portalInvoiceLink || _portalLoginLink || '';
const _waMsg  = 'Halo ' + trx.customerName + ', tagihan Anda sudah tersedia.\nNo: ' + _invoiceRef + ' — Rp ' + trx.amount.toLocaleString('id-ID') + (trx.description ? '\n' + trx.description : '') + '\n\nLihat & bayar tagihan Anda di portal:\n' + _waLink;
const _hasItems = trx.items && trx.items.length > 0;
%>

<main class="min-h-screen bg-slate-950 pt-4 sm:pt-6 pb-24">
<div class="max-w-5xl mx-auto px-3 sm:px-4 md:px-6">

    <!-- HEADER -->
    <div class="mb-6 sm:mb-8">
        <!-- Baris atas: back + title -->
        <div class="flex items-start gap-3 mb-4">
            <a href="/admin/payments"
                class="mt-0.5 shrink-0 p-2 rounded-xl bg-slate-900 border border-slate-800 text-slate-400 hover:text-white transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
            </a>
            <div class="min-w-0 flex-1">
                <p class="text-[10px] font-mono text-slate-600 uppercase tracking-[0.3em] mb-1">Detail Transaksi</p>
                <h1 class="text-lg sm:text-xl font-black text-white tracking-tight font-mono break-all leading-tight">
                    <%= trx.orderId %>
                </h1>
                <% if (trx.invoiceNumber && trx.invoiceNumber !== trx.orderId) { %>
                <p class="text-[10px] font-mono text-slate-500 mt-0.5">Invoice: <%= trx.invoiceNumber %></p>
                <% } %>
            </div>
        </div>
        <!-- Baris bawah: badge + tombol aksi -->
        <div class="flex items-center gap-2 flex-wrap">
            <span class="px-3 py-1.5 text-[10px] font-bold uppercase tracking-wider border rounded-xl <%= sc.cls %>">
                <%= sc.label %>
            </span>
            <% if (_isPaidSrc) { %>
            <form action="/admin/payments/<%= trx._id %>/check-status" method="POST" style="display:inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit"
                    class="flex items-center gap-1.5 px-3 py-1.5 bg-slate-800 hover:bg-indigo-600/20 border border-slate-700 hover:border-indigo-500/30 text-slate-400 hover:text-indigo-400 text-xs font-bold rounded-xl transition">
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                    Cek Status
                </button>
            </form>
            <% } %>
            <a href="/tagihan/<%= trx.orderId %>/print" target="_blank"
                class="flex items-center gap-1.5 px-3 py-1.5 bg-slate-800 hover:bg-orange-600/20 border border-slate-700 hover:border-orange-500/30 text-slate-400 hover:text-orange-400 text-xs font-bold rounded-xl transition">
                <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
                </svg>
                Cetak PDF
            </a>
        </div>
    </div>

    <!-- FLASH -->
    <% if (success) { %>
    <div class="mb-5 flex items-start gap-3 px-4 py-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl">
        <svg class="w-4 h-4 text-emerald-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <p class="text-emerald-400 text-xs font-bold"><%= success %></p>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="mb-5 flex items-start gap-3 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl">
        <svg class="w-4 h-4 text-red-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
        <p class="text-red-400 text-xs font-bold"><%= error %></p>
    </div>
    <% } %>

    <!-- MAIN GRID: mobile=1col, tablet=2col, desktop=3col -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-5 sm:gap-6">

        <!-- KIRI: Detail utama (3/5 di tablet ke atas) -->
        <div class="md:col-span-3 space-y-5 sm:space-y-6">

            <!-- Amount card -->
            <div class="bg-gradient-to-br from-blue-900/40 to-slate-900/60 border border-blue-500/20 rounded-2xl p-5 sm:p-6">
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <p class="text-[10px] font-mono text-blue-400/60 uppercase tracking-wider mb-1">Total Pembayaran</p>
                        <p class="text-2xl sm:text-3xl lg:text-4xl font-black text-white leading-tight">
                            Rp <%= trx.amount.toLocaleString('id-ID') %>
                        </p>
                        <% if (trx.midtransPaymentType) { %>
                        <p class="text-xs text-slate-400 mt-1">
                            via <%= trx.midtransPaymentType %>
                            <% if (trx.bank) { %> — <%= trx.bank.toUpperCase() %><% } %>
                        </p>
                        <% } %>
                        <% if (trx.dueDate) { %>
                        <p class="text-xs mt-1.5 <%= (trx.status !== 'success' && new Date(trx.dueDate) < new Date()) ? 'text-red-400 font-semibold' : 'text-slate-500' %>">
                            Jatuh tempo: <%= new Date(trx.dueDate).toLocaleDateString('id-ID', { day:'numeric', month:'long', year:'numeric' }) %>
                            <% if (trx.status !== 'success' && new Date(trx.dueDate) < new Date()) { %>
                            <span class="ml-1 px-1.5 py-0.5 bg-red-500/15 border border-red-500/30 rounded text-[10px] font-bold">Overdue</span>
                            <% } %>
                        </p>
                        <% } %>
                    </div>
                    <span class="shrink-0 px-2.5 py-1.5 text-[10px] font-bold uppercase tracking-wider border rounded-xl <%= sc.cls %>">
                        <%= sc.label %>
                    </span>
                </div>
            </div>

            <!-- Detail rows -->
            <div class="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden">
                <div class="px-5 sm:px-6 py-4 border-b border-slate-800">
                    <h3 class="text-[10px] font-mono text-slate-500 uppercase tracking-wider">Detail Transaksi</h3>
                </div>
                <div class="divide-y divide-slate-800/50">

                    <!-- Order ID -->
                    <div class="px-5 sm:px-6 py-3.5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 sm:gap-4">
                        <span class="text-xs text-slate-500 shrink-0">Order ID</span>
                        <code class="text-xs text-blue-400 bg-blue-500/10 px-2 py-0.5 rounded-lg break-all sm:text-right">
                            <%= trx.orderId %>
                        </code>
                    </div>

                    <% if (trx.invoiceNumber && trx.invoiceNumber !== trx.orderId) { %>
                    <div class="px-5 sm:px-6 py-3.5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 sm:gap-4">
                        <span class="text-xs text-slate-500 shrink-0">No. Invoice</span>
                        <code class="text-xs text-indigo-400 bg-indigo-500/10 px-2 py-0.5 rounded-lg break-all sm:text-right">
                            <%= trx.invoiceNumber %>
                        </code>
                    </div>
                    <% } %>

                    <div class="px-5 sm:px-6 py-3.5 flex items-center justify-between gap-4">
                        <span class="text-xs text-slate-500 shrink-0">Sumber</span>
                        <span class="text-xs px-2 py-0.5 rounded-lg shrink-0 <%= _isPaidSrc ? 'bg-indigo-500/10 text-indigo-400' : 'bg-slate-800 text-slate-400' %>">
                            <%= _isPaidSrc ? 'Payments Dashboard' : 'Apps' %>
                        </span>
                    </div>

                    <% if (trx.description) { %>
                    <div class="px-5 sm:px-6 py-3.5 flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1 sm:gap-4">
                        <span class="text-xs text-slate-500 shrink-0">Keterangan</span>
                        <span class="text-xs text-white sm:text-right"><%= trx.description %></span>
                    </div>
                    <% } %>

                    <div class="px-5 sm:px-6 py-3.5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 sm:gap-4">
                        <span class="text-xs text-slate-500 shrink-0">Dibuat</span>
                        <span class="text-xs text-slate-300 font-mono">
                            <%= new Date(trx.createdAt).toLocaleString('id-ID') %>
                        </span>
                    </div>

                    <% if (trx.paidAt) { %>
                    <div class="px-5 sm:px-6 py-3.5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 sm:gap-4">
                        <span class="text-xs text-slate-500 shrink-0">Dibayar</span>
                        <span class="text-xs text-emerald-400 font-mono">
                            <%= new Date(trx.paidAt).toLocaleString('id-ID') %>
                        </span>
                    </div>
                    <% } %>

                    <% if (trx.midtransVaNumber) { %>
                    <div class="px-5 sm:px-6 py-3.5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 sm:gap-4">
                        <span class="text-xs text-slate-500 shrink-0">No. Virtual Account</span>
                        <code class="text-xs text-white break-all"><%= trx.midtransVaNumber %></code>
                    </div>
                    <% } %>

                    <% if (trx.notes) { %>
                    <div class="px-5 sm:px-6 py-3.5 flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1 sm:gap-4">
                        <span class="text-xs text-slate-500 shrink-0">Catatan</span>
                        <span class="text-xs text-slate-400 sm:text-right"><%= trx.notes %></span>
                    </div>
                    <% } %>

                </div>
            </div>

            <!-- Items table (jika ada) -->
            <% if (_hasItems) { %>
            <div class="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden">
                <div class="px-5 sm:px-6 py-4 border-b border-slate-800">
                    <h3 class="text-[10px] font-mono text-slate-500 uppercase tracking-wider">Item Tagihan</h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full min-w-[420px]">
                        <thead>
                            <tr class="border-b border-slate-800 bg-slate-900/40">
                                <th class="px-5 sm:px-6 py-3 text-left text-[10px] font-mono text-slate-600 uppercase tracking-wider">Deskripsi</th>
                                <th class="px-3 py-3 text-right text-[10px] font-mono text-slate-600 uppercase tracking-wider w-12">Qty</th>
                                <th class="px-3 py-3 text-right text-[10px] font-mono text-slate-600 uppercase tracking-wider whitespace-nowrap">Harga Satuan</th>
                                <th class="px-5 sm:px-6 py-3 text-right text-[10px] font-mono text-slate-600 uppercase tracking-wider whitespace-nowrap">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-800/50">
                            <% trx.items.forEach(function(item) { %>
                            <tr class="hover:bg-slate-800/20 transition">
                                <td class="px-5 sm:px-6 py-3 text-xs text-white"><%= item.description || '-' %></td>
                                <td class="px-3 py-3 text-xs text-slate-300 text-right"><%= item.qty || 1 %></td>
                                <td class="px-3 py-3 text-xs text-slate-300 text-right whitespace-nowrap">Rp <%= (item.unitPrice || 0).toLocaleString('id-ID') %></td>
                                <td class="px-5 sm:px-6 py-3 text-xs text-white font-bold text-right whitespace-nowrap">Rp <%= (item.subtotal || 0).toLocaleString('id-ID') %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                        <tfoot class="border-t-2 border-slate-700 bg-slate-900/40">
                            <tr>
                                <td colspan="3" class="px-5 sm:px-6 py-3.5 text-xs text-slate-400 text-right font-bold">Total</td>
                                <td class="px-5 sm:px-6 py-3.5 text-sm text-white font-black text-right whitespace-nowrap">
                                    Rp <%= trx.amount.toLocaleString('id-ID') %>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <% } %>

        </div>

        <!-- KANAN: Side panel (2/5 di tablet ke atas) -->
        <div class="md:col-span-2 space-y-5 sm:space-y-6">

            <!-- Aksi & Link -->
            <div class="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden">
                <div class="px-5 py-4 border-b border-slate-800">
                    <h3 class="text-[10px] font-mono text-slate-500 uppercase tracking-wider">Aksi & Link</h3>
                </div>
                <div class="p-4 sm:p-5 space-y-3">

                    <% if (trx.status === 'success') { %>
                    <!-- Sudah lunas -->
                    <div class="text-center py-5">
                        <div class="w-14 h-14 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mx-auto mb-3">
                            <svg class="w-7 h-7 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                        </div>
                        <p class="text-emerald-400 text-sm font-bold">Lunas</p>
                        <p class="text-slate-500 text-xs mt-1">
                            <%= trx.paidAt ? new Date(trx.paidAt).toLocaleString('id-ID') : '-' %>
                        </p>
                    </div>
                    <% if (_portalInvoiceLink) { %>
                    <a href="<%= _portalInvoiceLink %>" target="_blank"
                        class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-indigo-600/15 hover:bg-indigo-600/25 border border-indigo-500/20 hover:border-indigo-500/40 text-indigo-400 text-xs font-bold rounded-xl transition">
                        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        Lihat Invoice di Portal
                    </a>
                    <% } %>
                    <% if (_waLink) { %>
                    <a href="https://wa.me/?text=<%= encodeURIComponent(_waMsg) %>" target="_blank"
                        class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-green-700/20 hover:bg-green-600/30 border border-green-600/20 hover:border-green-500/40 text-green-400 text-xs font-bold rounded-xl transition">
                        <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                        </svg>
                        Kirim via WhatsApp
                    </a>
                    <% } %>

                    <% } else { %>
                    <!-- Belum lunas -->

                    <% if (_portalInvoiceLink) { %>
                    <!-- Portal invoice link (utama) -->
                    <div class="bg-indigo-500/10 border border-indigo-500/20 rounded-xl p-3">
                        <p class="text-[10px] font-mono text-indigo-400/70 uppercase tracking-wider mb-1.5">Portal Invoice</p>
                        <p class="text-[10px] font-mono text-indigo-300 break-all leading-relaxed"><%= _portalInvoiceLink %></p>
                    </div>
                    <button onclick="copyLink('<%= _portalInvoiceLink %>', this)"
                        class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 active:bg-indigo-700 text-white text-xs font-bold rounded-xl transition">
                        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                        </svg>
                        Copy Link Portal Invoice
                    </button>
                    <a href="<%= _portalInvoiceLink %>" target="_blank"
                        class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-slate-800 hover:bg-slate-700 active:bg-slate-600 border border-slate-700 text-slate-300 text-xs font-bold rounded-xl transition">
                        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                        </svg>
                        Buka Portal Invoice
                    </a>


                    <% } else if (_portalLoginLink) { %>
                    <!-- Tidak ada portal invoice, arahkan ke portal login -->
                    <div class="bg-blue-500/10 border border-blue-500/20 rounded-xl p-3">
                        <p class="text-[10px] font-mono text-blue-400/70 uppercase tracking-wider mb-1">Portal Customer</p>
                        <p class="text-[10px] text-blue-300/70 mt-0.5">Customer dapat login dan membayar dari portal.</p>
                    </div>
                    <a href="<%= _portalLoginLink %>" target="_blank"
                        class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-blue-600 hover:bg-blue-500 active:bg-blue-700 text-white text-xs font-bold rounded-xl transition">
                        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                        </svg>
                        Buka Portal Customer
                    </a>

                    <% } else { %>
                    <div class="text-center py-6">
                        <svg class="w-8 h-8 text-slate-700 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                        </svg>
                        <p class="text-slate-600 text-xs">Tidak ada link tersedia</p>
                    </div>
                    <% } %>

                    <!-- WhatsApp -->
                    <% if (_waLink) { %>
                    <a href="https://wa.me/?text=<%= encodeURIComponent(_waMsg) %>" target="_blank"
                        class="w-full flex items-center justify-center gap-2 px-4 py-2.5 bg-green-700/20 hover:bg-green-600/30 active:bg-green-600/40 border border-green-600/20 hover:border-green-500/40 text-green-400 text-xs font-bold rounded-xl transition">
                        <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                        </svg>
                        Kirim via WhatsApp
                    </a>
                    <% } %>

                    <% } /* end else belum lunas */ %>
                </div>
            </div>

            <!-- Customer Info -->
            <div class="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden">
                <div class="px-5 py-4 border-b border-slate-800">
                    <h3 class="text-[10px] font-mono text-slate-500 uppercase tracking-wider">Customer</h3>
                </div>
                <div class="p-4 sm:p-5 space-y-3">
                    <div>
                        <p class="text-[10px] text-slate-600 mb-0.5">Nama</p>
                        <p class="text-sm text-white font-bold"><%= trx.customerName %></p>
                    </div>
                    <% if (trx.customerEmail) { %>
                    <div>
                        <p class="text-[10px] text-slate-600 mb-0.5">Email</p>
                        <p class="text-xs text-slate-300 break-all"><%= trx.customerEmail %></p>
                    </div>
                    <% } %>
                    <% if (trx.customerPhone) { %>
                    <div>
                        <p class="text-[10px] text-slate-600 mb-0.5">Telepon</p>
                        <p class="text-xs text-slate-300"><%= trx.customerPhone %></p>
                    </div>
                    <% } %>
                    <% if (_portalInvoiceLink || _portalLoginLink) { %>
                    <div class="pt-2 border-t border-slate-800 space-y-2">
                        <% if (_portalInvoiceLink) { %>
                        <a href="<%= _portalInvoiceLink %>" target="_blank"
