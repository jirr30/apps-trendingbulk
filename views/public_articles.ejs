<%- include('partials/header') %>


<div class="min-h-screen bg-slate-950 text-slate-200">
    <header class="py-16 px-6 border-b border-slate-900 bg-slate-900/50">
        <div class="max-w-6xl mx-auto text-center">
            <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight">
                Knowledge <span class="text-emerald-500">Base</span>
            </h1>
            <p class="text-slate-400 max-w-2xl mx-auto text-lg">
                Dokumentasi teknis, SOP, dan wawasan seputar infrastruktur jaringan dan pengembangan sistem.
            </p>
        </div>

	<div class="max-w-3xl mx-auto mb-10 px-4">
    		<form action="/articles" method="GET" class="relative group">
            <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
            	<svg class="w-5 h-5 text-slate-500 group-focus-within:text-emerald-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            	</svg>
            </div>
        	<input 
            	type="text" 
            	name="q" 
            	value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" 
            	placeholder="Cari dokumentasi teknis, konfigurasi, atau IP Address..." 
            	class="w-full bg-slate-900/50 border border-slate-800 text-slate-200 text-sm rounded-2xl focus:ring-2 focus:ring-emerald-500/50 focus:border-emerald-500 block pl-12 p-4 transition-all shadow-lg placeholder-slate-600"
            	autocomplete="off">
        	<% if (typeof searchQuery !== 'undefined' && searchQuery !== '') { %>
            	<a href="/articles" class="absolute inset-y-0 right-0 flex items-center pr-4 text-slate-500 hover:text-red-500 transition-colors">
                	<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    	<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                	</svg>
            	</a>
        	<% } %>
        
        	<% if (typeof searchQuery !== 'undefined' && searchQuery !== '') { %>
            <div class="absolute -bottom-6 left-2 text-[10px] font-mono text-emerald-500 tracking-widest uppercase">
          	Menemukan <%= articles.length %> hasil untuk "<%= searchQuery %>"
            </div>
        	<% } %>
    		</form>
	</div>
    </header>

    <main class="max-w-6xl mx-auto p-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% if (articles && articles.length > 0) { %>
                <% articles.forEach(article => { %>
                    <article class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-emerald-900/10 hover:border-emerald-500/50 transition duration-300 flex flex-col group">
                        <div class="relative h-48 overflow-hidden bg-slate-800">
                            <% if (article.thumbnail) { %>
                                <img src="<%= article.thumbnail %>" alt="<%= article.title %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-500">
                            <% } else { %>
                                <div class="flex items-center justify-center h-full text-slate-700">
                                    <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2z"></path></svg>
                                </div>
                            <% } %>
                            <div class="absolute top-4 left-4">
                                <span class="bg-emerald-600 text-[10px] text-white px-2 py-1 rounded-md uppercase font-bold tracking-widest shadow-lg">Documentation</span>
                            </div>
                        </div>

                        <div class="p-6 flex-grow flex flex-col">
                            <h2 class="text-xl font-bold text-white mb-3 group-hover:text-emerald-400 transition-colors line-clamp-2 italic">
                                <%= article.title %>
                            </h2>
                            <div class="text-slate-400 text-sm line-clamp-3 mb-6 opacity-80 leading-relaxed">
                                <%= article.content.replace(/<[^>]*>?/gm, '').substring(0, 120) %>...
                            </div>
                            
                            <div class="mt-auto flex justify-between items-center pt-4 border-t border-slate-800">
                                <span class="text-xs text-slate-500 font-mono">
                                    <%= article.createdAt.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                </span>
                                <a href="/article/<%= article._id %>" class="text-emerald-500 hover:text-emerald-400 font-bold text-sm flex items-center gap-1 group/link">
                                    Read More
                                    <svg class="w-4 h-4 group-hover/link:translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                                </a>
                            </div>
                        </div>
                    </article>
                <% }) %>
            <% } else { %>
                <div class="col-span-full py-20 text-center bg-slate-900 rounded-3xl border border-dashed border-slate-800">
                    <p class="text-slate-500 text-lg">Belum ada artikel yang dipublish.</p>
                </div>
            <% } %>
        </div>
    </main>
</div>

<%- include('partials/footer') %>
