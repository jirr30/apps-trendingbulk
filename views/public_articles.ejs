<%- include('partials/header') %>

<div class="min-h-screen bg-slate-950 text-slate-200">

    <!-- ── HERO ─────────────────────────────────────────────────── -->
    <section class="relative overflow-hidden border-b border-slate-800/60 min-h-[500px]">

        <% if (typeof heroPhotos !== 'undefined' && heroPhotos.length > 0) { %>
        <div id="hero-slideshow" class="absolute inset-0 z-0">
            <% heroPhotos.forEach(function(photo, i) { %>
            <div class="hero-slide absolute inset-0" style="opacity:<%= i === 0 ? 1 : 0 %>;transition:opacity 1.4s ease;">
                <img src="<%= photo.fileUrl %>" alt="<%= photo.title %>" loading="lazy" class="w-full h-full object-cover block">
            </div>
            <% }) %>
            <div class="absolute inset-0 z-[1]" style="background:linear-gradient(to bottom,rgba(2,8,23,0.55) 0%,rgba(2,8,23,0.8) 60%,rgba(2,8,23,1) 100%);"></div>
        </div>
        <% } else { %>
        <div class="absolute inset-0 z-0" style="background:linear-gradient(135deg,#0f172a 0%,#020817 50%,#0f172a 100%);"></div>
        <% } %>

        <div class="max-w-4xl mx-auto relative px-5 py-16 sm:py-20 md:py-28 text-center z-[2]">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-emerald-500/30 bg-emerald-500/10 mb-5">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                <span class="text-[10px] font-mono text-emerald-400 uppercase tracking-widest">Konten & Materi</span>
            </div>
            <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-white mb-4 leading-tight tracking-tight">
                Kisah di Balik <span class="text-emerald-400">Panggung</span>
            </h1>
            <p class="text-slate-400 text-sm sm:text-base md:text-lg max-w-xl mx-auto leading-relaxed px-2">
                Cerita, ulasan, dan catatan perjalanan dari setiap pementasan theater yang telah kami hadirkan.
            </p>
            <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
                <a href="#naskah" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-bold rounded-xl transition shadow-lg shadow-emerald-900/30">Naskah</a>
                <a href="#materi-teater" class="px-4 py-2 border border-slate-700 hover:border-blue-500 text-slate-300 hover:text-blue-400 text-xs font-bold rounded-xl transition">Materi Teater</a>
                <a href="#jadwal-latihan" class="px-4 py-2 border border-slate-700 hover:border-violet-500 text-slate-300 hover:text-violet-400 text-xs font-bold rounded-xl transition">Jadwal Latihan</a>
                <a href="#materi-latihan" class="px-4 py-2 border border-slate-700 hover:border-amber-500 text-slate-300 hover:text-amber-400 text-xs font-bold rounded-xl transition">Materi Latihan</a>
            </div>
        </div>

        <% if (typeof heroPhotos !== 'undefined' && heroPhotos.length > 1) { %>
        <div id="hero-dots" class="absolute bottom-5 left-1/2 -translate-x-1/2 flex gap-2 z-[2]">
            <% heroPhotos.forEach(function(_, i) { %>
            <span class="hero-dot" data-index="<%= i %>"
                  style="width:<%= i === 0 ? '20px' : '7px' %>;height:7px;border-radius:9999px;cursor:pointer;transition:all 0.3s;background:<%= i === 0 ? '#10b981' : 'rgba(255,255,255,0.25)' %>;"></span>
            <% }) %>
        </div>
        <% } %>
    </section>

    <script>
    (function() {
        var slides = document.querySelectorAll('.hero-slide');
        var dots   = document.querySelectorAll('.hero-dot');
        if (slides.length < 2) return;
        var current = 0;
        function goTo(n) {
            dots[current].style.width = '7px';
            dots[current].style.background = 'rgba(255,255,255,0.25)';
            slides[current].style.opacity = 0;
            current = n % slides.length;
            slides[current].style.opacity = 1;
            dots[current].style.width = '20px';
            dots[current].style.background = '#10b981';
        }
        dots.forEach(function(dot) {
            dot.addEventListener('click', function() { goTo(parseInt(this.dataset.index)); });
        });
        setInterval(function() { goTo(current + 1); }, 4500);
    })();
    </script>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 sidebar-grid">
      <div class="min-w-0">

    <!-- ── SEARCH ────────────────────────────────────────────────── -->
    <div class="border-b border-slate-900 py-6">
        <div class="max-w-3xl mx-auto">
            <form action="/articles" method="GET" class="relative group">
                <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                    <svg class="w-4 h-4 text-slate-500 group-focus-within:text-emerald-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <input type="text" name="q"
                    value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
                    placeholder="Cari naskah, materi, atau jadwal..."
                    class="w-full bg-slate-900 border border-slate-800 focus:border-emerald-500 text-slate-200 text-sm rounded-xl pl-10 pr-10 py-3 outline-none transition placeholder-slate-600">
                <% if (typeof searchQuery !== 'undefined' && searchQuery !== '') { %>
                <a href="/articles" class="absolute inset-y-0 right-0 flex items-center pr-4 text-slate-500 hover:text-red-400 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </a>
                <% } %>
            </form>
            <% if (typeof searchQuery !== 'undefined' && searchQuery !== '') { %>
            <p class="text-[10px] font-mono text-emerald-500 tracking-widest uppercase mt-2 pl-1">
                Menemukan <%= articles.length %> hasil untuk "<%= searchQuery %>"
            </p>
            <% } %>
        </div>
    </div>

    <!-- ── NASKAH ─────────────────────────────────────────────── -->
    <section id="naskah" class="py-10 sm:py-12 border-b border-slate-900">
        <div>
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-emerald-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Naskah & Dokumentasi</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5">Tulisan dan catatan dari panggung</p>
                </div>
                <% if (totalArticles > 0) { %>
                <span class="ml-auto text-[10px] font-mono bg-slate-900 text-slate-500 px-3 py-1 rounded-full border border-slate-800 shrink-0"><%= totalArticles %> naskah</span>
                <% } %>
            </div>

            <% if (articles && articles.length > 0) { %>
            <div class="overflow-x-auto rounded-2xl border border-slate-800">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-slate-900/80 border-b border-slate-800">
                            <th class="text-left px-5 py-3.5 text-[10px] font-black font-mono uppercase tracking-widest text-slate-500 w-12">No</th>
                            <th class="text-left px-5 py-3.5 text-[10px] font-black font-mono uppercase tracking-widest text-slate-500">Judul Naskah</th>
                            <th class="text-left px-5 py-3.5 text-[10px] font-black font-mono uppercase tracking-widest text-slate-500 hidden sm:table-cell">Karya</th>
                            <th class="text-left px-5 py-3.5 text-[10px] font-black font-mono uppercase tracking-widest text-slate-500 hidden md:table-cell">Tanggal</th>
                            <th class="px-5 py-3.5 w-20"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800/60">
                        <% articles.forEach(function(article, idx) { %>
                        <tr class="group hover:bg-slate-900/60 transition">
                            <td class="px-5 py-4">
                                <span class="text-[11px] font-black font-mono text-slate-600"><%= String(idx + 1).padStart(2, '0') %></span>
                            </td>
                            <td class="px-5 py-4">
                                <a href="/article/<%= article._id %>" class="font-semibold text-slate-200 group-hover:text-emerald-400 transition text-sm leading-snug line-clamp-2">
                                    <%= article.title %>
                                </a>
                            </td>
                            <td class="px-5 py-4 hidden sm:table-cell">
                                <span class="text-xs text-slate-400 font-mono"><%= article.karya || '-' %></span>
                            </td>
                            <td class="px-5 py-4 hidden md:table-cell">
                                <span class="text-[10px] text-slate-600 font-mono whitespace-nowrap">
                                    <%= article.createdAt.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                </span>
                            </td>
                            <td class="px-5 py-4 text-right">
                                <a href="/article/<%= article._id %>" class="inline-flex items-center gap-1 text-[10px] font-bold text-emerald-500 hover:text-emerald-400 uppercase tracking-wider transition whitespace-nowrap">
                                    Baca
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                                </a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
            <div class="text-center py-16 sm:py-24 border border-dashed border-slate-800 rounded-2xl">
                <div class="h-12 w-12 rounded-2xl bg-slate-800 border border-slate-700 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-6 h-6 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                </div>
                <p class="text-slate-500 font-medium text-sm">Belum ada naskah yang dipublish.</p>
                <p class="text-slate-700 text-xs font-mono mt-1">Segera hadir</p>
            </div>
            <% } %>

            <!-- PAGINASI -->
            <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
            <div class="flex items-center justify-center gap-2 mt-10">
                <% if (currentPage > 1) { %>
                <a href="/articles?<%= searchQuery ? 'q=' + encodeURIComponent(searchQuery) + '&' : '' %>page=<%= currentPage - 1 %>"
                   class="flex items-center gap-1.5 px-4 py-2 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-300 text-xs font-bold rounded-xl transition">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
                    Sebelumnya
                </a>
                <% } %>
                <% for (var p = 1; p <= totalPages; p++) { %>
                    <% if (p === currentPage) { %>
                    <span class="w-9 h-9 flex items-center justify-center bg-blue-500 text-white text-xs font-black rounded-xl">
                        <%= p %>
                    </span>
                    <% } else if (p === 1 || p === totalPages || (p >= currentPage - 1 && p <= currentPage + 1)) { %>
                    <a href="/articles?<%= searchQuery ? 'q=' + encodeURIComponent(searchQuery) + '&' : '' %>page=<%= p %>"
                       class="w-9 h-9 flex items-center justify-center bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-400 hover:text-white text-xs font-bold rounded-xl transition">
                        <%= p %>
                    </a>
                    <% } else if (p === currentPage - 2 || p === currentPage + 2) { %>
                    <span class="w-9 h-9 flex items-center justify-center text-slate-600 text-xs">…</span>
                    <% } %>
                <% } %>
                <% if (currentPage < totalPages) { %>
                <a href="/articles?<%= searchQuery ? 'q=' + encodeURIComponent(searchQuery) + '&' : '' %>page=<%= currentPage + 1 %>"
                   class="flex items-center gap-1.5 px-4 py-2 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-slate-300 text-xs font-bold rounded-xl transition">
                    Selanjutnya
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                </a>
                <% } %>
            </div>
            <p class="text-center text-[10px] font-mono text-slate-600 mt-3">
                Halaman <%= currentPage %> dari <%= totalPages %> &bull; <%= totalArticles %> naskah
            </p>
            <% } %>

        </div>
    </section>

    <!-- ── MATERI TEATER ─────────────────────────────────────── -->
    <section id="materi-teater" class="py-10 sm:py-12 border-b border-slate-900">
        <div>
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-blue-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Materi Teater</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5">Panduan dan referensi seni teater</p>
                </div>
                <% if (materiTeater && materiTeater.length > 0) { %>
                <span class="ml-auto text-[10px] font-mono bg-slate-900 text-slate-500 px-3 py-1 rounded-full border border-slate-800 shrink-0"><%= materiTeater.length %> materi</span>
                <% } %>
            </div>

            <% if (materiTeater && materiTeater.length > 0) { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                <% materiTeater.forEach(function(item, idx) { %>
                <div class="relative group bg-slate-900/60 border border-slate-800 hover:border-blue-500/40 rounded-2xl overflow-hidden transition-all duration-300 flex flex-col">
                    <div class="absolute inset-0 bg-gradient-to-b from-blue-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-2xl"></div>
                    <!-- Thumbnail -->
                    <div class="relative aspect-video overflow-hidden bg-slate-800 shrink-0">
                        <% if (item.thumbnail) { %>
                        <img src="<%= item.thumbnail %>" alt="<%= item.title %>"
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <% } else { %>
                        <div class="flex items-center justify-center h-full">
                            <svg class="w-8 h-8 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                            </svg>
                        </div>
                        <% } %>
                        <div class="absolute top-3 left-3 h-7 w-7 rounded-lg bg-slate-950/80 border border-slate-700 flex items-center justify-center">
                            <span class="text-[10px] font-black text-slate-400 font-mono"><%= String(idx + 1).padStart(2, '0') %></span>
                        </div>
                        <div class="absolute top-3 right-3">
                            <span class="bg-blue-600 text-[9px] text-white px-2 py-1 rounded-md uppercase font-black tracking-widest">Teater</span>
                        </div>
                    </div>
                    <!-- Info -->
                    <div class="relative p-5 flex flex-col flex-1">
                        <h3 class="text-sm font-bold text-white group-hover:text-blue-400 transition leading-snug line-clamp-2 mb-2"><%= item.title %></h3>
                        <p class="text-slate-500 text-xs leading-relaxed line-clamp-2 flex-1">
                            <%= (item.content || '').replace(/<[^>]*>?/gm, '').substring(0, 100) %>...
                        </p>
                        <div class="flex items-center justify-between mt-4 pt-3 border-t border-slate-800/60">
                            <span class="text-[10px] text-slate-600 font-mono"><%= item.createdAt.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %></span>
                            <a href="/materi-teater/<%= item._id %>" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-800 hover:bg-blue-600 text-white text-xs font-bold rounded-lg transition border border-slate-700 hover:border-blue-500">
                                Baca
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } else { %>
            <div class="text-center py-16 sm:py-24 border border-dashed border-slate-800 rounded-2xl">
                <div class="h-12 w-12 rounded-2xl bg-slate-800 border border-slate-700 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-6 h-6 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                </div>
                <p class="text-slate-500 font-medium text-sm">Belum ada materi teater.</p>
                <p class="text-slate-700 text-xs font-mono mt-1">Segera hadir</p>
            </div>
            <% } %>
        </div>
    </section>

    <!-- ── JADWAL LATIHAN ────────────────────────────────────── -->
    <% const hasJadwal = hariList.some(h => jadwalGrouped[h] && jadwalGrouped[h].length > 0); %>
    <section id="jadwal-latihan" class="py-10 sm:py-12 border-b border-slate-900">
        <div>
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
                <div class="h-9 w-1 bg-violet-500 rounded-full shrink-0"></div>
                <div>
                    <h2 class="text-lg sm:text-xl font-black text-white tracking-tight">Jadwal Latihan</h2>
                    <p class="text-slate-500 text-xs font-mono mt-0.5">Jadwal latihan mingguan</p>
                </div>
            </div>

            <% if (hasJadwal) { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                <% hariList.forEach(function(hari) { %>
                <% if (jadwalGrouped[hari] && jadwalGrouped[hari].length > 0) { %>
                <div class="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden hover:border-violet-500/30 transition-all duration-300">
                    <div class="px-4 py-3 bg-violet-500/10 border-b border-slate-800 flex items-center gap-2">
                        <span class="h-1.5 w-1.5 rounded-full bg-violet-400"></span>
                        <span class="text-xs font-black uppercase tracking-widest text-white"><%= hari %></span>
                        <span class="ml-auto text-[10px] font-mono text-slate-500"><%= jadwalGrouped[hari].length %> sesi</span>
                    </div>
                    <div class="divide-y divide-slate-800/50">
                        <% jadwalGrouped[hari].sort((a,b) => a.waktu_mulai.localeCompare(b.waktu_mulai)).forEach(function(sesi) { %>
                        <div class="px-4 py-3">
                            <div class="flex items-start justify-between gap-2 mb-1">
                                <span class="text-xs font-bold text-slate-200 leading-snug"><%= sesi.materi %></span>
                                <span class="text-[10px] font-mono text-violet-400 whitespace-nowrap shrink-0">
                                    <%= sesi.waktu_mulai %>–<%= sesi.waktu_selesai %>
                                </span>
                            </div>
                            <div class="flex flex-wrap items-center gap-3 mt-1.5">
                                <span class="flex items-center gap-1 text-[10px] text-slate-500">
                                    <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                    <%= sesi.pelatih %>
                                </span>
                                <span class="flex items-center gap-1 text-[10px] text-slate-500">
                                    <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                    <%= sesi.tempat %>
                                </span>
                            </div>
                            <% if (sesi.keterangan) { %>
                            <p class="text-[10px] text-slate-600 italic mt-1"><%= sesi.keterangan %></p>
                            <% } %>
                        </div>
                        <% }) %>
                    </div>
                </div>
                <% } %>
                <% }) %>
            </div>
            <% } else { %>
            <div class="text-center py-16 sm:py-24 border border-dashed border-slate-800 rounded-2xl">
                <div class="h-12 w-12 rounded-2xl bg-slate-800 border border-slate-700 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-6 h-6 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                </div>
                <p class="text-slate-500 font-medium text-sm">Belum ada jadwal latihan.</p>
                <p class="text-slate-700 text-xs font-mono mt-1">Segera hadir</p>
            </div>
            <% } %>
        </div>
    </section>

    <!-- ── MATERI LATIHAN ────────────────────────────────────── -->
    <%
    const KATEGORI_COLOR = {
        'Teknik':   { badge: 'bg-blue-500/15 text-blue-400 border-blue-500/20' },
        'Fisik':    { badge: 'bg-amber-500/15 text-amber-400 border-amber-500/20' },
        'Taktik':   { badge: 'bg-violet-500/15 text-violet-400 border-violet-500/20' },
        'Mental':   { badge: 'bg-emerald-500/15 text-emerald-400 border-emerald-500/20' },
        'Sparring': { badge: 'bg-red-500/15 text-red-400 border-red-500/20' },
        'Lainnya':  { badge: 'bg-slate-500/15 text-slate-400 border-slate-500/20' },
    };
    %>
    <section id="materi-latihan" class="py-10 sm:py-12 border-b border-slate-900">
        <div>
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
