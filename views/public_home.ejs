<%- include('partials/header') %>

<div class="min-h-screen bg-slate-950 text-slate-200">
    <header class="py-16 px-6 text-center bg-gradient-to-b from-slate-900 to-slate-950 border-b border-slate-800">
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">
            Trending <span class="text-blue-500">Bulk</span> Library
        </h1>
        <p class="text-slate-400 max-w-2xl mx-auto">
            Koleksi template dan resource terbaik yang telah dikurasi oleh tim NOC kami.
        </p>
    </header>

    <main class="max-w-7xl mx-auto p-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            <% if (templates && templates.length > 0) { %>
                <% templates.forEach(item => { %>
                    <div class="group bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden hover:border-blue-500 transition-all duration-300 shadow-xl">
                        <div class="relative overflow-hidden aspect-video">
                            <img src="<%= item.imageUrl %>" alt="<%= item.title %>" 
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent"></div>
                        </div>
                        
                        <div class="p-6">
                            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-blue-400 transition">
                                <%= item.title %>
                            </h3>
                            <p class="text-slate-400 text-sm leading-relaxed line-clamp-2 mb-4">
                                <%= item.description %>
                            </p>
                            <div class="flex items-center justify-between pt-4 border-t border-slate-800">
                                <span class="text-xs text-slate-500 font-mono">
                                    Released: <%= item.createdAt.toLocaleDateString('id-ID') %>
                                </span>
                                <button class="px-4 py-2 bg-slate-800 hover:bg-blue-600 text-white text-xs font-bold rounded-lg transition">
                                    <a href="/detail/<%= item._id %>" class="block w-full text-center px-4 py-2 bg-slate-800 hover:bg-blue-600 text-white text-xs font-bold rounded-lg transition duration-300">
    					View Detail
				    </a>

                                </button>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full text-center py-20">
                    <p class="text-slate-500 italic text-lg">Belum ada konten publik tersedia.</p>
                </div>
            <% } %>
        </div>
    </main>
</div>

<%- include('partials/footer') %>
