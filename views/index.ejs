<%- include('partials/admin_header') %>

<% const _stats = (typeof stats !== 'undefined' && stats) ? stats : { templates:0, articles:0, berita:0, galeri:0, totalKonten:0, articlesThisMonth:0, beritaThisMonth:0 }; %>
<% const _chart = (typeof chartData !== 'undefined' && chartData) ? chartData : []; %>

<main class="min-h-screen bg-slate-950 pt-6 pb-24">
<div class="max-w-7xl mx-auto px-4 md:px-6">

    <!-- ===== PAGE HEADER ===== -->
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <p class="text-[10px] font-mono text-slate-600 uppercase tracking-[0.3em] mb-1">
                <%= new Date().toLocaleDateString('id-ID', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) %>
            </p>
            <h1 class="text-2xl font-black text-white tracking-tight">
                Selamat datang, <span class="text-blue-400"><%= userName %></span>
            </h1>
            <p class="text-slate-500 text-xs mt-1">Kelola konten dan pengaturan website Teater Saphalta</p>
        </div>
        <div class="flex items-center gap-2">
            <a href="/admin/berita/add" class="flex items-center gap-2 px-4 py-2.5 bg-slate-800 hover:bg-slate-700 border border-slate-700 text-white text-xs font-bold rounded-xl transition">
                <svg class="w-3.5 h-3.5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Berita
            </a>
            <a href="/admin/article/add" class="flex items-center gap-2 px-4 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-xs font-black rounded-xl transition shadow-lg shadow-blue-900/30">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                Tulis Blog
            </a>
        </div>
    </div>

    <!-- ===== FLASH MESSAGES ===== -->
    <% if (success) { %>
    <div class="mb-6 flex items-center gap-3 px-4 py-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl">
        <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        <p class="text-emerald-400 text-xs font-bold"><%= success %></p>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="mb-6 flex items-center gap-3 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl">
        <svg class="w-4 h-4 text-red-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        <p class="text-red-400 text-xs font-bold"><%= error %></p>
    </div>
    <% } %>

    <!-- ===== STATS CARDS ===== -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">

        <!-- Riwayat Pementasan -->
        <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-5 relative overflow-hidden group hover:border-blue-500/40 transition">
            <div class="absolute top-0 right-0 h-20 w-20 bg-blue-600/5 rounded-full -translate-y-6 translate-x-6 group-hover:bg-blue-600/10 transition"></div>
            <div class="relative">
                <div class="flex items-center justify-between mb-3">
                    <div class="h-8 w-8 bg-blue-600/10 border border-blue-500/20 rounded-xl flex items-center justify-center">
                        <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <a href="/upload" class="text-[9px] font-mono text-blue-400/60 hover:text-blue-400 transition uppercase tracking-wider">Kelola →</a>
                </div>
                <p class="text-3xl font-black text-white"><%= _stats.templates %></p>
                <p class="text-[10px] font-mono text-slate-500 mt-1">Riwayat Pementasan</p>
            </div>
        </div>

        <!-- Blog / Naskah -->
        <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-5 relative overflow-hidden group hover:border-emerald-500/40 transition">
            <div class="absolute top-0 right-0 h-20 w-20 bg-emerald-600/5 rounded-full -translate-y-6 translate-x-6 group-hover:bg-emerald-600/10 transition"></div>
            <div class="relative">
                <div class="flex items-center justify-between mb-3">
                    <div class="h-8 w-8 bg-emerald-600/10 border border-emerald-500/20 rounded-xl flex items-center justify-center">
                        <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                    </div>
                    <a href="/admin/article/add" class="text-[9px] font-mono text-emerald-400/60 hover:text-emerald-400 transition uppercase tracking-wider">Tulis →</a>
                </div>
                <p class="text-3xl font-black text-white"><%= _stats.articles %></p>
                <p class="text-[10px] font-mono text-slate-500 mt-1">Blog & Naskah</p>
                <% if (_stats.articlesThisMonth > 0) { %>
                <div class="mt-2 flex items-center gap-1">
                    <div class="h-1 w-1 rounded-full bg-emerald-500"></div>
                    <span class="text-[9px] text-emerald-400 font-mono">+<%= _stats.articlesThisMonth %> bulan ini</span>
                </div>
                <% } %>
            </div>
        </div>

        <!-- Berita -->
        <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-5 relative overflow-hidden group hover:border-amber-500/40 transition">
            <div class="absolute top-0 right-0 h-20 w-20 bg-amber-600/5 rounded-full -translate-y-6 translate-x-6 group-hover:bg-amber-600/10 transition"></div>
            <div class="relative">
                <div class="flex items-center justify-between mb-3">
                    <div class="h-8 w-8 bg-amber-600/10 border border-amber-500/20 rounded-xl flex items-center justify-center">
                        <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v10a2 2 0 01-2 2z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 4v6h-6"/>
                        </svg>
                    </div>
                    <a href="/admin/berita" class="text-[9px] font-mono text-amber-400/60 hover:text-amber-400 transition uppercase tracking-wider">Kelola →</a>
                </div>
                <p class="text-3xl font-black text-white"><%= _stats.berita %></p>
                <p class="text-[10px] font-mono text-slate-500 mt-1">Berita & Info</p>
                <% if (_stats.beritaThisMonth > 0) { %>
                <div class="mt-2 flex items-center gap-1">
                    <div class="h-1 w-1 rounded-full bg-amber-500"></div>
                    <span class="text-[9px] text-amber-400 font-mono">+<%= _stats.beritaThisMonth %> bulan ini</span>
                </div>
                <% } %>
            </div>
        </div>

        <!-- Galeri -->
        <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-5 relative overflow-hidden group hover:border-violet-500/40 transition">
            <div class="absolute top-0 right-0 h-20 w-20 bg-violet-600/5 rounded-full -translate-y-6 translate-x-6 group-hover:bg-violet-600/10 transition"></div>
            <div class="relative">
                <div class="flex items-center justify-between mb-3">
                    <div class="h-8 w-8 bg-violet-600/10 border border-violet-500/20 rounded-xl flex items-center justify-center">
                        <svg class="w-4 h-4 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <a href="/admin/galeri" class="text-[9px] font-mono text-violet-400/60 hover:text-violet-400 transition uppercase tracking-wider">Kelola →</a>
                </div>
                <p class="text-3xl font-black text-white"><%= _stats.galeri %></p>
                <p class="text-[10px] font-mono text-slate-500 mt-1">Foto & Video</p>
            </div>
        </div>

    </div>

    <!-- ===== GRAFIK AKTIVITAS 6 BULAN ===== -->
    <% if (_chart.length > 0) { %>
    <%
        const _maxVal = Math.max(1, ..._chart.map(function(c){ return c.articles + c.berita; }));
    %>
    <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-6 mb-8">
        <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
                <div class="h-7 w-1 bg-blue-500 rounded-full"></div>
                <div>
                    <h2 class="text-sm font-black text-white">Aktivitas Konten</h2>
                    <p class="text-[10px] font-mono text-slate-500 mt-0.5">6 bulan terakhir</p>
                </div>
            </div>
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-1.5">
                    <div class="h-2 w-2 rounded-full bg-emerald-500"></div>
                    <span class="text-[10px] font-mono text-slate-500">Blog</span>
                </div>
                <div class="flex items-center gap-1.5">
                    <div class="h-2 w-2 rounded-full bg-amber-500"></div>
                    <span class="text-[10px] font-mono text-slate-500">Berita</span>
                </div>
            </div>
        </div>
        <div class="flex items-end gap-3 h-40">
            <% _chart.forEach(function(c) {
                var total = c.articles + c.berita;
                var articlePct = _maxVal > 0 ? Math.round((c.articles / _maxVal) * 100) : 0;
                var beritaPct  = _maxVal > 0 ? Math.round((c.berita  / _maxVal) * 100) : 0;
            %>
            <div class="flex-1 flex flex-col items-center gap-1">
                <span class="text-[9px] font-mono text-slate-600"><%= total > 0 ? total : '' %></span>
                <div class="w-full flex flex-col-reverse gap-0.5" style="height:120px;">
                    <div class="w-full rounded-t-lg bg-amber-500/80 transition-all duration-500" style="height:<%= beritaPct %>%;min-height:<%= c.berita > 0 ? '4px' : '0' %>;"></div>
                    <div class="w-full rounded-t-lg bg-emerald-500/80 transition-all duration-500" style="height:<%= articlePct %>%;min-height:<%= c.articles > 0 ? '4px' : '0' %>;"></div>
                </div>
                <span class="text-[9px] font-mono text-slate-500"><%= c.label %></span>
            </div>
            <% }) %>
        </div>
        <div class="mt-4 pt-4 border-t border-slate-800 grid grid-cols-3 gap-4">
            <div class="text-center">
                <p class="text-lg font-black text-white"><%= _stats.totalKonten %></p>
                <p class="text-[9px] font-mono text-slate-600 uppercase tracking-wider">Total Konten</p>
            </div>
            <div class="text-center border-x border-slate-800">
                <p class="text-lg font-black text-emerald-400">+<%= _stats.articlesThisMonth %></p>
                <p class="text-[9px] font-mono text-slate-600 uppercase tracking-wider">Blog Bulan Ini</p>
            </div>
            <div class="text-center">
                <p class="text-lg font-black text-amber-400">+<%= _stats.beritaThisMonth %></p>
                <p class="text-[9px] font-mono text-slate-600 uppercase tracking-wider">Berita Bulan Ini</p>
            </div>
        </div>
    </div>
    <% } %>

    <!-- ===== MAIN CONTENT GRID ===== -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">

        <!-- KIRI: Recent Blog + Berita (2/3) -->
        <div class="lg:col-span-2 space-y-6">

            <!-- Recent Blog -->
            <div class="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden">
                <div class="flex items-center justify-between px-6 py-4 border-b border-slate-800">
                    <div class="flex items-center gap-3">
                        <div class="h-7 w-1 bg-emerald-500 rounded-full"></div>
                        <h2 class="text-sm font-black text-white">Blog & Naskah</h2>
                        <span class="text-[10px] px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 font-mono"><%= articles.length %></span>
                    </div>
                    <a href="/admin/article/add" class="flex items-center gap-1.5 text-[10px] font-black uppercase tracking-widest text-emerald-400 hover:text-emerald-300 transition">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
                        Tulis
                    </a>
                </div>
                <div class="divide-y divide-slate-800/60">
                    <% if (articles.length === 0) { %>
                    <div class="px-6 py-10 text-center">
                        <p class="text-slate-600 text-xs font-mono uppercase tracking-[0.2em]">Belum ada blog</p>
                    </div>
                    <% } %>
                    <% articles.slice(0, 5).forEach(article => { %>
                    <div class="flex items-center gap-4 px-6 py-4 hover:bg-slate-800/30 transition group">
                        <div class="h-10 w-10 rounded-xl overflow-hidden bg-slate-800 border border-slate-700 shrink-0">
                            <img src="<%= article.thumbnail || '/images/default-doc.png' %>" class="h-full w-full object-cover">
                        </div>
                        <div class="flex-1 min-w-0">
                            <a href="/article/<%= article._id %>" target="_blank" class="text-sm font-bold text-slate-200 hover:text-emerald-400 transition truncate block leading-tight"><%= article.title %></a>
                            <div class="flex items-center gap-3 mt-0.5">
                                <span class="text-[10px] font-mono text-slate-600">@<%= article.author ? article.author.username : 'admin' %></span>
                                <span class="text-[10px] font-mono text-slate-700">·</span>
                                <span class="text-[10px] font-mono text-slate-600"><%= article.createdAt.toLocaleDateString('id-ID', {day:'numeric', month:'short', year:'numeric'}) %></span>
                            </div>
                        </div>
                        <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition shrink-0">
                            <a href="/admin/article/edit/<%= article._id %>" class="p-1.5 text-slate-500 hover:text-emerald-400 hover:bg-emerald-500/10 rounded-lg transition" title="Edit">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            </a>
                            <form action="/admin/article/delete/<%= article._id %>" method="POST" onsubmit="return confirm('Hapus artikel ini?')">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button type="submit" class="p-1.5 text-slate-500 hover:text-red-400 hover:bg-red-500/10 rounded-lg transition" title="Hapus">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                </button>
                            </form>
                        </div>
                    </div>
                    <% }) %>
                </div>
                <% if (articles.length > 5) { %>
                <div class="px-6 py-3 border-t border-slate-800 text-center">
                    <span class="text-[10px] font-mono text-slate-600">+ <%= articles.length - 5 %> artikel lainnya</span>
                </div>
                <% } %>
            </div>

            <!-- Recent Berita -->
            <% const _recentBerita = (typeof recentBerita !== 'undefined' && recentBerita) ? recentBerita : []; %>
            <div class="bg-slate-900/60 border border-slate-800 rounded-2xl overflow-hidden">
                <div class="flex items-center justify-between px-6 py-4 border-b border-slate-800">
                    <div class="flex items-center gap-3">
                        <div class="h-7 w-1 bg-amber-500 rounded-full"></div>
                        <h2 class="text-sm font-black text-white">Berita Terkini</h2>
                        <span class="text-[10px] px-2 py-0.5 rounded-full bg-amber-500/10 text-amber-400 border border-amber-500/20 font-mono"><%= _recentBerita.length %></span>
                    </div>
                    <a href="/admin/berita/add" class="flex items-center gap-1.5 text-[10px] font-black uppercase tracking-widest text-amber-400 hover:text-amber-300 transition">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
                        Tambah
                    </a>
                </div>
                <div class="divide-y divide-slate-800/60">
                    <% if (_recentBerita.length === 0) { %>
                    <div class="px-6 py-10 text-center">
                        <p class="text-slate-600 text-xs font-mono uppercase tracking-[0.2em]">Belum ada berita</p>
                    </div>
                    <% } %>
                    <% _recentBerita.forEach(b => { %>
                    <div class="flex items-center gap-4 px-6 py-4 hover:bg-slate-800/30 transition group">
                        <div class="h-10 w-10 rounded-xl overflow-hidden bg-slate-800 border border-slate-700 shrink-0">
                            <% if (b.thumbnail) { %>
                            <img src="<%= b.thumbnail %>" class="h-full w-full object-cover">
                            <% } else { %>
                            <div class="h-full w-full flex items-center justify-center">
                                <svg class="w-4 h-4 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v10a2 2 0 01-2 2z"/></svg>
                            </div>
                            <% } %>
                        </div>
                        <div class="flex-1 min-w-0">
                            <a href="/berita/<%= b.slug || b._id %>" target="_blank" class="text-sm font-bold text-slate-200 hover:text-amber-400 transition truncate block leading-tight"><%= b.title %></a>
                            <span class="text-[10px] font-mono text-slate-600"><%= b.createdAt.toLocaleDateString('id-ID', {day:'numeric', month:'short', year:'numeric'}) %></span>
                        </div>
                        <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition shrink-0">
                            <a href="/admin/berita/edit/<%= b._id %>" class="p-1.5 text-slate-500 hover:text-amber-400 hover:bg-amber-500/10 rounded-lg transition" title="Edit">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            </a>
                            <a href="/admin/berita" class="p-1.5 text-slate-500 hover:text-slate-300 hover:bg-slate-700 rounded-lg transition" title="Semua Berita">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
                            </a>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>

        </div>

        <!-- KANAN: Site Identity + Quick Links (1/3) -->
        <div class="space-y-6">

            <!-- Site Identity -->
            <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-5">
                <div class="flex items-center gap-3 mb-5">
                    <div class="h-7 w-1 bg-blue-500 rounded-full"></div>
                    <h2 class="text-sm font-black text-white">Site Identity</h2>
                </div>

                <!-- Logo Preview -->
                <div class="flex items-center gap-4 mb-5 pb-5 border-b border-slate-800">
                    <div class="h-14 w-14 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center overflow-hidden shrink-0">
                        <% if (typeof siteSetting !== 'undefined' && siteSetting && siteSetting.logoUrl) { %>
                        <img src="<%= siteSetting.logoUrl %>" alt="Logo" class="w-full h-full object-contain p-1">
                        <% } else { %>
                        <svg class="h-7 w-7 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                        <% } %>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-xs font-bold text-slate-300 mb-0.5">Logo Website</p>
                        <% if (typeof siteSetting !== 'undefined' && siteSetting && siteSetting.logoUrl) { %>
                        <p class="text-[10px] text-emerald-400 font-mono">Terpasang</p>
                        <form action="/admin/site-settings/logo/delete" method="POST" onsubmit="return confirm('Hapus logo?')">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="text-[10px] font-mono text-red-500 hover:text-red-400 transition mt-1">Hapus Logo</button>
                        </form>
                        <% } else { %>
                        <p class="text-[10px] text-slate-600 font-mono">Menggunakan ikon default</p>
                        <% } %>
                    </div>
                </div>

                <!-- Upload Form -->
                <form action="/admin/site-settings/logo" method="POST" enctype="multipart/form-data" class="space-y-3">
                    <label id="logo-drop" class="flex items-center gap-3 w-full border-2 border-dashed border-slate-700 rounded-xl px-4 py-3.5 cursor-pointer hover:border-blue-500/60 hover:bg-blue-500/5 transition group">
                        <input type="file" name="logo" id="logo-input" required accept="image/jpeg,image/jpg,image/png,image/webp,image/svg+xml" class="hidden">
                        <div id="logo-placeholder" class="flex items-center gap-3 w-full">
