<%- include('partials/header') %>

<main class="min-h-screen bg-slate-950 pt-12 pb-24 px-6">
    <div class="max-w-7xl mx-auto">
        
        <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <div class="h-3 w-3 rounded-full bg-blue-500 shadow-[0_0_12px_rgba(59,130,246,0.8)] animate-pulse"></div>
                    <h1 class="text-4xl font-black text-white tracking-tighter uppercase italic">Terminal Dashboard</h1>
                </div>
                <p class="text-slate-500 font-mono text-xs uppercase tracking-[0.3em]">
                    Active Operator: <span class="text-blue-400 font-bold"><%= userName %></span> 
                    <span class="mx-2 text-slate-800">|</span> 
                    Node: <span class="text-slate-300">apps.trendingbulk.top</span>
                </p>
            </div>
            
            <div class="flex gap-4">
                <a href="/upload" class="bg-slate-900 hover:bg-slate-800 text-white text-[10px] font-black uppercase tracking-widest px-6 py-3 rounded-xl border border-slate-800 transition-all flex items-center gap-2">
                    <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    New Template
                </a>
                <a href="/admin/article/add" class="bg-blue-600 hover:bg-blue-700 text-white text-[10px] font-black uppercase tracking-widest px-6 py-3 rounded-xl transition-all shadow-lg shadow-blue-900/20 flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                    Write Article
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
            <div class="bg-slate-900/40 border border-slate-800 p-6 rounded-[2rem]">
                <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest mb-1">Total Articles</p>
                <h3 class="text-3xl font-black text-white"><%= articles.length %> <span class="text-blue-500 text-sm italic font-medium tracking-normal">Entries</span></h3>
            </div>
            <div class="bg-slate-900/40 border border-slate-800 p-6 rounded-[2rem]">
                <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest mb-1">Active Templates</p>
                <h3 class="text-3xl font-black text-white"><%= templates.length %> <span class="text-emerald-500 text-sm italic font-medium tracking-normal">Assets</span></h3>
            </div>
            <div class="bg-slate-900/40 border border-slate-800 p-6 rounded-[2rem]">
                <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest mb-1">System Status</p>
                <div class="flex items-center gap-2 mt-2">
                    <span class="px-2 py-1 bg-emerald-500/10 text-emerald-500 text-[9px] font-black rounded uppercase">Operational</span>
                    <span class="px-2 py-1 bg-blue-500/10 text-blue-500 text-[9px] font-black rounded uppercase">v2.4-stable</span>
                </div>
            </div>
        </div>

        <section class="mb-16">
            <div class="flex items-center gap-4 mb-6">
                <h2 class="text-xl font-black text-white uppercase tracking-tighter italic">Knowledge Repository</h2>
                <div class="h-[1px] flex-1 bg-slate-900"></div>
            </div>

            <div class="bg-slate-900/20 border border-slate-800 rounded-[2.5rem] overflow-hidden">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-slate-800 bg-slate-900/50">
                            <th class="p-6 text-[10px] font-black text-slate-500 uppercase tracking-widest">Document Title</th>
                            <th class="p-6 text-[10px] font-black text-slate-500 uppercase tracking-widest hidden md:table-cell">Author</th>
                            <th class="p-6 text-[10px] font-black text-slate-500 uppercase tracking-widest">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800/50">
                        <% articles.forEach(article => { %>
                        <tr class="hover:bg-slate-800/20 transition-colors group">
                            <td class="p-6">
                                <div class="flex items-center gap-4">
                                    <div class="h-10 w-10 rounded-xl overflow-hidden bg-slate-800 border border-slate-700 shrink-0">
                                        <img src="<%= article.thumbnail || '/images/default-doc.png' %>" class="h-full w-full object-cover">
                                    </div>
                                    <div>
                                        <a href="/article/<%= article._id %>" class="text-slate-200 font-bold hover:text-blue-400 transition block leading-tight mb-1"><%= article.title %></a>
                                        <span class="text-[9px] font-mono text-slate-600 uppercase tracking-tighter"><%= article.createdAt.toDateString() %></span>
                                    </div>
                                </div>
                            </td>
                            <td class="p-6 hidden md:table-cell">
                                <span class="text-[10px] font-bold text-slate-400 uppercase italic">@<%= article.author ? article.author.username : 'admin' %></span>
                            </td>
                            <td class="p-6">
                                <div class="flex items-center gap-3">
                                    <a href="/admin/article/edit/<%= article._id %>" class="p-2 text-slate-500 hover:text-emerald-500 hover:bg-emerald-500/10 rounded-lg transition" title="Edit Article">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </a>
                                    <form action="/admin/article/delete/<%= article._id %>" method="POST" onsubmit="return confirm('Archive this document?');">
                                        <button type="submit" class="p-2 text-slate-500 hover:text-red-500 hover:bg-red-500/10 rounded-lg transition" title="Delete">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                        <% if (articles.length === 0) { %>
                            <tr><td colspan="3" class="p-12 text-center text-slate-600 font-mono text-xs uppercase tracking-[0.3em]">No documentation found in this node.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </section>

        <section>
            <div class="flex items-center gap-4 mb-6">
                <h2 class="text-xl font-black text-white uppercase tracking-tighter italic">Asset Catalog</h2>
                <div class="h-[1px] flex-1 bg-slate-900"></div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <% templates.forEach(template => { %>
                <div class="bg-slate-900/40 border border-slate-800 rounded-[2rem] overflow-hidden group hover:border-blue-500/50 transition-all duration-500">
                    <div class="aspect-video relative overflow-hidden">
                        <img src="<%= template.imageUrl %>" class="w-full h-full object-cover transition duration-700 group-hover:scale-110 group-hover:rotate-2">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 to-transparent opacity-60"></div>
                    </div>
                    <div class="p-6">
                        <h4 class="text-slate-200 font-bold mb-1 truncate text-sm uppercase tracking-tight"><%= template.title %></h4>
                        <p class="text-[10px] text-slate-500 mb-6 line-clamp-1"><%= template.description %></p>
                        <div class="flex items-center justify-between border-t border-slate-800/50 pt-4">
                            <div class="flex gap-2">
                                <a href="/admin/template/edit/<%= template._id %>" class="text-slate-500 hover:text-blue-400 transition">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                </a>
                                <form action="/delete/<%= template._id %>" method="POST" onsubmit="return confirm('Destroy asset?');">
                                    <button type="submit" class="text-slate-500 hover:text-red-500 transition">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </form>
                            </div>
                            <span class="text-[8px] font-black text-slate-600 uppercase tracking-widest italic">Core Asset</span>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </section>

    </div>
</main>

<%- include('partials/footer') %>
