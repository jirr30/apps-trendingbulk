<%- include('partials/header') %>

<div class="min-h-screen bg-slate-950 text-slate-200">

    <!-- Back Nav -->
    <div class="border-b border-slate-900 bg-slate-900/50">
        <div class="max-w-4xl mx-auto px-6 py-3">
            <a href="/berita" class="inline-flex items-center gap-2 text-slate-500 hover:text-amber-400 text-xs font-mono transition">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Kembali ke Berita
            </a>
        </div>
    </div>

    <!-- Grid wrapper -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 sidebar-grid">
      <main class="min-w-0">

        <!-- Meta -->
        <%
            const d = berita.createdAt;
            const ms = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
            const _wordCount = (berita.content || '').replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim().split(' ').filter(function(w){ return w; }).length;
            const _readTime  = Math.max(1, Math.round(_wordCount / 200));
        %>
        <div class="mb-6">
            <div class="flex flex-wrap items-center gap-2 mb-4">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-amber-500/10 border border-amber-500/20">
                    <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>
                    <span class="text-[10px] font-mono text-amber-400 uppercase tracking-widest"><%= berita.category || 'Berita' %></span>
                </div>
                <span class="text-[10px] font-mono text-slate-600"><%= d.getDate() + ' ' + ms[d.getMonth()] + ' ' + d.getFullYear() %></span>
                <span class="text-slate-700">·</span>
                <span class="text-[10px] font-bold text-slate-500">@<%= berita.author ? berita.author.username : 'admin' %></span>
                <span class="text-slate-700">·</span>
                <span class="text-[10px] font-mono text-slate-600"><%= _readTime %> menit baca</span>
            </div>
            <h1 class="text-2xl sm:text-3xl md:text-4xl font-black text-white leading-snug tracking-tight mb-6">
                <%= berita.title %>
            </h1>
        </div>

        <!-- Thumbnail -->
        <% if (berita.thumbnail) { %>
        <div class="rounded-2xl overflow-hidden border border-slate-800 mb-10 bg-slate-900">
            <img src="<%= berita.thumbnail %>" alt="<%= berita.title %>"
                 class="w-full object-cover max-h-[480px]">
        </div>
        <% } %>

        <!-- Content -->
        <div class="prose-berita">
            <%- berita.content %>
        </div>

        <!-- Footer -->
        <div class="mt-14 pt-8 border-t border-slate-800 space-y-6">
            <!-- Mobile share (hidden on lg where sidebar shows) -->
            <div class="lg:hidden">
                <p class="text-[10px] font-mono text-slate-600 uppercase tracking-widest mb-3">Bagikan Artikel</p>
                <div class="flex gap-2">
                    <button id="btn-copy-link-bottom"
                        onclick="navigator.clipboard.writeText(window.location.href).then(function(){var b=document.getElementById('btn-copy-link-bottom');var orig=b.innerHTML;b.classList.add('border-emerald-500/50','text-emerald-400');b.textContent='✓ Disalin!';setTimeout(function(){b.classList.remove('border-emerald-500/50','text-emerald-400');b.innerHTML=orig;},2000)})"
                        class="flex-1 flex items-center justify-center gap-1.5 py-2.5 rounded-xl bg-slate-900 border border-slate-800 hover:border-slate-600 text-slate-400 hover:text-white transition text-xs font-bold cursor-pointer">
                        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                        </svg>
                        Salin Link
                    </button>
                    <a id="btn-share-wa-bottom" href="#" target="_blank" rel="noopener"
                       class="flex-1 flex items-center justify-center gap-1.5 py-2.5 rounded-xl bg-slate-900 border border-slate-800 hover:border-green-500/40 hover:bg-green-500/10 text-slate-400 hover:text-green-400 transition text-xs font-bold">
                        <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.94 3.659 1.435 5.621 1.435h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                        </svg>
                        WhatsApp
                    </a>
                </div>
                <script>
                    (function(){
                        var wa = document.getElementById('btn-share-wa-bottom');
                        if (wa) wa.href = 'https://api.whatsapp.com/send?text=' + encodeURIComponent(document.title + ' — ' + window.location.href);
                    })();
                </script>
            </div>
            <!-- Nav -->
            <div class="flex items-center justify-between">
                <a href="/berita"
                   class="inline-flex items-center gap-2 text-xs font-bold text-slate-400 hover:text-amber-400 border border-slate-800 hover:border-amber-500/30 px-4 py-2 rounded-xl bg-slate-900/50 uppercase tracking-wider transition">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                    Berita Lainnya
                </a>
                <span class="text-[10px] font-mono text-slate-700">
                    <%= d.getDate() + ' ' + ms[d.getMonth()] + ' ' + d.getFullYear() %>
                </span>
            </div>
        </div>
      </main>

      <aside class="hidden lg:block">
        <div class="sticky top-24 py-10 flex flex-col gap-2">
          <div class="flex items-center gap-2 mb-3">
            <div class="h-7 w-1 bg-emerald-500 rounded-full shrink-0"></div>
            <div>
              <h2 class="text-sm font-black text-white tracking-tight">Jelajahi Lebih Lanjut</h2>
              <p class="text-slate-500 text-[10px] font-mono mt-0.5">Temukan lebih banyak</p>
            </div>
          </div>
          <a href="/" class="group flex items-center gap-3 p-3 bg-slate-900/60 border border-slate-800 hover:border-blue-500/50 rounded-xl transition-all duration-300 overflow-hidden">
            <div class="h-9 w-9 rounded-lg bg-blue-500/10 border border-blue-500/20 flex items-center justify-center shrink-0 group-hover:bg-blue-500/20 transition">
              <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs font-bold text-white group-hover:text-blue-300 transition truncate">Tentang Kami</p>
              <p class="text-[10px] text-slate-500 leading-snug">Sejarah & pencapaian kami</p>
            </div>
            <svg class="w-3.5 h-3.5 text-slate-600 group-hover:text-blue-400 shrink-0 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/galeri" class="group flex items-center gap-3 p-3 bg-slate-900/60 border border-slate-800 hover:border-blue-500/50 rounded-xl transition-all duration-300 overflow-hidden">
            <div class="h-9 w-9 rounded-lg bg-blue-500/10 border border-blue-500/20 flex items-center justify-center shrink-0 group-hover:bg-blue-500/20 transition">
              <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs font-bold text-white group-hover:text-blue-300 transition truncate">Galeri Foto & Video</p>
              <p class="text-[10px] text-slate-500 leading-snug">Dokumentasi kegiatan kami</p>
            </div>
            <svg class="w-3.5 h-3.5 text-slate-600 group-hover:text-blue-400 shrink-0 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/articles" class="group flex items-center gap-3 p-3 bg-slate-900/60 border border-slate-800 hover:border-emerald-500/50 rounded-xl transition-all duration-300 overflow-hidden">
            <div class="h-9 w-9 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center shrink-0 group-hover:bg-emerald-500/20 transition">
              <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs font-bold text-white group-hover:text-emerald-300 transition truncate">Artikel & Materi</p>
              <p class="text-[10px] text-slate-500 leading-snug">Naskah & materi teater</p>
            </div>
            <svg class="w-3.5 h-3.5 text-slate-600 group-hover:text-emerald-400 shrink-0 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/sekretariat" class="group flex items-center gap-3 p-3 bg-slate-900/60 border border-slate-800 hover:border-violet-500/50 rounded-xl transition-all duration-300 overflow-hidden">
            <div class="h-9 w-9 rounded-lg bg-violet-500/10 border border-violet-500/20 flex items-center justify-center shrink-0 group-hover:bg-violet-500/20 transition">
              <svg class="w-4 h-4 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs font-bold text-white group-hover:text-violet-300 transition truncate">Sekretariat</p>
              <p class="text-[10px] text-slate-500 leading-snug">Kontak & info organisasi</p>
            </div>
            <svg class="w-3.5 h-3.5 text-slate-600 group-hover:text-violet-400 shrink-0 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
          </a>
        <%- include("partials/sidebar_extras") %>
        </div>
      </aside>
    </div><!-- end grid -->
</div>

<style>
.prose-berita {
    color: #cbd5e1;
    font-size: 15px;
    line-height: 1.9;
}
.prose-berita h1, .prose-berita h2, .prose-berita h3 {
    color: #f8fafc;
    font-weight: 800;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
}
.prose-berita h1 { font-size: 1.75rem; }
.prose-berita h2 { font-size: 1.4rem; }
.prose-berita h3 { font-size: 1.15rem; }
.prose-berita h4 { font-size: 1rem; font-weight: 700; }
.prose-berita p { margin-bottom: 1.25rem; }
.prose-berita strong { color: #f1f5f9; }
.prose-berita a { color: #f59e0b; text-decoration: underline; }
.prose-berita a:hover { color: #fbbf24; }
.prose-berita img {
    max-width: 100%;
    border-radius: 12px;
    border: 1px solid #1e293b;
    margin: 1.5rem auto;
    display: block;
}
.prose-berita blockquote {
    border-left: 3px solid #f59e0b;
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: #94a3b8;
    font-style: italic;
}
.prose-berita ul, .prose-berita ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
}
.prose-berita ul { list-style-type: disc; }
.prose-berita ol { list-style-type: decimal; }
.prose-berita li { margin-bottom: 0.4rem; }
.prose-berita .table-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 1.5rem 0;
    border-radius: 8px;
    border: 1px solid #1e293b;
}
.prose-berita table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    min-width: 480px;
}
.prose-berita th, .prose-berita td {
    border: 1px solid #1e293b;
    padding: 0.6rem 0.9rem;
    text-align: left;
}
.prose-berita th { background: #0f172a; color: #f1f5f9; font-weight: 700; }
.prose-berita iframe {
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: 12px;
    border: 1px solid #1e293b;
    margin: 1.5rem 0;
}
</style>

<script>
(function(){
    document.querySelectorAll('.prose-berita table').forEach(function(t) {
        if (t.parentNode.classList.contains('table-scroll')) return;
        var w = document.createElement('div');
        w.className = 'table-scroll';
        t.parentNode.insertBefore(w, t);
        w.appendChild(t);
    });
})();
</script>

<%- include('partials/footer') %>
