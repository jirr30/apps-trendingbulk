<%- include('partials/header') %>
<style>nav { display: none !important; }</style>

<div class="min-h-screen flex items-center justify-center bg-slate-950 py-12 px-4">
    <div class="max-w-md w-full space-y-8 bg-slate-900 p-10 rounded-3xl shadow-2xl border border-slate-800">

        <!-- Icon & Heading -->
        <div class="text-center">
            <div class="mx-auto h-16 w-16 bg-violet-600/10 border border-violet-500/20 rounded-2xl flex items-center justify-center mb-6">
                <svg class="h-8 w-8 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                </svg>
            </div>
            <h2 class="text-2xl font-black text-white tracking-tighter uppercase">Verifikasi 2FA</h2>
            <p class="mt-2 text-[10px] text-slate-500 uppercase tracking-[0.3em] font-mono">Two-Factor Authentication</p>
            <p class="mt-1 text-xs text-slate-600">Buka aplikasi autentikator Anda dan masukkan kode 6 digit.</p>
        </div>

        <!-- Alerts -->
        <% if (error) { %>
        <div class="bg-red-900/40 border border-red-500/40 text-red-300 text-xs rounded-xl px-4 py-3 text-center">
            <%= error %>
        </div>
        <% } %>
        <% if (success) { %>
        <div class="bg-green-900/40 border border-green-500/40 text-green-300 text-xs rounded-xl px-4 py-3 text-center">
            <%= success %>
        </div>
        <% } %>

        <!-- Form -->
        <form class="space-y-6" action="/login/2fa" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2 ml-1">
                    Kode Autentikasi
                </label>
                <input
                    name="token"
                    type="text"
                    inputmode="numeric"
                    autocomplete="one-time-code"
                    maxlength="6"
                    pattern="[0-9]{6}"
                    required
                    autofocus
                    class="appearance-none rounded-xl block w-full px-4 py-4 bg-slate-950 border border-slate-800
                           placeholder-slate-600 text-white text-center font-mono text-2xl tracking-[0.5em]
                           focus:outline-none focus:ring-1 focus:ring-violet-500 focus:border-violet-500 transition"
                    placeholder="000000">
                <p class="text-[10px] text-slate-600 mt-2 text-center font-mono">
                    Kode berubah setiap 30 detik
                </p>
            </div>

            <button type="submit"
                class="w-full py-4 bg-violet-600 hover:bg-violet-700 text-white text-xs font-black uppercase tracking-[0.2em] rounded-xl transition shadow-lg shadow-violet-900/20">
                Verifikasi &amp; Masuk
            </button>
        </form>

        <!-- Back to login -->
        <div class="text-center pt-4 border-t border-slate-800">
            <a href="/login" class="text-xs text-slate-500 hover:text-slate-300 transition">
                ← Kembali ke halaman login
            </a>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
