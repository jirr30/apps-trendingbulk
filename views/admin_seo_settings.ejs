<%- include('partials/admin_header', { pageTitle: 'SEO & Iklan' }) %>

<div class="min-h-screen bg-slate-950">

    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10">

        <!-- Page Header -->
        <div class="mb-8">
            <div class="flex items-center gap-3 mb-2">
                <div class="h-9 w-1 bg-emerald-500 rounded-full"></div>
                <h1 class="text-xl font-black text-white tracking-tight">SEO & Iklan</h1>
            </div>
            <p class="text-slate-500 text-xs font-mono ml-4">Kelola meta tag global, Google Analytics, AdSense, dan sitemap</p>
        </div>

        <% if (typeof query !== 'undefined' && query && query.success) { %>
        <div class="mb-6 px-4 py-3 rounded-xl bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-sm font-medium">
            Pengaturan SEO berhasil disimpan.
        </div>
        <% } %>
        <% if (typeof query !== 'undefined' && query && query.error) { %>
        <div class="mb-6 px-4 py-3 rounded-xl bg-red-500/10 border border-red-500/30 text-red-400 text-sm font-medium">
            Gagal menyimpan pengaturan SEO.
        </div>
        <% } %>

        <form action="/admin/seo-settings" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <!-- SEO GLOBAL -->
            <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-6 mb-6">
                <div class="flex items-center gap-3 mb-6">
                    <div class="h-7 w-1 bg-blue-500 rounded-full"></div>
                    <h2 class="text-sm font-black text-white">SEO Global</h2>
                </div>
                <div class="space-y-5">
                    <div>
                        <label class="block text-xs font-bold text-slate-400 mb-1.5">Site Title <span class="text-slate-600 font-normal">(judul utama website di Google)</span></label>
                        <input type="text" name="siteTitle" value="<%= ss.siteTitle || '' %>" maxlength="60"
                               placeholder="Teater Saphalta — Seni Pertunjukan"
                               class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-2.5 text-sm text-white placeholder-slate-600 focus:outline-none focus:border-blue-500 transition">
                        <div class="flex justify-between mt-1">
                            <p class="text-slate-600 text-[10px]">Optimal: 50–60 karakter</p>
                            <span id="cnt-siteTitle" class="text-[10px] text-slate-600 font-mono"><%= (ss.siteTitle || '').length %>/60</span>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-400 mb-1.5">Site Description <span class="text-slate-600 font-normal">(deskripsi utama di hasil pencarian)</span></label>
                        <textarea name="siteDescription" maxlength="160" rows="3"
                                  placeholder="Teater Saphalta adalah komunitas seni pertunjukan..."
                                  class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-2.5 text-sm text-white placeholder-slate-600 focus:outline-none focus:border-blue-500 transition resize-none"><%= ss.siteDescription || '' %></textarea>
                        <div class="flex justify-between mt-1">
                            <p class="text-slate-600 text-[10px]">Optimal: 120–160 karakter</p>
                            <span id="cnt-siteDesc" class="text-[10px] text-slate-600 font-mono"><%= (ss.siteDescription || '').length %>/160</span>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-400 mb-1.5">Site Keywords <span class="text-slate-600 font-normal">(pisahkan dengan koma)</span></label>
                        <input type="text" name="siteKeywords" value="<%= ss.siteKeywords || '' %>"
                               placeholder="teater, seni pertunjukan, saphalta, teater indonesia"
                               class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-2.5 text-sm text-white placeholder-slate-600 focus:outline-none focus:border-blue-500 transition">
                        <p class="text-slate-600 text-[10px] mt-1">Contoh: teater, seni pertunjukan, naskah drama, latihan teater</p>
                    </div>
                </div>
            </div>

            <!-- GOOGLE TOOLS -->
            <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-6 mb-6">
                <div class="flex items-center gap-3 mb-6">
                    <div class="h-7 w-1 bg-blue-500 rounded-full"></div>
                    <h2 class="text-sm font-black text-white">Google Tools</h2>
                </div>
                <div class="space-y-5">
                    <div>
                        <label class="block text-xs font-bold text-slate-400 mb-1.5">
                            Google Analytics Tracking ID
                            <span class="ml-2 px-2 py-0.5 rounded-md bg-blue-500/10 text-blue-400 text-[10px] font-mono border border-blue-500/20">GA4</span>
                        </label>
                        <input type="text" name="gaTrackingId" value="<%= ss.gaTrackingId || '' %>"
                               placeholder="G-XXXXXXXXXX"
                               class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-2.5 text-sm text-white font-mono placeholder-slate-600 focus:outline-none focus:border-blue-500 transition">
                        <p class="text-slate-600 text-[10px] mt-1">Dapatkan dari: <span class="text-slate-500">analytics.google.com → Admin → Data Streams → Measurement ID</span></p>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-400 mb-1.5">
                            Google Search Console Verification
                            <span class="ml-2 px-2 py-0.5 rounded-md bg-emerald-500/10 text-emerald-400 text-[10px] font-mono border border-emerald-500/20">GSC</span>
                        </label>
                        <input type="text" name="searchConsoleVerification" value="<%= ss.searchConsoleVerification || '' %>"
                               placeholder="kode-verifikasi-dari-gsc"
                               class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-2.5 text-sm text-white font-mono placeholder-slate-600 focus:outline-none focus:border-blue-500 transition">
                        <p class="text-slate-600 text-[10px] mt-1">
                            Dari Search Console → Settings → Ownership Verification → HTML Tag → salin hanya isi <span class="text-slate-500 font-mono">content="..."</span>
                        </p>
                    </div>
                </div>
            </div>

            <!-- GOOGLE ADSENSE -->
            <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-6 mb-6">
                <div class="flex items-center gap-3 mb-2">
                    <div class="h-7 w-1 bg-amber-500 rounded-full"></div>
                    <h2 class="text-sm font-black text-white">Google AdSense</h2>
                    <span class="ml-2 px-2 py-0.5 rounded-md bg-amber-500/10 text-amber-400 text-[10px] font-bold border border-amber-500/20">Iklan</span>
                </div>
                <p class="text-slate-600 text-xs ml-4 mb-6">Pasang iklan Google untuk menghasilkan pendapatan dari traffic website</p>
                <div class="space-y-5">
                    <div>
                        <label class="block text-xs font-bold text-slate-400 mb-1.5">
                            AdSense Account Verification
                            <span class="ml-2 px-2 py-0.5 rounded-md bg-amber-500/10 text-amber-400 text-[10px] font-mono border border-amber-500/20">Verify</span>
                        </label>
                        <input type="text" name="adsenseAccountVerification" value="<%= ss.adsenseAccountVerification || '' %>"
                               placeholder="ca-pub-XXXXXXXXXXXXXXXX"
                               class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-2.5 text-sm text-white font-mono placeholder-slate-600 focus:outline-none focus:border-amber-500 transition">
                        <p class="text-slate-600 text-[10px] mt-1">Salin hanya isi <span class="text-slate-500 font-mono">content="..."</span> dari tag <span class="text-slate-500 font-mono">&lt;meta name="google-adsense-account"&gt;</span></p>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-400 mb-1.5">AdSense Publisher ID</label>
                        <input type="text" name="adsensePublisherId" value="<%= ss.adsensePublisherId || '' %>"
                               placeholder="ca-pub-XXXXXXXXXXXXXXXX"
                               class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-2.5 text-sm text-white font-mono placeholder-slate-600 focus:outline-none focus:border-amber-500 transition">
                        <p class="text-slate-600 text-[10px] mt-1">Dapatkan dari: <span class="text-slate-500">adsense.google.com → Account → Account information → Publisher ID</span></p>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-400 mb-1.5">
                            AdSense Auto Ads Code
                            <span class="ml-2 px-2 py-0.5 rounded-md bg-slate-800 text-slate-500 text-[10px] font-mono border border-slate-700">opsional</span>
                        </label>
                        <textarea name="adsenseAutoCode" rows="5"
                                  placeholder='<script async src="https://pagead2..."></script>&#10;<ins class="adsbygoogle" ...></ins>'
                                  class="w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-2.5 text-xs text-white font-mono placeholder-slate-600 focus:outline-none focus:border-amber-500 transition resize-none"><%= ss.adsenseAutoCode || '' %></textarea>
                        <p class="text-slate-600 text-[10px] mt-1">Paste kode Auto Ads lengkap dari AdSense jika ingin mengaktifkan iklan otomatis di seluruh halaman</p>
                    </div>
                </div>
            </div>

            <!-- SITEMAP INFO -->
            <div class="bg-slate-900/40 border border-slate-800/60 rounded-2xl p-5 mb-6">
                <div class="flex items-center gap-3 mb-4">
                    <div class="h-7 w-1 bg-violet-500 rounded-full"></div>
                    <h2 class="text-sm font-black text-white">Sitemap & Robots</h2>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="bg-slate-900 border border-slate-800 rounded-xl p-4">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-xs font-bold text-slate-300">sitemap.xml</span>
                            <span class="text-[10px] px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 font-mono">Aktif</span>
                        </div>
                        <p class="text-slate-600 text-[10px] leading-relaxed mb-3">Auto-generate semua URL berita, artikel, dan halaman statis</p>
                        <a href="/sitemap.xml" target="_blank" class="inline-flex items-center gap-1 text-[10px] font-black uppercase tracking-widest text-violet-400 hover:text-violet-300 transition">
                            Lihat Sitemap
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                        </a>
                    </div>
                    <div class="bg-slate-900 border border-slate-800 rounded-xl p-4">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-xs font-bold text-slate-300">robots.txt</span>
                            <span class="text-[10px] px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 font-mono">Aktif</span>
                        </div>
                        <p class="text-slate-600 text-[10px] leading-relaxed mb-3">Mengarahkan crawler Google ke sitemap secara otomatis</p>
                        <a href="/robots.txt" target="_blank" class="inline-flex items-center gap-1 text-[10px] font-black uppercase tracking-widest text-violet-400 hover:text-violet-300 transition">
                            Lihat Robots
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                        </a>
                    </div>
                </div>
                <div class="mt-4 p-3 bg-blue-500/5 border border-blue-500/20 rounded-xl">
                    <p class="text-blue-400 text-[10px] font-bold mb-1">Cara submit sitemap ke Google Search Console:</p>
                    <ol class="text-slate-500 text-[10px] space-y-0.5 list-decimal list-inside">
                        <li>Buka <span class="text-slate-400">search.google.com/search-console</span></li>
                        <li>Pilih property website Anda</li>
                        <li>Klik menu <span class="text-slate-400">Sitemaps</span> di sidebar</li>
                        <li>Masukkan: <span class="text-slate-400 font-mono">sitemap.xml</span> → klik Submit</li>
                    </ol>
                </div>
            </div>

            <!-- ACTIONS -->
            <div class="flex items-center gap-3">
                <button type="submit" class="px-6 py-2.5 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-bold rounded-xl transition shadow-lg shadow-emerald-900/30">
                    Simpan Pengaturan SEO
                </button>
                <a href="/dashboard" class="px-6 py-2.5 border border-slate-700 hover:border-slate-500 text-slate-400 hover:text-white text-sm font-bold rounded-xl transition">
                    Kembali
                </a>
            </div>

        </form>
    </div>
</div>

<script>
function charCounter(inputId, counterId, max) {
    const el = document.querySelector('[name="' + inputId + '"]');
    const cnt = document.getElementById(counterId);
    if (!el || !cnt) return;
    el.addEventListener('input', function() {
        const len = this.value.length;
        cnt.textContent = len + '/' + max;
        cnt.className = len > max ? 'text-[10px] font-mono text-amber-400' : 'text-[10px] font-mono text-slate-600';
    });
}
charCounter('siteTitle', 'cnt-siteTitle', 60);
charCounter('siteDescription', 'cnt-siteDesc', 160);
</script>

<%- include('partials/footer') %>
