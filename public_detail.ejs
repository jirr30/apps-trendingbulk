<%- include('partials/header') %>

<div class="min-h-screen bg-slate-950 text-slate-200">
    <div class="max-w-5xl mx-auto p-6">
        <a href="/" class="text-blue-400 hover:text-blue-300 flex items-center gap-2 transition group">
            <svg class="w-5 h-5 group-hover:-translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Kembali ke Katalog
        </a>
    </div>

    <main class="max-w-5xl mx-auto p-6 grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div class="rounded-3xl overflow-hidden border border-slate-800 shadow-2xl bg-slate-900">
            <img src="<%= item.imageUrl %>" alt="<%= item.title %>" class="w-full h-auto object-cover">
        </div>

        <div class="space-y-6">
            <div class="border-b border-slate-800 pb-6">
                <span class="text-blue-500 font-mono text-xs uppercase tracking-widest">Template Detail</span>
                <h1 class="text-4xl font-extrabold text-white mt-2 leading-tight"><%= item.title %></h1>
                <p class="text-slate-500 text-sm mt-4 italic">Diunggah pada: <%= item.createdAt.toLocaleDateString('id-ID', { dateStyle: 'full' }) %></p>
            </div>

            <div class="prose prose-invert max-w-none">
                <h3 class="text-lg font-semibold text-slate-300 mb-2 underline decoration-blue-500 underline-offset-8">Deskripsi Projek:</h3>
                <p class="text-slate-400 leading-relaxed"><%= item.description %></p>
            </div>

            <div class="pt-8 flex flex-col sm:flex-row gap-4">
                <button onclick="window.print()" class="flex-1 px-6 py-4 bg-slate-800 hover:bg-slate-700 text-white font-bold rounded-xl transition flex items-center justify-center gap-2 border border-slate-700 shadow-lg">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                    Simpan PDF
                </button>

                <a href="https://api.whatsapp.com/send?text=Halo, cek template *<%= item.title %>* ini: <%= appUrl %>/detail/<%= item._id %>"
                   target="_blank"
                   class="flex-1 px-6 py-4 bg-green-600 hover:bg-green-700 text-white font-bold rounded-xl transition flex items-center justify-center gap-2 shadow-lg shadow-green-900/20">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    Share WhatsApp
                </a>
            </div>
        </div>
    </main>
</div>

<%- include('partials/footer') %>
